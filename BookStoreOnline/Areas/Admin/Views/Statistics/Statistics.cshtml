@model IEnumerable<BookStoreOnline.Models.SANPHAM>

@{
    ViewBag.Title = "Thống Kê Doanh Thu & Sản Phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";

    // Ép kiểu các dữ liệu nhận từ Controller
    var productStats = ViewBag.ProductStats as List<BookStoreOnline.Areas.Admin.Controllers.ProductStatViewModel>;
    var categoryStats = ViewBag.CategoryStats as List<BookStoreOnline.Areas.Admin.Controllers.CategoryStatViewModel> ?? new List<BookStoreOnline.Areas.Admin.Controllers.CategoryStatViewModel>();
    var publisherStats = ViewBag.PublisherStats as List<BookStoreOnline.Areas.Admin.Controllers.PublisherStatViewModel> ?? new List<BookStoreOnline.Areas.Admin.Controllers.PublisherStatViewModel>();
    var quarterlyRevenue = ViewBag.QuarterlyRevenue as decimal[] ?? new decimal[4];
    var monthlyRevenue = ViewBag.MonthlyRevenue as decimal[] ?? new decimal[12];

    var totalQuantityInStock = ViewBag.TotalQuantityInStock;
    var totalQuantitySold = ViewBag.TotalQuantitySold;

    // ĐÃ SỬA: Đồng bộ hóa nhận giá trị tổng doanh thu theo năm thay vì toàn thời gian
    var totalRevenue = ViewBag.TotalRevenueInYear;

    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .page-title {
        font-size: 20px;
        font-weight: 800;
        color: #0f172a;
    }

        .page-title span {
            color: #e8392a;
        }

    /* Year Filter */
    .filter-section {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .filter-select {
        padding: 6px 12px;
        border: 1px solid #cbd5e1;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 600;
        color: #334155;
        outline: none;
    }

    /* Stats Layout */
    .stat-cards {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        margin-bottom: 28px;
    }

    .stat-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        padding: 24px 20px;
        display: flex;
        align-items: center;
        gap: 18px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        transition: all 0.2s;
    }

        .stat-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 24px rgba(0,0,0,0.08);
        }

    .stat-icon {
        width: 56px;
        height: 56px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 24px;
        flex-shrink: 0;
    }

        .stat-icon.blue {
            background: #eff6ff;
            color: #3b82f6;
        }

        .stat-icon.green {
            background: #f0fdf4;
            color: #22c55e;
        }

        .stat-icon.amber {
            background: #fffbeb;
            color: #f59e0b;
        }

    .stat-label {
        font-size: 12px;
        color: #64748b;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
    }

    .stat-value {
        font-size: 24px;
        font-weight: 800;
        color: #0f172a;
    }

    /* Chart Layout */
    .charts-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 20px;
        margin-bottom: 28px;
    }

    .chart-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    }

    .chart-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 20px;
    }

    .chart-card-title {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .canvas-container {
        position: relative;
        height: 340px;
        width: 100%;
    }

    /* Custom Navigation Tabs */
    .custom-tabs {
        display: flex;
        gap: 8px;
        padding: 12px 24px;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
    }

    .tab-btn {
        background: none;
        border: none;
        padding: 8px 16px;
        font-size: 13px;
        font-weight: 700;
        color: #64748b;
        border-radius: 8px;
        transition: all 0.2s;
    }

        .tab-btn:hover {
            background: #f1f5f9;
            color: #0f172a;
        }

        .tab-btn.active {
            background: #fff;
            color: #e8392a;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }

    /* Table Card */
    .section-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .section-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .section-card-title {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .badge-num {
        background: #f1f5f9;
        color: #475569;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 700;
        padding: 3px 10px;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table thead th {
            background: #f8fafc;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #64748b;
            padding: 12px 16px;
            border-bottom: 1px solid #e2e8f0;
            text-align: left;
        }

        .admin-table tbody tr {
            border-bottom: 1px solid #f1f5f9;
            transition: background 0.15s;
        }

            .admin-table tbody tr:hover {
                background: #f8fafc;
            }

            .admin-table tbody tr:last-child {
                border-bottom: none;
            }

        .admin-table tbody td {
            padding: 14px 16px;
            font-size: 13px;
            color: #334155;
        }

    .tab-content-panel {
        display: none;
    }

        .tab-content-panel.active {
            display: block;
        }

    @@media (max-width: 992px) {
        .stat-cards {
            grid-template-columns: 1fr;
        }

        .charts-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="page-header">
    <div class="page-title">Thống Kê <span>Sản Phẩm & Doanh Thu</span></div>

    <form method="get" action="@Url.Action("Statistics", "Statistics", new { area = "Admin" })" class="filter-section">
        <span class="text-secondary fw-bold small">Năm báo cáo:</span>
        <select name="year" class="filter-select" onchange="this.form.submit()">
            @for (int i = DateTime.Now.Year - 3; i <= DateTime.Now.Year; i++)
            {
                <option value="@i" @(i == ViewBag.SelectedYear ? "selected" : "")>@i</option>
            }
        </select>
    </form>
</div>

<div class="stat-cards">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="bi bi-box-seam-fill"></i></div>
        <div>
            <div class="stat-label">Tổng Tồn Kho</div>
            <div class="stat-value">@(totalQuantityInStock != null ? string.Format("{0:N0}", totalQuantityInStock) : "0") cuốn</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="bi bi-cart-check-fill"></i></div>
        <div>
            <div class="stat-label">Tổng Số Lượng Đã Bán</div>
            <div class="stat-value">@(totalQuantitySold != null ? string.Format("{0:N0}", totalQuantitySold) : "0") cuốn</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="bi bi-cash-coin"></i></div>
        <div>
            <div class="stat-label">Tổng Doanh Thu</div>
            <div class="stat-value">@(totalRevenue != null ? string.Format(price, "{0:C}", totalRevenue) : "0 ₫")</div>
        </div>
    </div>
</div>

<div class="charts-grid">
    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title"><i class="bi bi-calendar-range-fill me-2" style="color:#3b82f6"></i>Doanh Thu Xu Hướng 12 Tháng (Năm @ViewBag.SelectedYear)</div>
        </div>
        <div class="canvas-container">
            <canvas id="monthlyRevenueChart"></canvas>
        </div>
    </div>

    <div class="chart-card">
        <div class="chart-card-header">
            <div class="chart-card-title"><i class="bi bi-pie-chart-fill me-2" style="color:#22c55e"></i>Cơ Cấu Thể Loại</div>
        </div>
        <div class="canvas-container" style="display:flex; justify-content:center; align-items:center;">
            <canvas id="categoryPieChart"></canvas>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="custom-tabs">
        <button class="tab-btn active" onclick="switchTab(event, 'tab-sach')">Theo Sản Phẩm</button>
        <button class="tab-btn" onclick="switchTab(event, 'tab-quy')">Theo Quý</button>
        <button class="tab-btn" onclick="switchTab(event, 'tab-theloai')">Theo Thể Loại</button>
        <button class="tab-btn" onclick="switchTab(event, 'tab-nxb')">Theo Tác Giả / NXB</button>
    </div>

    <div id="tab-sach" class="tab-content-panel active">
        <div class="section-card-header">
            <span class="section-card-title"><i class="bi bi-list-stars me-2" style="color:#e8392a"></i>Chi Tiết Hiệu Suất Sản Phẩm</span>
            <span class="badge-num">@(productStats != null ? productStats.Count : 0) sản phẩm</span>
        </div>
        <div class="table-responsive" style="max-height: 420px; overflow-y: auto;">
            <table class="admin-table">
                <thead style="position: sticky; top: 0; z-index: 10;">
                    <tr>
                        <th>Tên Sản Phẩm</th>
                        <th style="width: 180px;">Số Lượng Tồn Kho</th>
                        <th style="width: 180px;">Số Lượng Đã Bán</th>
                        <th style="width: 220px;">Tổng Doanh Thu</th>
                    </tr>
                </thead>
                <tbody>
                    @if (productStats != null && productStats.Any())
                    {
                        foreach (var product in productStats)
                        {
                            <tr>
                                <td><strong>@product.ProductName</strong></td>
                                <td>@product.QuantityInStock.ToString("N0")</td>
                                <td>@product.QuantitySold.ToString("N0")</td>
                                <td><strong style="color:#22c55e;">@product.TotalRevenue.ToString("C", price)</strong></td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div id="tab-quy" class="tab-content-panel">
        <div class="section-card-header">
            <span class="section-card-title"><i class="bi bi-clock-history me-2" style="color:#3b82f6"></i>Phân Bổ Doanh Thu Theo Quý (Năm @ViewBag.SelectedYear)</span>
        </div>
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Mốc Thời Gian</th>
                        <th style="text-align: right; padding-right: 40px;">Doanh Thu Đạt Được (VND)</th>
                    </tr>
                </thead>
                <tbody>
                    @for (int i = 0; i < quarterlyRevenue.Length; i++)
                    {
                        <tr>
                            <td><strong>Quý @(i + 1) (Năm @ViewBag.SelectedYear)</strong></td>
                            <td style="text-align: right; padding-right: 40px;"><strong style="color:#3b82f6;">@quarterlyRevenue[i].ToString("C", price)</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div id="tab-theloai" class="tab-content-panel">
        <div class="section-card-header">
            <span class="section-card-title"><i class="bi bi-tags-fill me-2" style="color:#22c55e"></i>Thống Kê Hiệu Suất Nhóm Thể Loại</span>
        </div>
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Tên Thể Loại</th>
                        <th style="width: 250px;">Số Lượng Đã Bán</th>
                        <th style="width: 300px;">Tổng Doanh Thu đạt được</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var cat in categoryStats)
                    {
                        <tr>
                            <td><strong>@cat.CategoryName</strong></td>
                            <td>@cat.TotalQuantitySold.ToString("N0") cuốn</td>
                            <td><strong style="color:#22c55e;">@cat.TotalRevenue.ToString("C", price)</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <div id="tab-nxb" class="tab-content-panel">
        <div class="section-card-header">
            <span class="section-card-title"><i class="bi bi-person-bounding-box me-2" style="color:#f59e0b"></i>Báo Cáo Doanh Số Theo Tác Giả / Nhà Xuất Bản</span>
        </div>
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Tên Tác Giả / Nhà Xuất Bản</th>
                        <th style="width: 250px;">Số Lượng Bán Ra</th>
                        <th style="width: 300px;">Tổng Doanh Thu</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var pub in publisherStats)
                    {
                        <tr>
                            <td><strong>@pub.PublisherName</strong></td>
                            <td>@pub.TotalQuantitySold.ToString("N0") cuốn</td>
                            <td><strong style="color:#f59e0b;">@pub.TotalRevenue.ToString("C", price)</strong></td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    // Hàm chuyển đổi Tab không cần reload trang
    function switchTab(evt, tabId) {
        var i, tabcontent, tablinks;
        tabcontent = document.getElementsByClassName("tab-content-panel");
        for (i = 0; i < tabcontent.length; i++) {
            tabcontent[i].classList.remove("active");
        }
        tablinks = document.getElementsByClassName("tab-btn");
        for (i = 0; i < tablinks.length; i++) {
            tablinks[i].classList.remove("active");
        }
        document.getElementById(tabId).classList.add("active");
        evt.currentTarget.classList.add("active");
    }

    document.addEventListener("DOMContentLoaded", function() {
        // --- 1. KHỞI TẠO BIỂU ĐỒ XU HƯỚNG 12 THÁNG ---
        var ctxMonthly = document.getElementById('monthlyRevenueChart').getContext('2d');
        var monthlyData = @Html.Raw(Json.Encode(monthlyRevenue));

        new Chart(ctxMonthly, {
            type: 'line',
            data: {
                labels: ['T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7', 'T8', 'T9', 'T10', 'T11', 'T12'],
                datasets: [{
                    label: 'Doanh thu sản sinh (VND)',
                    data: monthlyData,
                    borderColor: 'rgba(59, 130, 246, 1)',
                    backgroundColor: 'rgba(59, 130, 246, 0.05)',
                    borderWidth: 3,
                    pointRadius: 4,
                    tension: 0.3,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        grid: { color: '#f1f5f9' },
                        ticks: {
                            callback: function(value) { return value.toLocaleString('vi-VN') + ' ₫'; }
                        }
                    },
                    x: { grid: { display: false } }
                }
            }
        });

        // --- 2. KHỞI TẠO BIỂU ĐỒ TRÒN CƠ CẤU THỂ LOẠI ---
        var ctxPie = document.getElementById('categoryPieChart').getContext('2d');
        var catLabels = [];
        var catRevenues = [];

        @foreach (var c in categoryStats.Take(5))
        {
            <text>
                catLabels.push('@Html.Raw(c.CategoryName)');
                catRevenues.push(@c.TotalRevenue);
            </text>
        }

        new Chart(ctxPie, {
            type: 'doughnut', // Dạng bánh Doughnut hiện đại
            data: {
                labels: catLabels,
                datasets: [{
                    data: catRevenues,
                    backgroundColor: ['#3b82f6', '#22c55e', '#f59e0b', '#ec4899', '#6366f1'],
                    borderWidth: 2,
                    hoverOffset: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { position: 'bottom', labels: { boxWidth: 12, usePointStyle: true } }
                }
            }
        });
    });
</script>