@{
    ViewBag.Title = "Trang Tổng Quan";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var admin = Session["TaiKhoan"] as BookStoreOnline.Models.NHANVIEN;
    if (admin == null) { Response.Redirect("~/Home/Index"); }
    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
}

<style>
    .dash-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }
    .dash-title { font-size: 22px; font-weight: 800; color: #0f172a; }
    .dash-title span { color: #e8392a; }
    .dash-clock {
        font-size: 13px; color: #64748b; font-weight: 500;
        background: #fff; border: 1px solid #e2e8f0;
        border-radius: 8px; padding: 8px 16px;
    }
    .stat-cards { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; margin-bottom: 28px; }
    .stat-card {
        background: #fff; border-radius: 16px;
        border: 1px solid #f1f5f9;
        padding: 24px 20px;
        display: flex; align-items: center; gap: 18px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        transition: all 0.2s;
    }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
    .stat-icon {
        width: 56px; height: 56px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 24px; flex-shrink: 0;
    }
    .stat-icon.blue  { background: #eff6ff; color: #3b82f6; }
    .stat-icon.red   { background: #fef2f2; color: #e8392a; }
    .stat-icon.green { background: #f0fdf4; color: #22c55e; }
    .stat-icon.amber { background: #fffbeb; color: #f59e0b; }
    .stat-label { font-size: 12px; color: #64748b; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
    .stat-value { font-size: 26px; font-weight: 800; color: #0f172a; }
    .stat-sub { font-size: 11px; color: #94a3b8; margin-top: 2px; }

    .section-card {
        background: #fff; border-radius: 16px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        overflow: hidden;
    }
    .section-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex; align-items: center; justify-content: space-between;
    }
    .section-card-title { font-size: 15px; font-weight: 700; color: #0f172a; }
    .admin-table { width: 100%; border-collapse: collapse; }
    .admin-table thead th {
        background: #f8fafc; font-size: 11px; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.6px;
        color: #64748b; padding: 12px 16px;
        border-bottom: 1px solid #e2e8f0; text-align: left;
    }
    .admin-table tbody tr { border-bottom: 1px solid #f1f5f9; transition: background 0.15s; }
    .admin-table tbody tr:hover { background: #f8fafc; }
    .admin-table tbody tr:last-child { border-bottom: none; }
    .admin-table tbody td { padding: 12px 16px; font-size: 13px; color: #334155; }
    .badge-status {
        display: inline-block; padding: 3px 10px;
        border-radius: 20px; font-size: 11px; font-weight: 600;
    }
    .badge-processing { background:#fef9c3; color:#854d0e; }
    .badge-confirmed  { background:#dcfce7; color:#166534; }
    .badge-shipping   { background:#dbeafe; color:#1e40af; }
    .badge-received   { background:#f0fdf4; color:#15803d; }
    .badge-canceled   { background:#fee2e2; color:#991b1b; }
    @@media (max-width: 1200px) { .stat-cards { grid-template-columns: repeat(2, 1fr); } }
    @@media (max-width: 768px) { .stat-cards { grid-template-columns: 1fr; } }
</style>

<div class="dash-header">
    <div class="dash-title">Trang <span>Tổng Quan</span></div>
    <div class="dash-clock" id="clock">Đang tải...</div>
</div>

<div class="stat-cards">
    <div class="stat-card">
        <div class="stat-icon blue"><i class="bi bi-people-fill"></i></div>
        <div>
            <div class="stat-label">Khách Hàng</div>
            <div class="stat-value">@ViewBag.SoLuongKhachHang</div>
            <div class="stat-sub">Tổng khách hàng đang quản lý</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red"><i class="bi bi-book-fill"></i></div>
        <div>
            <div class="stat-label">Sản Phẩm</div>
            <div class="stat-value">@ViewBag.TongSanPham</div>
            <div class="stat-sub">Tổng số sách trong hệ thống</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber"><i class="bi bi-cart-fill"></i></div>
        <div>
            <div class="stat-label">Đơn Hàng</div>
            <div class="stat-value">@ViewBag.TongDonHang</div>
            <div class="stat-sub">Tổng đơn hàng trong tháng</div>
        </div>
    </div>
    <div class="stat-card">
        <div class="stat-icon green"><i class="bi bi-tags-fill"></i></div>
        <div>
            <div class="stat-label">Thể Loại</div>
            <div class="stat-value">@ViewBag.TongLoai</div>
            <div class="stat-sub">Tổng loại sản phẩm hiện có</div>
        </div>
    </div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <span class="section-card-title"><i class="bi bi-receipt me-2" style="color:#e8392a"></i>Đơn Hàng Gần Đây</span>
        <a href="/Admin/OrdersAdmin?status=0" style="font-size:13px; color:#e8392a; text-decoration:none; font-weight:600;">Xem tất cả →</a>
    </div>
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Mã Đơn</th>
                    <th>Tên Khách Hàng</th>
                    <th>Tổng Tiền</th>
                    <th>Trạng Thái</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in ViewBag.DonHangs as List<BookStoreOnline.Models.DONHANG>)
                {
                    <tr>
                        <td><strong>#@order.MaDonHang</strong></td>
                        <td>@order.KHACHHANG.Ten</td>
                        <td style="font-weight:600; color:#e8392a;">@order.TongTien.ToString("C", price)</td>
                        <td>
                            @switch (order.TrangThai)
                            {
                                case 0: <span class="badge-status badge-processing">Chờ xác nhận</span> break;
                                case 1: <span class="badge-status badge-confirmed">Đã xác nhận</span> break;
                                case 2: <span class="badge-status badge-shipping">Đang giao hàng</span> break;
                                case 3: <span class="badge-status badge-received">Đã nhận hàng</span> break;
                                case 4: <span class="badge-status badge-canceled">Đã hủy</span> break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function updateClock() {
        var weekday = ["Chủ Nhật","Thứ Hai","Thứ Ba","Thứ Tư","Thứ Năm","Thứ Sáu","Thứ Bảy"];
        var now = new Date();
        var h = String(now.getHours()).padStart(2,'0');
        var m = String(now.getMinutes()).padStart(2,'0');
        var s = String(now.getSeconds()).padStart(2,'0');
        var dd = String(now.getDate()).padStart(2,'0');
        var mm = String(now.getMonth()+1).padStart(2,'0');
        var day = weekday[now.getDay()];
        document.getElementById('clock').innerText = day + ', ' + dd + '/' + mm + '/' + now.getFullYear() + '  ' + h + ':' + m + ':' + s;
        setTimeout(updateClock, 1000);
    }
    updateClock();
</script>
