@model IEnumerable<BookStoreOnline.Models.KHACHHANG>
@{
    ViewBag.Title = "Danh Sách Khách Hàng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    int currentPage = ViewBag.CurrentPage ?? 1;
}

<style>
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .page-title {
        font-size: 20px;
        font-weight: 800;
        color: #0f172a;
    }

        .page-title span {
            color: #e8392a;
        }

    .section-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .section-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

    .section-card-title {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .count-badge {
        background: #f1f5f9;
        color: #475569;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 700;
        padding: 3px 10px;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table thead th {
            background: #f8fafc;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #64748b;
            padding: 12px 16px;
            border-bottom: 1px solid #e2e8f0;
            text-align: left;
        }

        .admin-table tbody tr {
            border-bottom: 1px solid #f1f5f9;
            transition: background 0.15s;
        }

            .admin-table tbody tr:hover {
                background: #f8fafc;
            }

            .admin-table tbody tr:last-child {
                border-bottom: none;
            }

        .admin-table tbody td {
            padding: 14px 16px;
            font-size: 13px;
            color: #334155;
            vertical-align: middle;
        }

    .stt-badge {
        background: #f1f5f9;
        color: #475569;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 700;
        padding: 3px 10px;
    }

    .status-active {
        background: #dcfce7;
        color: #166534;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
        display: inline-block;
    }

    .status-disabled {
        background: #fee2e2;
        color: #991b1b;
        border-radius: 20px;
        padding: 3px 10px;
        font-size: 11px;
        font-weight: 700;
        display: inline-block;
    }

    .action-group {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .btn-action-info {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #e0f2fe;
        color: #0369a1;
        border: none;
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .btn-action-info:hover {
            background: #bae6fd;
            color: #075985;
            text-decoration: none;
        }

    .btn-action-warn {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #fef3c7;
        color: #92400e;
        border: none;
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .btn-action-warn:hover {
            background: #fde68a;
            color: #78350f;
            text-decoration: none;
        }

    .btn-action-del {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #fee2e2;
        color: #991b1b;
        border: none;
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        white-space: nowrap;
    }

        .btn-action-del:hover {
            background: #fecaca;
            color: #7f1d1d;
            text-decoration: none;
        }

    .user-avatar {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: linear-gradient(135deg,#3b82f6,#60a5fa);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-weight: 800;
        font-size: 14px;
        flex-shrink: 0;
    }

    .user-info {
        display: flex;
        align-items: center;
        gap: 10px;
    }

    .user-name {
        font-weight: 700;
        color: #0f172a;
        font-size: 13px;
    }

    .user-email {
        font-size: 11px;
        color: #64748b;
    }

    .empty-state {
        text-align: center;
        padding: 48px 20px;
        color: #94a3b8;
    }

        .empty-state i {
            font-size: 40px;
            margin-bottom: 12px;
            display: block;
        }

    /* Thêm CSS phân trang thống nhất */
    .pagination-container {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .page-link-custom {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 32px;
        height: 32px;
        padding: 0 10px;
        font-size: 13px;
        font-weight: 600;
        color: #475569;
        background: #f1f5f9;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s;
    }

        .page-link-custom:hover {
            background: #e2e8f0;
            color: #0f172a;
            text-decoration: none;
        }

        .page-link-custom.active {
            background: linear-gradient(135deg, #e8392a, #ff6b5b);
            color: #fff;
            box-shadow: 0 4px 10px rgba(232,57,42,0.25);
        }

        .page-link-custom.disabled {
            opacity: 0.5;
            pointer-events: none;
        }
</style>

<div class="page-header">
    <div class="page-title">Quản Lý <span>Khách Hàng</span></div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <span class="section-card-title"><i class="bi bi-people-fill me-2" style="color:#e8392a"></i>Danh Sách Tài Khoản Người Dùng</span>
        <span class="count-badge">@Model.Count() khách hàng</span>
    </div>
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th style="width:60px">STT</th>
                    <th>Tên Khách Hàng</th>
                    <th>Địa Chi</th>
                    <th>Trạng Thái</th>
                    <th>Ngày Tạo</th>
                    <th style="width:280px; text-align:center;">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    int pageSize = 5;
                    int stt = ((currentPage - 1) * pageSize) + 1;
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><span class="stt-badge">@stt</span></td>
                            <td>
                                <div class="user-info">
                                    <div class="user-avatar">@(item.Ten != null && item.Ten.Length > 0 ? item.Ten[0].ToString().ToUpper() : "K")</div>
                                    <div>
                                        <div class="user-name">@Html.DisplayFor(modelItem => item.Ten)</div>
                                        <div class="user-email">@Html.DisplayFor(modelItem => item.Email)</div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                @if (string.IsNullOrEmpty(item.DiaChi))
                                {
                                    <span class="text-muted" style="font-style:italic; font-size:12px;">Chưa cập nhật</span>
                                }
                                else
                                {
                                    @Html.DisplayFor(modelItem => item.DiaChi)
                                }
                            </td>
                            <td>
                                @if (item.TrangThai == true)
                                {
                                    <span class="status-active">
                                        <i class="bi bi-check-circle-fill me-1"></i>Kích Hoạt
                                    </span>
                                }
                                else
                                {
                                    <span class="status-disabled">
                                        <i class="bi bi-x-circle-fill me-1"></i>Vô Hiệu Hóa
                                    </span>
                                }
                            </td>
                            <td>
                                @(item.NgayTao.HasValue ? item.NgayTao.Value.ToString("dd/MM/yyyy") : "N/A")
                            </td>
                            <td>
                                <div class="action-group" style="justify-content:center;">
                                    <a href="@Url.Action("Details", new { id = item.MaKH })" class="btn-action-info">
                                        <i class="bi bi-eye-fill"></i> Chi Tiết
                                    </a>

                                    @if (item.TrangThai == true)
                                    {
                                        <a href="@Url.Action("DisableAccount", new { id = item.MaKH })" class="btn-action-warn">
                                            <i class="bi bi-lock-fill"></i> Khóa
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="@Url.Action("EnableAccount", new { id = item.MaKH })" class="btn-action-info" style="background:#dcfce7; color:#15803d;">
                                            <i class="bi bi-unlock-fill"></i> Mở Khóa
                                        </a>
                                    }

                                    <a href="@Url.Action("Delete", new { id = item.MaKH })" class="btn-action-del">
                                        <i class="bi bi-trash-fill"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                        stt++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6">
                            <div class="empty-state">
                                <i class="bi bi-people"></i>
                                Không tìm thấy khách hàng nào trong hệ thống.
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="d-flex justify-content-between align-items-center p-3 border-top" style="background: #f8fafc;">
            <span style="font-size: 13px; color: #64748b;">
                Trang <strong>@currentPage</strong> / @ViewBag.TotalPages
            </span>
            <div class="pagination-container d-flex gap-1">
                <a href="@Url.Action("Index", new { page = currentPage - 1 })"
                   class="page-link-custom @(currentPage == 1 ? "disabled" : "")">
                    <i class="bi bi-chevron-left"></i> Trước
                </a>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="@Url.Action("Index", new { page = i })"
                       class="page-link-custom @(currentPage == i ? "active" : "")">
                        @i
                    </a>
                }

                <a href="@Url.Action("Index", new { page = currentPage + 1 })"
                   class="page-link-custom @(currentPage == ViewBag.TotalPages ? "disabled" : "")">
                    Sau <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        </div>
    }
</div>