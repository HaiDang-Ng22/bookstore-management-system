@model IEnumerable<BookStoreOnline.Models.SANPHAM>

@{
    ViewBag.Title = "Danh Sách Sách";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; }
    .page-title { font-size:20px; font-weight:800; color:#0f172a; }
    .page-title span { color:#e8392a; }
    .toolbar { display:flex; align-items:center; gap:12px; }
    .search-wrap { position:relative; }
    .search-wrap i { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#94a3b8; font-size:14px; }
    .search-input {
        padding:10px 14px 10px 36px; border:1.5px solid #e2e8f0;
        border-radius:10px; font-size:14px; color:#0f172a;
        background:#f8fafc; transition:all 0.2s; outline:none; width:280px;
    }
    .search-input:focus { border-color:#e8392a; background:#fff; box-shadow:0 0 0 3px rgba(232,57,42,0.08); }
    .btn-search {
        background:#0f172a; color:#fff; border:none; border-radius:10px;
        padding:10px 18px; font-size:14px; font-weight:600; cursor:pointer;
        transition:all 0.2s; display:inline-flex; align-items:center; gap:6px;
    }
    .btn-search:hover { background:#1e293b; }
    .btn-add-new {
        background:linear-gradient(135deg,#e8392a,#ff6b5b);
        color:#fff; border:none; border-radius:10px;
        padding:10px 20px; font-size:14px; font-weight:600;
        text-decoration:none; display:inline-flex; align-items:center; gap:8px;
        transition:all 0.2s; box-shadow:0 4px 12px rgba(232,57,42,0.3); cursor:pointer;
    }
    .btn-add-new:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(232,57,42,0.4); color:#fff; text-decoration:none; }
    .section-card {
        background:#fff; border-radius:16px;
        border:1px solid #f1f5f9;
        box-shadow:0 2px 12px rgba(0,0,0,0.04); overflow:hidden;
    }
    .admin-table { width:100%; border-collapse:collapse; }
    .admin-table thead th {
        background:#f8fafc; font-size:11px; font-weight:700;
        text-transform:uppercase; letter-spacing:0.6px;
        color:#64748b; padding:12px 16px;
        border-bottom:1px solid #e2e8f0; text-align:left;
    }
    .admin-table tbody tr { border-bottom:1px solid #f1f5f9; transition:background 0.15s; }
    .admin-table tbody tr:hover { background:#f8fafc; }
    .admin-table tbody tr:last-child { border-bottom:none; }
    .admin-table tbody td { padding:12px 16px; font-size:13px; color:#334155; vertical-align:middle; }
    .product-thumb {
        width:56px; height:72px; object-fit:cover; border-radius:8px;
        box-shadow:0 2px 8px rgba(0,0,0,0.1);
    }
    .product-thumb-placeholder {
        width:56px; height:72px; background:#f1f5f9; border-radius:8px;
        display:flex; align-items:center; justify-content:center;
        color:#94a3b8; font-size:20px;
    }
    .product-name { font-weight:700; color:#0f172a; font-size:13px; }
    .price-badge {
        background:#fef0f0; color:#e8392a; font-weight:700;
        border-radius:6px; padding:3px 8px; font-size:12px;
    }
    .qty-badge {
        background:#f0fdf4; color:#15803d; font-weight:700;
        border-radius:6px; padding:3px 8px; font-size:12px;
    }
    .category-tag {
        background:#eff6ff; color:#1d4ed8; border-radius:6px;
        padding:3px 8px; font-size:11px; font-weight:600;
    }
    .action-group { display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
    .btn-edit {
        display:inline-flex; align-items:center; gap:4px;
        background:#fef3c7; color:#92400e; border:none; border-radius:7px;
        padding:5px 12px; font-size:11px; font-weight:700;
        text-decoration:none; transition:all 0.2s; cursor:pointer; white-space:nowrap;
    }
    .btn-edit:hover { background:#fde68a; color:#78350f; text-decoration:none; }
    .btn-del {
        display:inline-flex; align-items:center; gap:4px;
        background:#fee2e2; color:#991b1b; border:none; border-radius:7px;
        padding:5px 12px; font-size:11px; font-weight:700;
        text-decoration:none; transition:all 0.2s; cursor:pointer; white-space:nowrap;
    }
    .btn-del:hover { background:#fecaca; color:#7f1d1d; text-decoration:none; }
    .btn-clone {
        display:inline-flex; align-items:center; gap:4px;
        background:#f0f9ff; color:#0369a1; border:none; border-radius:7px;
        padding:5px 12px; font-size:11px; font-weight:700;
        text-decoration:none; transition:all 0.2s; cursor:pointer; white-space:nowrap;
    }
    .btn-clone:hover { background:#e0f2fe; color:#075985; text-decoration:none; }
    .empty-state { text-align:center; padding:48px 20px; color:#94a3b8; }
    .empty-state i { font-size:40px; margin-bottom:12px; display:block; }
</style>

<div class="page-header">
    <div class="page-title">Quản Lý <span>Sách</span></div>
    <div class="toolbar">
        @using (Html.BeginForm("Index", "Products", FormMethod.Get))
        {
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="searchString" class="search-input" value="@ViewBag.CurrentFilter" placeholder="Tìm kiếm sách..." />
            </div>
            <button type="submit" class="btn-search"><i class="bi bi-search"></i> Tìm</button>
        }
        <a class="btn-add-new" href="@Url.Action("Create", "Products")">
            <i class="bi bi-plus-lg"></i> Thêm Sách Mới
        </a>
    </div>
</div>

<div class="section-card">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th style="width:70px">Ảnh</th>
                    <th>Tên Sách</th>
                    <th>Tác Giả</th>
                    <th>Thể Loại</th>
                    <th>Giá</th>
                    <th style="width:80px">Số Lượng</th>
                    <th style="width:200px; text-align:center;">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Anh))
                                {
                                    string imgSrc = item.Anh.StartsWith("http") || item.Anh.StartsWith("/") ? item.Anh : "/Images/" + item.Anh;
                                    <img src="@imgSrc" alt="@item.TenSanPham" class="product-thumb" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                    <div class="product-thumb-placeholder" style="display:none"><i class="bi bi-image"></i></div>
                                }
                                else
                                {
                                    <div class="product-thumb-placeholder"><i class="bi bi-image"></i></div>
                                }
                            </td>
                            <td>
                                <div class="product-name">@Html.DisplayFor(modelItem => item.TenSanPham)</div>
                            </td>
                            <td>@Html.DisplayFor(modelItem => item.TacGia)</td>
                            <td><span class="category-tag">@Html.DisplayFor(modelItem => item.LOAI.Tenloai)</span></td>
                            <td><span class="price-badge">@String.Format("{0:N0}đ", item.Gia)</span></td>
                            <td><span class="qty-badge">@Html.DisplayFor(modelItem => item.SoLuong)</span></td>
                            <td>
                                <div class="action-group" style="justify-content:center;">
                                    <a href="@Url.Action("Edit", new { id = item.MaSanPham })" class="btn-edit">
                                        <i class="bi bi-pencil-fill"></i> Sửa
                                    </a>
                                    <a href="@Url.Action("Clone", new { id = item.MaSanPham })" class="btn-clone">
                                        <i class="bi bi-copy"></i> Nhân Bản
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.MaSanPham })" class="btn-del">
                                        <i class="bi bi-trash-fill"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">
                                <i class="bi bi-book"></i>
                                Không tìm thấy sách nào. Hãy thêm sách mới!
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>