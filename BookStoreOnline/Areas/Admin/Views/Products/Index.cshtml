@model IEnumerable<BookStoreOnline.Models.SANPHAM>

@{
    ViewBag.Title = "Danh Sách Sách";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    int currentPage = ViewBag.CurrentPage ?? 1;
}

<style>
    .page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 24px;
    }

    .page-title {
        font-size: 20px;
        font-weight: 800;
        color: #0f172a;
    }

        .page-title span {
            color: #e8392a;
        }

    .toolbar {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .search-wrap {
        position: relative;
    }

        .search-wrap i {
            position: absolute;
            left: 12px;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 14px;
        }

    .search-input {
        padding: 10px 14px 10px 36px;
        border: 1.5px solid #e2e8f0;
        border-radius: 10px;
        font-size: 14px;
        color: #0f172a;
        background: #f8fafc;
        transition: all 0.2s;
        outline: none;
        width: 280px;
    }

        .search-input:focus {
            border-color: #e8392a;
            background: #fff;
            box-shadow: 0 0 0 3px rgba(232,57,42,0.08);
        }

    .btn-search {
        background: #0f172a;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 18px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }

        .btn-search:hover {
            background: #1e293b;
        }

    .btn-add-new {
        background: linear-gradient(135deg,#e8392a,#ff6b5b);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 20px;
        font-size: 14px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
        box-shadow: 0 4px 12px rgba(232,57,42,0.3);
        cursor: pointer;
    }

        .btn-add-new:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 18px rgba(232,57,42,0.4);
            color: #fff;
            text-decoration: none;
        }

    .section-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        overflow: hidden;
    }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table thead th {
            background: #f8fafc;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #64748b;
            padding: 12px 16px;
            border-bottom: 1px solid #e2e8f0;
            text-align: left;
        }

        .admin-table tbody tr {
            border-bottom: 1px solid #f1f5f9;
            transition: background 0.15s;
        }

            .admin-table tbody tr:hover {
                background: #f8fafc;
            }

            .admin-table tbody tr:last-child {
                border-bottom: none;
            }

        .admin-table tbody td {
            padding: 12px 16px;
            font-size: 13px;
            color: #334155;
            vertical-align: middle;
        }

    .product-thumb {
        width: 56px;
        height: 72px;
        object-fit: cover;
        border-radius: 8px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .product-thumb-placeholder {
        width: 56px;
        height: 72px;
        background: #f1f5f9;
        border-radius: 8px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 20px;
    }

    .product-name {
        font-weight: 700;
        color: #0f172a;
        font-size: 13px;
    }

    .price-badge {
        background: #fef0f0;
        color: #e8392a;
        font-weight: 700;
        border-radius: 6px;
        padding: 3px 8px;
        font-size: 12px;
    }

    .qty-badge {
        background: #f0fdf4;
        color: #15803d;
        font-weight: 700;
        border-radius: 6px;
        padding: 3px 8px;
        font-size: 12px;
    }

    .category-tag {
        background: #eff6ff;
        color: #1d4ed8;
        border-radius: 6px;
        padding: 3px 8px;
        font-size: 11px;
        font-weight: 600;
    }

    .action-group {
        display: flex;
        gap: 6px;
        align-items: center;
        flex-wrap: wrap;
    }

    .btn-edit {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #fef3c7;
        color: #92400e;
        border: none;
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-edit:hover {
            background: #fde68a;
            color: #78350f;
            text-decoration: none;
        }

    .btn-discount {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #ffedd5;
        color: #c2410c;
        border: none;
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-discount:hover {
            background: #fed7aa;
            color: #9a3412;
            text-decoration: none;
        }

    .btn-del {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #fee2e2;
        color: #991b1b;
        border: none;
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-del:hover {
            background: #fecaca;
            color: #7f1d1d;
            text-decoration: none;
        }

    .btn-details {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        background: #f0f9ff;
        color: #0369a1;
        border: none;
        border-radius: 7px;
        padding: 5px 12px;
        font-size: 11px;
        font-weight: 700;
        text-decoration: none;
        transition: all 0.2s;
        cursor: pointer;
        white-space: nowrap;
    }

        .btn-details:hover {
            background: #e0f2fe;
            color: #075985;
            text-decoration: none;
        }

    .empty-state {
        text-align: center;
        padding: 48px 20px;
        color: #94a3b8;
    }

        .empty-state i {
            font-size: 40px;
            margin-bottom: 12px;
            display: block;
        }

    .page-link-custom {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 32px;
        height: 32px;
        padding: 0 10px;
        font-size: 13px;
        font-weight: 600;
        color: #475569;
        background: #f1f5f9;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s;
    }

        .page-link-custom:hover {
            background: #e2e8f0;
            color: #0f172a;
            text-decoration: none;
        }

        .page-link-custom.active {
            background: linear-gradient(135deg, #e8392a, #ff6b5b);
            color: #fff;
            box-shadow: 0 4px 10px rgba(232,57,42,0.25);
        }

        .page-link-custom.disabled {
            opacity: 0.5;
            pointer-events: none;
        }
</style>

@* Khối hiển thị thông báo trạng thái cập nhật *@
@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm my-2 text-success fw-bold" role="alert" style="border-radius: 8px; background-color: #f0fdf4; padding: 12px 20px;">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm my-2 text-danger fw-bold" role="alert" style="border-radius: 8px; background-color: #fef2f2; padding: 12px 20px;">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="page-header">
    <div class="page-title">Quản Lý <span>Sách</span></div>
    <div class="toolbar">
        @using (Html.BeginForm("Index", "Products", new { area = "Admin" }, FormMethod.Get))
        {
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="searchString" class="search-input" value="@ViewBag.CurrentFilter" placeholder="Tìm kiếm sách..." />
            </div>
            <button type="submit" class="btn-search"><i class="bi bi-search"></i> Tìm</button>
        }
        <a class="btn-add-new" href="@Url.Action("Create", "Products", new { area = "Admin" })">
            <i class="bi bi-plus-lg"></i> Thêm Sách Mới
        </a>
    </div>
</div>

<div class="section-card">
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th style="width:70px">Ảnh</th>
                    <th>Tên Sách</th>
                    <th>Giá</th>
                    <th style="width:80px">Số Lượng</th>
                    <th style="width:280px; text-align:center;">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.Anh))
                                {
                                    string imgSrc = item.Anh.StartsWith("http") || item.Anh.StartsWith("/") ? item.Anh : "/Images/" + item.Anh;
                                    <img src="@imgSrc" alt="@item.TenSanPham" class="product-thumb" onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';" />
                                    <div class="product-thumb-placeholder" style="display:none"><i class="bi bi-image"></i></div>
                                }
                                else
                                {
                                    <div class="product-thumb-placeholder"><i class="bi bi-image"></i></div>
                                }
                            </td>
                            <td>
                                <div class="product-name">@Html.DisplayFor(modelItem => item.TenSanPham)</div>
                            </td>
                            <td>
                                <span class="price-badge">@String.Format("{0:N0}đ", item.Gia)</span>
                                @if (item.GiamGia > 0)
                                {
                                    <span class="badge bg-danger ms-1" style="font-size: 10px;">-@item.GiamGia%</span>
                                }
                            </td>
                            <td>
                                <span class="qty-badge">@Html.DisplayFor(modelItem => item.SoLuong)</span>
                            </td>
                            <td>
                                <div class="action-group" style="justify-content:center;">
                                    <button type="button" class="btn-discount"
                                            data-bs-toggle="modal" data-bs-target="#discountModal"
                                            data-id="@item.MaSanPham" data-name="@item.TenSanPham" data-discount="@item.GiamGia">
                                        <i class="bi bi-ticket-perforated-fill"></i> Khuyến Mãi
                                    </button>

                                    <a href="@Url.Action("Edit", "Products", new { area = "Admin", id = item.MaSanPham })" class="btn-edit">
                                        <i class="bi bi-pencil-fill"></i> Sửa
                                    </a>
                                    <a href="@Url.Action("Details", "Products", new { area = "Admin", id = item.MaSanPham })" class="btn-details">
                                        <i class="bi bi-info-circle"></i> Chi Tiết
                                    </a>
                                    <a href="@Url.Action("Delete", "Products", new { area = "Admin", id = item.MaSanPham })" class="btn-del">
                                        <i class="bi bi-trash-fill"></i> Xóa
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5">
                            <div class="empty-state">
                                <i class="bi bi-book"></i>
                                Không tìm thấy sách nào. Hãy thêm sách mới!
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        string currentFilter = ViewBag.CurrentFilter ?? "";

        <div class="d-flex justify-content-between align-items-center p-3 border-top" style="background: #f8fafc;">
            <span style="font-size: 13px; color: #64748b;">
                Trang <strong>@currentPage</strong> / @ViewBag.TotalPages
            </span>
            <div class="pagination-container d-flex gap-1" style="padding: 0; border: none;">
                <a href="@Url.Action("Index", "Products", new { area = "Admin", searchString = currentFilter, page = currentPage - 1 })"
                   class="page-link-custom @(currentPage == 1 ? "disabled" : "")">
                    <i class="bi bi-chevron-left"></i> Trước
                </a>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="@Url.Action("Index", "Products", new { area = "Admin", searchString = currentFilter, page = i })"
                       class="page-link-custom @(currentPage == i ? "active" : "")">
                        @i
                    </a>
                }

                <a href="@Url.Action("Index", "Products", new { area = "Admin", searchString = currentFilter, page = currentPage + 1 })"
                   class="page-link-custom @(currentPage == ViewBag.TotalPages ? "disabled" : "")">
                    Sau <i class="bi bi-chevron-right"></i>
                </a>
            </div>
        </div>
    }
</div>

<div class="modal fade" id="discountModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 12px;">
            @using (Html.BeginForm("UpdateDiscount", "Products", new { area = "Admin" }, FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                <input type="hidden" name="maSanPham" id="discountBookId" />

                <div class="modal-header border-bottom-0 pt-4 px-4">
                    <h5 class="modal-title fw-bold text-dark">
                        <i class="bi bi-ticket-perforated text-warning me-2"></i>Cấu Hình Khuyến Mãi Sách
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body px-4">
                    <p class="text-secondary mb-3">Sách áp dụng: <strong class="text-dark" id="discountBookName"></strong></p>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-secondary" style="font-size:13px;">PHẦN TRĂM GIẢM GIÁ (%)</label>
                        <div class="input-group">
                            <input type="number" name="phanTramGiam" id="discountValue" class="form-control" min="0" max="100" required style="border-radius: 8px 0 0 8px; padding: 10px 14px;">
                            <span class="input-group-text bg-light text-secondary fw-bold" style="border-radius: 0 8px 8px 0;">%</span>
                        </div>
                        <small class="text-muted mt-2 d-block">Nhập số nguyên từ 0 đến 100. Đặt về <strong class="text-danger">0</strong> để hủy áp dụng giảm giá.</small>
                    </div>
                </div>

                <div class="modal-footer border-top-0 pb-4 px-4">
                    <button type="button" class="btn btn-light fw-bold" data-bs-dismiss="modal" style="border-radius: 8px; padding: 8px 16px;">Hủy</button>
                    <button type="submit" class="btn btn-warning text-white fw-bold px-4" style="border-radius: 8px; padding: 8px 24px;">Áp dụng</button>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    $(document).ready(function () {
        $('#discountModal').on('show.bs.modal', function (event) {
            var button = $(event.relatedTarget);
            var id = button.data('id');
            var name = button.data('name');
            var discount = button.data('discount');

            $('#discountBookId').val(id);
            $('#discountBookName').text(name);
            $('#discountValue').val(discount ? discount : 0);
        });
    });
</script>