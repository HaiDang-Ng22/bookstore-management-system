@model IEnumerable<BookStoreOnline.Models.NHANVIEN>
@using BookStoreOnline.Areas.Admin.Constants;

@{
    ViewBag.Title = "Tài Khoản Quản Trị";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .page-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:24px; }
    .page-title { font-size:20px; font-weight:800; color:#0f172a; }
    .page-title span { color:#e8392a; }
    .btn-add-new {
        background:linear-gradient(135deg,#e8392a,#ff6b5b);
        color:#fff; border:none; border-radius:10px;
        padding:10px 20px; font-size:14px; font-weight:600;
        text-decoration:none; display:inline-flex; align-items:center; gap:8px;
        transition:all 0.2s; box-shadow:0 4px 12px rgba(232,57,42,0.3); cursor:pointer;
    }
    .btn-add-new:hover { transform:translateY(-2px); box-shadow:0 6px 18px rgba(232,57,42,0.4); color:#fff; text-decoration:none; }
    .section-card {
        background:#fff; border-radius:16px;
        border:1px solid #f1f5f9;
        box-shadow:0 2px 12px rgba(0,0,0,0.04); overflow:hidden;
    }
    .section-card-header { padding:18px 24px; border-bottom:1px solid #f1f5f9; display:flex; align-items:center; justify-content:space-between; }
    .section-card-title { font-size:15px; font-weight:700; color:#0f172a; }
    .count-badge { background:#f1f5f9; color:#475569; border-radius:6px; font-size:12px; font-weight:700; padding:3px 10px; }
    .admin-table { width:100%; border-collapse:collapse; }
    .admin-table thead th {
        background:#f8fafc; font-size:11px; font-weight:700;
        text-transform:uppercase; letter-spacing:0.6px;
        color:#64748b; padding:12px 16px;
        border-bottom:1px solid #e2e8f0; text-align:left;
    }
    .admin-table tbody tr { border-bottom:1px solid #f1f5f9; transition:background 0.15s; }
    .admin-table tbody tr:hover { background:#f8fafc; }
    .admin-table tbody tr:last-child { border-bottom:none; }
    .admin-table tbody td { padding:13px 16px; font-size:13px; color:#334155; vertical-align:middle; }
    .stt-badge { background:#f1f5f9; color:#475569; border-radius:6px; font-size:12px; font-weight:700; padding:3px 10px; }
    .role-badge {
        display:inline-block; padding:3px 10px; border-radius:20px;
        font-size:11px; font-weight:700;
    }
    .role-1 { background:#fef9c3; color:#854d0e; }
    .role-2 { background:#dbeafe; color:#1e40af; }
    .role-3 { background:#f0fdf4; color:#166534; }
    .status-active { background:#dcfce7; color:#166534; border-radius:20px; padding:3px 10px; font-size:11px; font-weight:700; display:inline-block; }
    .status-disabled { background:#fee2e2; color:#991b1b; border-radius:20px; padding:3px 10px; font-size:11px; font-weight:700; display:inline-block; }
    .action-group { display:flex; gap:6px; align-items:center; flex-wrap:wrap; }
    .btn-edit {
        display:inline-flex; align-items:center; gap:4px;
        background:#fef3c7; color:#92400e; border:none; border-radius:7px;
        padding:5px 12px; font-size:11px; font-weight:700;
        text-decoration:none; transition:all 0.2s; white-space:nowrap;
    }
    .btn-edit:hover { background:#fde68a; color:#78350f; text-decoration:none; }
    .btn-disable {
        display:inline-flex; align-items:center; gap:4px;
        background:#f0f9ff; color:#0369a1; border:none; border-radius:7px;
        padding:5px 12px; font-size:11px; font-weight:700;
        text-decoration:none; transition:all 0.2s; white-space:nowrap;
    }
    .btn-disable:hover { background:#e0f2fe; color:#075985; text-decoration:none; }
    .btn-del {
        display:inline-flex; align-items:center; gap:4px;
        background:#fee2e2; color:#991b1b; border:none; border-radius:7px;
        padding:5px 12px; font-size:11px; font-weight:700;
        text-decoration:none; transition:all 0.2s; white-space:nowrap;
    }
    .btn-del:hover { background:#fecaca; color:#7f1d1d; text-decoration:none; }
    .user-info { display:flex; align-items:center; gap:10px; }
    .user-avatar {
        width:36px; height:36px; border-radius:50%; background:linear-gradient(135deg,#e8392a,#ff6b5b);
        display:flex; align-items:center; justify-content:center; color:#fff; font-weight:800; font-size:14px; flex-shrink:0;
    }
    .user-name { font-weight:700; color:#0f172a; font-size:13px; }
    .user-email { font-size:11px; color:#64748b; }
</style>

<div class="page-header">
    <div class="page-title">Tài Khoản <span>Quản Trị</span></div>
    <a class="btn-add-new" href="/Admin/AdminAccounts/Create">
        <i class="bi bi-plus-lg"></i> Thêm Người Quản Trị
    </a>
</div>

<div class="section-card">
    <div class="section-card-header">
        <span class="section-card-title"><i class="bi bi-person-badge-fill me-2" style="color:#e8392a"></i>Danh Sách Quản Trị Viên</span>
        <span class="count-badge">@Model.Count() tài khoản</span>
    </div>
    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th style="width:60px">STT</th>
                    <th>Tên Quản Trị Viên</th>
                    <th>Quyền Hạn</th>
                    <th>Trạng Thái</th>
                    <th>Ngày Tạo</th>
                    <th style="width:220px; text-align:center;">Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @{ int stt = 1; }
                @foreach (var item in Model)
                {
                    <tr>
                        <td><span class="stt-badge">@stt</span></td>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar">@(item.Ten != null && item.Ten.Length > 0 ? item.Ten[0].ToString().ToUpper() : "A")</div>
                                <div>
                                    <div class="user-name">@Html.DisplayFor(modelItem => item.Ten)</div>
                                    <div class="user-email">@Html.DisplayFor(modelItem => item.Email)</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            @{
                                string roleClass = item.Quyen == 1 ? "role-1" : (item.Quyen == 2 ? "role-2" : "role-3");
                            }
                            <span class="role-badge @roleClass">
                                @EHelper.GetEnumDescription((Constants.AdminRole)item.Quyen)
                            </span>
                        </td>
                        <td>
                            @if (item.TrangThai)
                            {
                                <span class="status-active"><i class="bi bi-check-circle-fill me-1"></i>Kích Hoạt</span>
                            }
                            else
                            {
                                <span class="status-disabled"><i class="bi bi-x-circle-fill me-1"></i>Vô Hiệu Hóa</span>
                            }
                        </td>
                        <td>@Html.DisplayFor(modelItem => item.NgayTao)</td>
                        <td>
                            <div class="action-group" style="justify-content:center;">
                                <a href="@Url.Action("Edit", new { id = item.MaNV })" class="btn-edit">
                                    <i class="bi bi-pencil-fill"></i> Sửa
                                </a>
                                <a href="@Url.Action("DisableAccount", new { id = item.MaNV })" class="btn-disable">
                                    <i class="bi bi-slash-circle-fill"></i> Vô Hiệu
                                </a>
                                <a href="@Url.Action("Delete", new { id = item.MaNV })" class="btn-del">
                                    <i class="bi bi-trash-fill"></i> Xóa
                                </a>
                            </div>
                        </td>
                    </tr>
                    stt++;
                }
            </tbody>
        </table>
    </div>
</div>
