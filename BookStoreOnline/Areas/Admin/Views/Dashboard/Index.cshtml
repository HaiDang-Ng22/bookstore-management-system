@{
    ViewBag.Title = "Bảng Điều Khiển";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
}

<style>
    .dash-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
    .dash-title { font-size: 22px; font-weight: 800; color: #0f172a; }
    .dash-title span { color: #e8392a; }
    
    .welcome-card {
        background: linear-gradient(135deg, #0f172a, #1e293b);
        color: #fff; border-radius: 16px; padding: 32px;
        box-shadow: 0 4px 20px rgba(15, 23, 42, 0.1);
        margin-bottom: 28px; display: flex; align-items: center; justify-content: space-between;
    }
    .welcome-text h2 { font-size: 24px; font-weight: 800; margin: 0 0 8px 0; }
    .welcome-text p { font-size: 14px; color: #cbd5e1; margin: 0; }
    .welcome-btn {
        background: #fff; color: #0f172a; border: none; border-radius: 10px;
        padding: 10px 20px; font-size: 14px; font-weight: 700;
        text-decoration: none; display: inline-flex; align-items: center; gap: 8px;
        transition: all 0.2s;
    }
    .welcome-btn:hover { background: #f1f5f9; transform: translateY(-1px); }

    .grid-layout { display: grid; grid-template-columns: 2fr 1fr; gap: 24px; }
    
    .card-panel {
        background: #fff; border-radius: 16px;
        border: 1px solid #f1f5f9; padding: 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    }
    .card-panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .card-panel-title { font-size: 15px; font-weight: 700; color: #0f172a; }
    
    .empty-chart-state {
        height: 250px; display: flex; flex-direction: column;
        align-items: center; justify-content: center;
        color: #94a3b8; gap: 12px;
    }
    .empty-chart-state i { font-size: 48px; color: #cbd5e1; }
    
    .activity-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 16px; }
    .activity-item { display: flex; align-items: center; gap: 12px; }
    .activity-dot { width: 8px; height: 8px; border-radius: 50%; background: #3b82f6; flex-shrink: 0; }
    .activity-info { font-size: 13px; color: #475569; }
    .activity-time { font-size: 11px; color: #94a3b8; margin-left: auto; }
</style>

<div class="dash-header">
    <div class="dash-title">Bảng <span>Điều Khiển</span></div>
</div>

<div class="welcome-card">
    <div class="welcome-text">
        <h2>Xin chào, Quản trị viên!</h2>
        <p>Chào mừng bạn trở lại hệ thống quản lý nhà sách. Dưới đây là hoạt động và các cập nhật mới nhất.</p>
    </div>
    <a href="/Admin/Home_Page" class="welcome-btn">
        <i class="bi bi-speedometer2"></i> Xem Tổng Quan
    </a>
</div>

<div class="grid-layout">
    <div class="card-panel">
        <div class="card-panel-header">
            <span class="card-panel-title"><i class="bi bi-bar-chart-line-fill me-2" style="color:#e8392a;"></i>Biểu đồ lượt xem sách</span>
        </div>
        <div class="empty-chart-state">
            <i class="bi bi-graph-up"></i>
            <span>Không có dữ liệu thống kê hoạt động lượt xem hiện tại.</span>
        </div>
    </div>
    
    <div class="card-panel">
        <div class="card-panel-header">
            <span class="card-panel-title"><i class="bi bi-bell-fill me-2" style="color:#3b82f6;"></i>Hoạt động gần đây</span>
        </div>
        <ul class="activity-list">
            <li class="activity-item">
                <span class="activity-dot" style="background:#3b82f6;"></span>
                <span class="activity-info">Đã xác nhận đơn hàng mới</span>
                <span class="activity-time">Vừa xong</span>
            </li>
            <li class="activity-item">
                <span class="activity-dot" style="background:#10b981;"></span>
                <span class="activity-info">Cập nhật thông tin sách thành công</span>
                <span class="activity-time">5 phút trước</span>
            </li>
            <li class="activity-item">
                <span class="activity-dot" style="background:#f59e0b;"></span>
                <span class="activity-info">Đã kích hoạt chương trình khuyến mãi mới</span>
                <span class="activity-time">1 giờ trước</span>
            </li>
        </ul>
    </div>
</div>
