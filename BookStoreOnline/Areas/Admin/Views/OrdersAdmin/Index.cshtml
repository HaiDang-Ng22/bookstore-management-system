@model IEnumerable<BookStoreOnline.Models.DONHANG>
@using BookStoreOnline.Areas.Admin.Constants;
@{
    ViewBag.Title = "Quản Lý Đơn Hàng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
    string currentStatus = Request.QueryString["status"] ?? "";
}

<style>
    .form-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .form-page-title {
        font-size: 20px;
        font-weight: 800;
        color: #0f172a;
    }

        .form-page-title span {
            color: #e8392a;
        }

    .section-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        overflow: hidden;
        margin-bottom: 24px;
    }

    .section-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
    }

    .section-card-title {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .status-filter-container {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 16px 24px;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
    }

    .btn-filter {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        color: #475569;
        background: #fff;
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
    }

        .btn-filter:hover {
            background: #f1f5f9;
            color: #0f172a;
            text-decoration: none;
        }

        .btn-filter.active-all {
            background: #475569;
            color: #fff;
            border-color: #475569;
        }

        .btn-filter.active-noinform {
            background: #f59e0b;
            color: #fff;
            border-color: #f59e0b;
        }

        .btn-filter.active-informed {
            background: #10b981;
            color: #fff;
            border-color: #10b981;
        }

        .btn-filter.active-shipping {
            background: #3b82f6;
            color: #fff;
            border-color: #3b82f6;
        }

        .btn-filter.active-received {
            background: #8b5cf6;
            color: #fff;
            border-color: #8b5cf6;
        }

        .btn-filter.active-canceled {
            background: #ef4444;
            color: #fff;
            border-color: #ef4444;
        }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table thead th {
            background: #f8fafc;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            color: #64748b;
            padding: 12px 16px;
            border-bottom: 1px solid #e2e8f0;
            text-align: left;
        }

        .admin-table tbody tr {
            border-bottom: 1px solid #f1f5f9;
        }

            .admin-table tbody tr:hover {
                background: #f8fafc;
            }

        .admin-table tbody td {
            padding: 14px 16px;
            font-size: 13px;
            color: #334155;
            vertical-align: middle;
        }

    .status-badge {
        display: inline-flex;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 700;
    }

    .badge-noinform {
        background: #fef3c7;
        color: #d97706;
    }

    .badge-informed {
        background: #d1fae5;
        color: #059669;
    }

    .badge-shipping {
        background: #dbeafe;
        color: #2563eb;
    }

    .badge-received {
        background: #ede9fe;
        color: #7c3aed;
    }

    .badge-canceled {
        background: #fee2e2;
        color: #dc2626;
    }

    .table-actions {
        display: flex;
        gap: 8px;
    }

    .btn-table-action {
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: none;
        cursor: pointer;
    }

    .btn-table-detail {
        background: #f1f5f9;
        color: #334155;
    }

        .btn-table-detail:hover {
            background: #e2e8f0;
            text-decoration: none;
        }

    .btn-table-delete {
        background: #fee2e2;
        color: #dc2626;
    }

        .btn-table-delete:hover {
            background: #fca5a5;
            text-decoration: none;
        }

    .pagination-container {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .page-link-custom {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 32px;
        height: 32px;
        padding: 0 10px;
        font-size: 13px;
        font-weight: 600;
        color: #475569;
        background: #f1f5f9;
        border-radius: 8px;
        text-decoration: none;
    }

        .page-link-custom.active {
            background: #e8392a;
            color: #fff;
        }
</style>

<div class="form-page-header"><div class="form-page-title">Quản Lý <span>Đơn Hàng</span></div></div>

@if (TempData["Message"] != null)
{<div class="alert alert-success">@TempData["Message"]</div>}

<div class="section-card">
    <div class="status-filter-container">
        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "", area = "Admin" })" class="btn-filter @(string.IsNullOrEmpty(currentStatus) ? "active-all" : "")">Tất Cả</a>
        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "NoInform", area = "Admin" })" class="btn-filter @(currentStatus == "NoInform" ? "active-noinform" : "")">Chờ Xác Nhận</a>
        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "Informed", area = "Admin" })" class="btn-filter @(currentStatus == "Informed" ? "active-informed" : "")">Đã Xác Nhận</a>
        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "Shipping", area = "Admin" })" class="btn-filter @(currentStatus == "Shipping" ? "active-shipping" : "")">Đang Giao</a>
        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "Received", area = "Admin" })" class="btn-filter @(currentStatus == "Received" ? "active-received" : "")">Đã Nhận</a>
        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "Canceled", area = "Admin" })" class="btn-filter @(currentStatus == "Canceled" ? "active-canceled" : "")">Đã Hủy</a>
    </div>

    <table class="admin-table">
        <thead>
            <tr><th>Mã ĐH</th><th>Khách Hàng</th><th>Địa Chỉ</th><th>Ngày Đặt</th><th>Tổng Tiền</th><th>Trạng Thái</th><th>Hành Động</th></tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>#@item.MaDonHang</strong></td>
                    <td>@item.KHACHHANG.Ten</td>
                    <td>@item.DiaChi</td>
                    <td>@(item.NgayDat?.ToString("dd/MM/yyyy"))</td>
                    <td style="color:#e8392a; font-weight:700;">@String.Format(price, "{0:c0}", item.TongTien)</td>
                    <td>
                        @if (item.TrangThai == (int)Constants.StatusOrder.NoInform)
                        {<span class="status-badge badge-noinform">Chờ Xác Nhận</span> }
                        else if (item.TrangThai == (int)Constants.StatusOrder.Informed)
                        { <span class="status-badge badge-informed">Đã Xác Nhận</span> }
                        else if (item.TrangThai == (int)Constants.StatusOrder.Shipping)
                        { <span class="status-badge badge-shipping">Đang Giao</span> }
                        else if (item.TrangThai == (int)Constants.StatusOrder.Received)
                        { <span class="status-badge badge-received">Đã Nhận</span> }
                        else
                        { <span class="status-badge badge-canceled">Đã Hủy</span>}
                    </td>
                    <td>
                        <div class="table-actions">
                            <a href="@Url.Action("Details", "OrdersAdmin", new { id = item.MaDonHang, area = "Admin" })" class="btn-table-action btn-table-detail">Xem</a>
                            @if (item.TrangThai != (int)Constants.StatusOrder.Canceled && item.TrangThai != (int)Constants.StatusOrder.Received && item.TrangThai != (int)Constants.StatusOrder.Shipping)
                            {
                                <button type="button" class="btn-table-action btn-table-delete" style="background:#fff3cd; color:#d97706;" onclick="HuyDonHangNhanh(@item.MaDonHang)">Hủy</button>
                            }
                            <form action="@Url.Action("Delete", "OrdersAdmin", new { id = item.MaDonHang, area = "Admin", status = currentStatus })" method="post" style="display:inline;" onsubmit="return confirm('Xóa đơn hàng?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-table-action btn-table-delete">Xóa</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@using (Html.BeginForm("CancelOrder", "OrdersAdmin", new { area = "Admin" }, FormMethod.Post, new { id = "formHuyDonNhanh" }))
{
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="idDonHangHuyNhanh" />
    <input type="hidden" name="lyDoHuy" id="noiDungLyDoNhanh" />
}

<script>
    function HuyDonHangNhanh(id) {
        var lyDo = prompt("Nhập lý do hủy:");
        if (lyDo !== null && lyDo.trim() !== "") {
            document.getElementById("idDonHangHuyNhanh").value = id;
            document.getElementById("noiDungLyDoNhanh").value = lyDo;
            document.getElementById("formHuyDonNhanh").submit();
        }
    }
</script>