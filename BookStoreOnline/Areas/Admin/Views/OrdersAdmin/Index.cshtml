@model IEnumerable<BookStoreOnline.Models.DONHANG>
@using BookStoreOnline.Areas.Admin.Constants;
@{
    ViewBag.Title = "Quản Lý Đơn Hàng";
    Layout = "~/Areas/Admin/Views/Shared/_LayoutAdmin.cshtml";
    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");

    // Lấy trạng thái bộ lọc hiện tại từ URL query string
    string currentStatus = Request.QueryString["status"] ?? "";
}

<style>
    .form-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 28px;
    }

    .form-page-title {
        font-size: 20px;
        font-weight: 800;
        color: #0f172a;
    }

        .form-page-title span {
            color: #e8392a;
        }

    .section-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f1f5f9;
        box-shadow: 0 2px 12px rgba(0,0,0,0.04);
        overflow: hidden;
        margin-bottom: 24px;
    }

    .section-card-header {
        padding: 18px 24px;
        border-bottom: 1px solid #f1f5f9;
    }

    .section-card-title {
        font-size: 15px;
        font-weight: 700;
        color: #0f172a;
    }

    .status-filter-container {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        padding: 16px 24px;
        background: #f8fafc;
        border-bottom: 1px solid #f1f5f9;
    }

    .btn-filter {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 8px 16px;
        border-radius: 8px;
        font-size: 13px;
        font-weight: 600;
        text-decoration: none;
        color: #475569;
        background: #fff;
        border: 1px solid #e2e8f0;
        transition: all 0.2s;
    }

        .btn-filter:hover {
            background: #f1f5f9;
            color: #0f172a;
            text-decoration: none;
        }

        .btn-filter.active-all {
            background: #475569;
            color: #fff;
            border-color: #475569;
        }

        .btn-filter.active-noinform {
            background: #f59e0b;
            color: #fff;
            border-color: #f59e0b;
        }

        .btn-filter.active-informed {
            background: #10b981;
            color: #fff;
            border-color: #10b981;
        }

        .btn-filter.active-shipping {
            background: #3b82f6;
            color: #fff;
            border-color: #3b82f6;
        }

        .btn-filter.active-received {
            background: #8b5cf6;
            color: #fff;
            border-color: #8b5cf6;
        }

        .btn-filter.active-canceled {
            background: #ef4444;
            color: #fff;
            border-color: #ef4444;
        }

    .admin-table {
        width: 100%;
        border-collapse: collapse;
    }

        .admin-table thead th {
            background: #f8fafc;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.6px;
            color: #64748b;
            padding: 12px 16px;
            border-bottom: 1px solid #e2e8f0;
            text-align: left;
        }

        .admin-table tbody tr {
            border-bottom: 1px solid #f1f5f9;
        }

            .admin-table tbody tr:hover {
                background: #f8fafc;
            }

        .admin-table tbody td {
            padding: 14px 16px;
            font-size: 13px;
            color: #334155;
            vertical-align: middle;
        }

    .status-badge {
        display: inline-flex;
        padding: 4px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 700;
    }

    .badge-noinform {
        background: #fef3c7;
        color: #d97706;
    }

    .badge-informed {
        background: #d1fae5;
        color: #059669;
    }

    .badge-shipping {
        background: #dbeafe;
        color: #2563eb;
    }

    .badge-received {
        background: #ede9fe;
        color: #7c3aed;
    }

    .badge-canceled {
        background: #fee2e2;
        color: #dc2626;
    }

    .table-actions {
        display: flex;
        gap: 8px;
    }

    .btn-table-action {
        padding: 5px 10px;
        border-radius: 6px;
        font-size: 12px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        border: none;
        cursor: pointer;
    }

    .btn-table-detail {
        background: #f1f5f9;
        color: #334155;
    }

        .btn-table-detail:hover {
            background: #e2e8f0;
            text-decoration: none;
        }

    .btn-table-delete {
        background: #fee2e2;
        color: #dc2626;
    }

        .btn-table-delete:hover {
            background: #fca5a5;
            text-decoration: none;
        }

    /* CSS Thanh phân trang custom */
    .pagination-container {
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .page-link-custom {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 32px;
        height: 32px;
        padding: 0 10px;
        font-size: 13px;
        font-weight: 600;
        color: #475569;
        background: #f1f5f9;
        border-radius: 8px;
        text-decoration: none;
        transition: all 0.2s;
    }

        .page-link-custom:hover {
            background: #e2e8f0;
            color: #0f172a;
            text-decoration: none;
        }

        .page-link-custom.active {
            background: linear-gradient(135deg, #e8392a, #ff6b5b);
            color: #fff;
            box-shadow: 0 4px 10px rgba(232,57,42,0.25);
        }

        .page-link-custom.disabled {
            opacity: 0.5;
            pointer-events: none;
        }
</style>

<div class="form-page-header">
    <div class="form-page-title">Quản Lý <span>Đơn Hàng Tổng Hợp</span></div>
</div>

<div class="section-card">
    <div class="section-card-header">
        <span class="section-card-title"><i class="bi bi-funnel-fill me-2" style="color:#e8392a"></i>Bộ Lọc Trạng Thái</span>
    </div>

    <div class="status-filter-container">
        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "", area = "Admin" })"
           class="btn-filter @(string.IsNullOrEmpty(currentStatus) ? "active-all" : "")">
            <i class="bi bi-list-task"></i> Tất Cả Đơn Hàng
        </a>

        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "NoInform", area = "Admin" })"
           class="btn-filter @(currentStatus == "NoInform" ? "active-noinform" : "")">
            <i class="bi bi-clock-history"></i> Chờ Xác Nhận
        </a>

        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "Informed", area = "Admin" })"
           class="btn-filter @(currentStatus == "Informed" ? "active-informed" : "")">
            <i class="bi bi-check2-circle"></i> Đã Xác Nhận
        </a>

        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "Shipping", area = "Admin" })"
           class="btn-filter @(currentStatus == "Shipping" ? "active-shipping" : "")">
            <i class="bi bi-truck"></i> Đang Giao Hàng
        </a>

        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "Received", area = "Admin" })"
           class="btn-filter @(currentStatus == "Received" ? "active-received" : "")">
            <i class="bi bi-box-seam"></i> Đã Nhận Hàng
        </a>

        <a href="@Url.Action("Index", "OrdersAdmin", new { status = "Canceled", area = "Admin" })"
           class="btn-filter @(currentStatus == "Canceled" ? "active-canceled" : "")">
            <i class="bi bi-x-circle"></i> Đơn Hàng Đã Hủy
        </a>
    </div>

    <div class="table-responsive">
        <table class="admin-table">
            <thead>
                <tr>
                    <th style="width: 90px;">Mã ĐH</th>
                    <th>Khách Hàng</th>
                    <th>Địa Chỉ Nhận Hàng</th>
                    <th style="width: 130px;">Ngày Đặt</th>
                    <th style="width: 140px; text-align: right;">Tổng Tiền</th>
                    <th style="width: 150px; text-align: center;">Trạng Thái</th>
                    <th style="width: 140px; text-align: center;">Hành Động</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; color: #94a3b8; padding: 30px;">
                            <i class="bi bi-inbox fs-4 d-block mb-2"></i> Không có đơn hàng nào thuộc trạng thái này.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>#@item.MaDonHang</strong></td>
                            <td>@item.KHACHHANG.Ten</td>
                            <td>@item.DiaChi</td>
                            <td>@(item.NgayDat.HasValue ? item.NgayDat.Value.ToString("dd/MM/yyyy") : "N/A")</td>
                            <td style="text-align: right; font-weight: 700; color: #e8392a;">
                                @String.Format(price, "{0:c0}", item.TongTien)
                            </td>
                            <td style="text-align: center;">
                                @if (item.TrangThai == (int)Constants.StatusOrder.NoInform)
                                {
                                    <span class="status-badge badge-noinform">Chờ Xác Nhận</span>
                                }
                                else if (item.TrangThai == (int)Constants.StatusOrder.Informed)
                                {
                                    <span class="status-badge badge-informed">Đã Xác Nhận</span>
                                }
                                else if (item.TrangThai == (int)Constants.StatusOrder.Shipping)
                                {
                                    <span class="status-badge badge-shipping">Đang Giao</span>
                                }
                                else if (item.TrangThai == (int)Constants.StatusOrder.Received)
                                {
                                    <span class="status-badge badge-received">Đã Nhận</span>
                                }
                                else if (item.TrangThai == (int)Constants.StatusOrder.Canceled)
                                {
                                    <span class="status-badge badge-canceled">Đã Hủy</span>
                                }
                            </td>
                            <td style="text-align: center;">
                                <div class="table-actions justify-content-center">
                                    <a href="@Url.Action("Details", "OrdersAdmin", new { id = item.MaDonHang, area = "Admin" })" class="btn-table-action btn-table-detail">
                                        <i class="bi bi-eye-fill"></i> Xem
                                    </a>

                                    <form action="@Url.Action("Delete", "OrdersAdmin", new { id = item.MaDonHang, area = "Admin", status = currentStatus })" method="post" style="display:inline;" onsubmit="return confirmDelete(event, '#@item.MaDonHang')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn-table-action btn-table-delete">
                                            <i class="bi bi-trash-fill"></i> Xóa
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @* --- THANH PHÂN TRANG GIAO DIỆN SPACE-BETWEEN --- *@
    @if (ViewBag.TotalPages > 1)
    {
        int curPage = ViewBag.CurrentPage ?? 1;
        <div class="d-flex justify-content-between align-items-center p-3 border-top" style="background: #f8fafc;">
            <span style="font-size: 13px; color: #64748b;">
                Trang <strong>@curPage</strong> / @ViewBag.TotalPages (Tổng số: @ViewBag.TotalCount đơn hàng)
            </span>
            <div class="pagination-container d-flex gap-1" style="padding: 0; border: none;">

                <a href="@Url.Action("Index", "OrdersAdmin", new { area = "Admin", status = currentStatus, page = curPage - 1 })"
                   class="page-link-custom @(curPage == 1 ? "disabled" : "")">
                    <i class="bi bi-chevron-left"></i> Trước
                </a>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a href="@Url.Action("Index", "OrdersAdmin", new { area = "Admin", status = currentStatus, page = i })"
                       class="page-link-custom @(curPage == i ? "active" : "")">
                        @i
                    </a>
                }

                <a href="@Url.Action("Index", "OrdersAdmin", new { area = "Admin", status = currentStatus, page = curPage + 1 })"
                   class="page-link-custom @(curPage == ViewBag.TotalPages ? "disabled" : "")">
                    Sau <i class="bi bi-chevron-right"></i>
                </a>

            </div>
        </div>
    }
</div>

<script>
    function confirmDelete(event, orderId) {
        event.preventDefault();
        var result = confirm("Bạn có chắc chắn muốn xóa đơn hàng " + orderId + " không?\nHành động này sẽ xóa toàn bộ dữ liệu liên quan và không thể hoàn tác!");
        if (result) {
            event.target.submit();
        }
    }
</script>