@model IEnumerable<BookStoreOnline.Models.DONHANG>
@using BookStoreOnline.Areas.Admin.Constants
@{
    ViewBag.Title = "Quản lý giao hàng";
    Layout = "~/Areas/Shipper/Views/Shared/_LayoutShipper.cshtml";
    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
    string currentTab = ViewBag.CurrentTab ?? "delivering";
    int currentPage = ViewBag.CurrentPage ?? 1;
    int totalPages = ViewBag.TotalPages ?? 1;
}

<style>
    .page-title { font-size: 22px; font-weight: 800; color: #0f172a; margin-bottom: 20px; }
    .page-title span { color: #2563eb; }
    .card-table { background: #fff; border-radius: 16px; border: 1px solid #f1f5f9; overflow: hidden; box-shadow: 0 2px 12px rgba(0,0,0,0.04); }
    .admin-table { width: 100%; border-collapse: collapse; }
    .admin-table thead th { background: #f8fafc; font-size: 11px; font-weight: 700; text-transform: uppercase; color: #64748b; padding: 12px 16px; border-bottom: 1px solid #e2e8f0; }
    .admin-table tbody td { padding: 14px 16px; font-size: 13px; border-bottom: 1px solid #f1f5f9; vertical-align: middle; }
    .btn-sm-action { padding: 6px 14px; border-radius: 8px; font-size: 12px; font-weight: 700; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
    .btn-view { background: #eff6ff; color: #2563eb; }
    .btn-accept { background: #dcfce7; color: #16a34a; }
    .status-badge { padding: 4px 10px; border-radius: 6px; font-size: 11px; font-weight: 700; }
    .status-shipping { background: #dbeafe; color: #1d4ed8; }
    .status-informed { background: #fef3c7; color: #b45309; }
    .empty-state { text-align: center; padding: 60px 20px; color: #94a3b8; }
</style>

<div class="page-title">
    @if (currentTab == "available")
    {
        <span>Đơn hàng</span> //chờ nhận
    }
    else
    {
        <span>Đơn hàng</span> //đang giao
    }
    <small class="text-muted fs-6">(@ViewBag.TotalCount đơn)</small>
</div>

<div class="card-table">
    @if (Model != null && Model.Any())
    {
        <div class="table-responsive">
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Mã đơn</th>
                        <th>Khách hàng</th>
                        <th>Địa chỉ giao</th>
                        <th>Ngày đặt</th>
                        <th>Tổng tiền</th>
                        <th>Trạng thái</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td><strong>#@item.MaDonHang</strong></td>
                            <td>@(item.KHACHHANG?.Ten ?? "N/A")</td>
                            <td>@item.DiaChi</td>
                            <td>@(item.NgayDat?.ToString("dd/MM/yyyy HH:mm") ?? "N/A")</td>
                            <td style="font-weight:700; color:#2563eb;">@String.Format(price, "{0:c0}", item.TongTien)</td>
                            <td>
                                @if (item.TrangThai == (int)Constants.StatusOrder.Shipping)
                                {
                                    <span class="status-badge status-shipping">Đang giao</span>
                                }
                                else
                                {
                                    <span class="status-badge status-informed">Chờ nhận</span>
                                }
                            </td>
                            <td>
                                <a href="@Url.Action("Details", "OrdersShipper", new { area = "Shipper", id = item.MaDonHang })" class="btn-sm-action btn-view">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                                @if (currentTab == "available")
                                {
                                    <a href="@Url.Action("AcceptOrder", "OrdersShipper", new { area = "Shipper", id = item.MaDonHang })" class="btn-sm-action btn-accept ms-1"
                                       onclick="return confirm('Bạn có chắc muốn nhận đơn hàng này?');">
                                        <i class="bi bi-check-lg"></i> Nhận đơn
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-inbox" style="font-size:48px;"></i>
            <p class="mt-3 mb-0">Không có đơn hàng nào.</p>
        </div>
    }
</div>

@if (totalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= totalPages; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link" href="@Url.Action("Index", "OrdersShipper", new { area = "Shipper", tab = currentTab, page = i })">@i</a>
                </li>
            }
        </ul>
    </nav>
}
