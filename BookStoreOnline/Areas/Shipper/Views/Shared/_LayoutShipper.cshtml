@{
    var shipper = Session["TaiKhoan"] as BookStoreOnline.Models.NHANVIEN;
    var tenVaiTro = Session["TenVaiTro"] as string ?? "Shipper";
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>Shipper - Nhà Sách Online</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root { --brand: #2563eb; --brand-light: #eff6ff; --bg: #f8fafc; }
        body { font-family: 'Inter', sans-serif; background: var(--bg); }
        .sidebar { width: 250px; min-height: 100vh; background: #fff; border-right: 1px solid #e2e8f0; }
        .brand { padding: 20px; font-weight: 800; color: #0f172a; border-bottom: 1px solid #e2e8f0; display: flex; align-items: center; gap: 10px; }
        .brand i { color: var(--brand); font-size: 22px; }
        .menu a { display: flex; align-items: center; gap: 10px; padding: 12px 20px; color: #334155; font-weight: 700; text-decoration: none; border-left: 4px solid transparent; }
        .menu a:hover, .menu a.active { background: var(--brand-light); color: var(--brand); border-left-color: var(--brand); }
        .content { flex: 1; padding: 30px; }
        .topbar { background: #fff; border-bottom: 1px solid #e2e8f0; padding: 16px 30px; display: flex; justify-content: space-between; align-items: center; }
        .alert-custom { border-radius: 12px; border: none; font-weight: 600; }
    </style>
</head>
<body>
    <div class="d-flex">
        <div class="sidebar">
            <div class="brand"><i class="bi bi-truck"></i> SHIPPER</div>
            <div class="p-3 border-bottom">
                <div class="fw-bold">@(shipper?.Ten)</div>
                <small class="text-muted">@tenVaiTro</small>
            </div>
            <div class="menu py-2">
                <a href="@Url.Action("Index", "OrdersShipper", new { area = "Shipper", tab = "delivering" })"
                   class="@(Request.QueryString["tab"] != "available" ? "active" : "")">
                    <i class="bi bi-box-seam"></i> Đơn đang giao
                </a>
                <a href="@Url.Action("Index", "OrdersShipper", new { area = "Shipper", tab = "available" })"
                   class="@(Request.QueryString["tab"] == "available" ? "active" : "")">
                    <i class="bi bi-inbox"></i> Đơn chờ nhận
                </a>
                <a href="/User/LogOut" class="text-danger mt-3"><i class="bi bi-box-arrow-right"></i> Đăng xuất</a>
            </div>
        </div>
        <div class="flex-grow-1">
            <div class="topbar">
                <span class="fw-bold text-secondary">Hệ thống giao hàng</span>
                <span class="badge bg-primary">@shipper?.Email</span>
            </div>
            <div class="content">
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-custom">@TempData["SuccessMessage"]</div>
                }
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-custom">@TempData["ErrorMessage"]</div>
                }
                @RenderBody()
            </div>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
