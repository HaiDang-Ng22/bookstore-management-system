@{ var shipper=Session["TaiKhoan"] as BookStoreOnline.Models.NHANVIEN; var tab=Request.QueryString["tab"]??"delivering"; }
<!DOCTYPE html><html lang="vi"><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><title>@ViewBag.Title - Shipper</title><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css"><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"><style>body{font-family:Arial,sans-serif;background:#f8fafc}.sidebar{width:250px;min-height:100vh;background:#fff;border-right:1px solid #e2e8f0}.brand{padding:20px;font-weight:800;border-bottom:1px solid #e2e8f0}.menu a{display:flex;gap:10px;padding:12px 20px;color:#334155;font-weight:700;text-decoration:none;border-left:4px solid transparent}.menu a:hover,.menu a.active{background:#eff6ff;color:#2563eb;border-left-color:#2563eb}.content{padding:28px}.topbar{background:#fff;border-bottom:1px solid #e2e8f0;padding:15px 28px;display:flex;justify-content:space-between}.alert{border-radius:12px}@@media(max-width:800px){.sidebar{width:76px}.sidebar .label,.profile{display:none}.menu a{justify-content:center;padding:15px}.content{padding:15px}}</style></head><body><div class="d-flex"><aside class="sidebar"><div class="brand"><i class="bi bi-truck text-primary"></i> <span class="label">SHIPPER</span></div><div class="profile p-3 border-bottom"><strong>@shipper?.Ten</strong><br><small class="text-muted">Shipper</small></div><nav class="menu py-2"><a class="@(tab=="available"?"active":"")" href="@Url.Action("Index","OrdersShipper",new{area="Shipper",tab="available"})"><i class="bi bi-inbox"></i><span class="label">Đơn có thể nhận</span></a><a class="@(tab=="delivering"?"active":"")" href="@Url.Action("Index","OrdersShipper",new{area="Shipper",tab="delivering"})"><i class="bi bi-box-seam"></i><span class="label">Đang giao</span></a><a class="@(tab=="delivered"?"active":"")" href="@Url.Action("Index","OrdersShipper",new{area="Shipper",tab="delivered"})"><i class="bi bi-check-circle"></i><span class="label">Giao thành công</span></a><a class="@(tab=="failed"?"active":"")" href="@Url.Action("Index","OrdersShipper",new{area="Shipper",tab="failed"})"><i class="bi bi-exclamation-circle"></i><span class="label">Giao thất bại</span></a><a class="text-danger mt-3" href="@Url.Action("LogOut","User",new{area=""})"><i class="bi bi-box-arrow-right"></i><span class="label">Đăng xuất</span></a></nav></aside><main class="flex-grow-1"><div class="topbar"><strong>Hệ thống giao hàng</strong><span class="badge bg-primary">@shipper?.Email</span></div><div class="content">@if(TempData["SuccessMessage"]!=null){<div class="alert alert-success">@TempData["SuccessMessage"]</div>}@if(TempData["ErrorMessage"]!=null){<div class="alert alert-danger">@TempData["ErrorMessage"]</div>}@RenderBody()</div></main></div><script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/js/bootstrap.bundle.min.js"></script></body></html>
