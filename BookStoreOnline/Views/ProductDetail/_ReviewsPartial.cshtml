@model List<BookStoreOnline.Models.DANHGIA>

@if (Model != null && Model.Any())
{
    foreach (var review in Model)
    {
        <div class="review-item">
            <div class="review-header">
                <span class="review-user"><i class="bi bi-person-circle text-muted mr-1"></i> @review.KHACHHANG.Ten</span>
                <span class="review-date">@review.NgayTao.ToString("dd/MM/yyyy HH:mm")</span>
            </div>
            <div class="review-stars">
                @for (int i = 1; i <= 5; i++)
                {
                    <i class="bi @(i <= review.SoSao ? "bi-star-fill" : "bi-star")"></i>
                }
                <small class="text-muted ml-2">(@review.SoSao/5 sao)</small>
            </div>
            <div class="review-content">
                @review.NoiDung
            </div>
        </div>
    }
}
else
{
    <div class="text-center py-4 text-muted">
        <i class="bi bi-chat-square-dots" style="font-size: 32px; opacity: 0.5;"></i>
        <p class="mt-2 mb-0">Chưa có đánh giá nào cho sản phẩm này. Hãy là người đầu tiên chia sẻ cảm nhận!</p>
    </div>
}
