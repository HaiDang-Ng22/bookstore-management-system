@model BookStoreOnline.Models.SANPHAM

@{
    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
    var user = ViewBag.User as BookStoreOnline.Models.KHACHHANG;
}

<style>
    .detail-container {
        padding: 40px 15px;
    }
    .product-main-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        padding: 30px;
        margin-bottom: 40px;
    }
    .img-container {
        background: #f8fafc;
        border-radius: 16px;
        padding: 24px;
        text-align: center;
        border: 1px solid #f1f5f9;
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 450px;
    }
    .img-container img {
        max-height: 400px;
        object-fit: contain;
        border-radius: 8px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        transition: transform 0.3s ease;
    }
    .img-container img:hover {
        transform: scale(1.03);
    }
    .product-info-panel h1 {
        font-size: 28px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 16px;
        line-height: 1.3;
    }
    .meta-item {
        display: inline-flex;
        align-items: center;
        font-size: 14px;
        color: #6b7280;
        margin-right: 20px;
        margin-bottom: 12px;
    }
    .meta-item i {
        margin-right: 6px;
        color: #e8392a;
    }
    .product-price-box {
        background: #fdf2f2;
        border-radius: 14px;
        padding: 18px 24px;
        margin: 20px 0;
        border: 1.5px solid rgba(232,57,42,0.08);
    }
    .product-price {
        font-size: 32px;
        font-weight: 800;
        color: #e8392a;
        margin: 0;
    }
    .stock-badge {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        padding: 6px 14px;
        border-radius: 999px;
        font-size: 13px;
        font-weight: 700;
        margin-bottom: 20px;
    }
    .stock-in {
        background: #dcfce7;
        color: #166534;
    }
    .stock-out {
        background: #fee2e2;
        color: #991b1b;
    }
    .description-box {
        font-size: 15px;
        color: #4b5563;
        line-height: 1.7;
        border-top: 1px solid #f1f5f9;
        padding-top: 20px;
        margin-top: 20px;
    }
    .description-title {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 8px;
    }
    /* Add to cart styling */
    .cart-action-group {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 28px;
        flex-wrap: wrap;
    }
    .quantity-control {
        display: flex;
        align-items: center;
        border: 1.5px solid #d1d5db;
        border-radius: 12px;
        overflow: hidden;
        height: 50px;
        background: #fff;
    }
    .quantity-control button {
        background: none;
        border: none;
        width: 44px;
        height: 100%;
        color: #374151;
        font-weight: 600;
        transition: background 0.2s;
    }
    .quantity-control button:hover {
        background: #f1f5f9;
    }
    .quantity-control input {
        border: none;
        width: 50px;
        text-align: center;
        font-weight: 700;
        color: #111827;
        outline: none;
        font-size: 15px;
    }
    .btn-add-to-cart {
        height: 50px;
        border-radius: 12px;
        border: none;
        background: linear-gradient(135deg, #e8392a 0%, #ff6b5b 100%);
        color: #fff;
        padding: 0 32px;
        font-weight: 700;
        font-size: 15px;
        box-shadow: 0 4px 14px rgba(232,57,42,0.22);
        cursor: pointer;
        transition: all 0.25s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }
    .btn-add-to-cart:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(232,57,42,0.32);
    }
    .btn-add-to-cart:disabled {
        background: #9ca3af;
        box-shadow: none;
        cursor: not-allowed;
        opacity: 0.6;
    }
    /* Review Card and section */
    .reviews-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        padding: 30px;
        margin-bottom: 40px;
    }
    .reviews-title {
        font-size: 20px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 24px;
        border-bottom: 1.5px solid #f1f5f9;
        padding-bottom: 16px;
    }
    .review-item {
        border-bottom: 1px solid #f1f5f9;
        padding: 20px 0;
    }
    .review-item:last-child {
        border-bottom: none;
    }
    .review-header {
        display: flex;
        justify-content: space-between;
        margin-bottom: 8px;
    }
    .review-user {
        font-weight: 700;
        color: #111827;
        font-size: 15px;
    }
    .review-date {
        color: #9ca3af;
        font-size: 13px;
    }
    .review-stars {
        color: #fbbf24;
        margin-bottom: 8px;
    }
    .review-content {
        color: #4b5563;
        font-size: 14.5px;
        line-height: 1.6;
    }
    .form-review-box {
        background: #f8fafc;
        border-radius: 14px;
        padding: 24px;
        margin-top: 30px;
        border: 1px solid #e2e8f0;
    }
    .form-review-box h4 {
        font-size: 16px;
        font-weight: 700;
        color: #111827;
        margin-bottom: 18px;
    }
    .form-review-box textarea {
        width: 100%;
        border-radius: 10px;
        border: 1.5px solid #e2e8f0;
        padding: 12px 16px;
        font-family: inherit;
        font-size: 14px;
        outline: none;
        resize: vertical;
        transition: border-color 0.2s;
    }
    .form-review-box textarea:focus {
        border-color: #e8392a;
    }
    .star-select-label {
        font-size: 14px;
        font-weight: 600;
        color: #4b5563;
        margin-right: 12px;
    }
    .rating-stars-interactive {
        display: inline-flex;
        gap: 6px;
        font-size: 22px;
        cursor: pointer;
        color: #d1d5db;
        vertical-align: middle;
    }
    .rating-stars-interactive .star.active {
        color: #fbbf24;
    }
    .btn-submit-review {
        background: #1e293b;
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 10px 24px;
        font-weight: 700;
        font-size: 14px;
        transition: background 0.2s;
        cursor: pointer;
    }
    .btn-submit-review:hover {
        background: #0f172a;
    }
    /* Related books grid */
    .related-books-section {
        margin-top: 50px;
    }
    .section-title {
        font-size: 22px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .related-card {
        background: #fff;
        border-radius: 16px;
        border: 1px solid #e5e7eb;
        overflow: hidden;
        box-shadow: 0 4px 16px rgba(0,0,0,0.03);
        transition: transform 0.25s, box-shadow 0.25s;
        margin-bottom: 30px;
    }
    .related-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 32px rgba(0,0,0,0.08);
    }
    .related-img-box {
        background: #f8fafc;
        height: 250px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 16px;
    }
    .related-img-box img {
        max-height: 210px;
        object-fit: contain;
        box-shadow: 0 4px 10px rgba(0,0,0,0.06);
    }
    .related-body {
        padding: 20px;
    }
    .related-title {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
        line-height: 1.4;
        height: 42px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        margin-bottom: 8px;
    }
    .related-title a:hover {
        color: #e8392a;
    }
    .related-price {
        font-size: 16px;
        font-weight: 800;
        color: #e8392a;
        margin-bottom: 12px;
    }
    .btn-buy-now {
        display: block;
        width: 100%;
        text-align: center;
        background: #fff;
        border: 1.5px solid #e8392a;
        color: #e8392a;
        border-radius: 10px;
        padding: 8px 0;
        font-weight: 700;
        font-size: 13.5px;
        transition: all 0.2s;
    }
    .btn-buy-now:hover {
        background: #e8392a;
        color: #fff;
    }
    .btn-view-all {
        color: #e8392a;
        font-size: 14px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        gap: 6px;
    }
</style>

<div class="container detail-container">
    <!-- Main Info Block -->
    <div class="product-main-card">
        <div class="row">
            <!-- Product Image -->
            <div class="col-lg-5 col-md-6 mb-4 mb-md-0">
                <div class="img-container">
                    <img src="@Model.Anh" alt="@Model.TenSanPham">
                </div>
            </div>

            <!-- Product Details -->
            <div class="col-lg-7 col-md-6">
                <div class="product-info-panel">
                    @if (Model.SoLuong > 0)
                    {
                        <span class="stock-badge stock-in"><i class="bi bi-patch-check-fill"></i> Còn hàng (@Model.SoLuong sản phẩm)</span>
                    }
                    else
                    {
                        <span class="stock-badge stock-out"><i class="bi bi-x-circle-fill"></i> Tạm hết hàng</span>
                    }

                    <h1>@Model.TenSanPham</h1>

                    <div class="product-meta">
                        <span class="meta-item"><i class="bi bi-person-fill"></i> Tác giả: <strong>@Model.TacGia</strong></span>
                        <span class="meta-item"><i class="bi bi-tag-fill"></i> Thể loại: <strong>@Model.LOAI.Tenloai</strong></span>
                    </div>

                    <div class="product-price-box">
                        <p class="product-price">@String.Format(price, "{0:c0}", Model.Gia)</p>
                    </div>

                    <!-- Add to Cart Form -->
                    @if (user == null)
                    {
                        <div class="cart-action-group">
                            <div class="quantity-control">
                                <button type="button" disabled>-</button>
                                <input type="number" value="1" disabled>
                                <button type="button" disabled>+</button>
                            </div>
                            <button class="btn-add-to-cart" disabled>
                                <i class="bi bi-bag-plus-fill"></i> Đăng nhập để mua hàng
                            </button>
                        </div>
                    }
                    else
                    {
                        if (Model.SoLuong > 0)
                        {
                            using (Html.BeginForm("AddToCart", "Cart", FormMethod.Post, new { @class = "cart-action-group" }))
                            {
                                <div class="quantity-control">
                                    <button type="button" onclick="adjustQty(-1)">-</button>
                                    <input type="number" id="purchase-qty" name="Quantity" value="1" min="1" max="@Model.SoLuong">
                                    <button type="button" onclick="adjustQty(1)">+</button>
                                </div>
                                <input type="hidden" name="ProductID" value="@Model.MaSanPham" />
                                <button class="btn-add-to-cart" type="submit">
                                    <i class="bi bi-bag-plus-fill"></i> Thêm vào giỏ hàng
                                </button>
                            }
                        }
                        else
                        {
                            <div class="cart-action-group">
                                <div class="quantity-control">
                                    <button type="button" disabled>-</button>
                                    <input type="number" value="0" disabled>
                                    <button type="button" disabled>+</button>
                                </div>
                                <button class="btn-add-to-cart" disabled>
                                    <i class="bi bi-bag-x-fill"></i> Đã hết hàng
                                </button>
                            </div>
                        }
                    }

                    <div class="description-box">
                        <div class="description-title">Giới thiệu sản phẩm</div>
                        <p>@Model.MoTa</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Reviews Section -->
    <div class="reviews-card">
        <h3 class="reviews-title"><i class="bi bi-chat-left-heart"></i> Đánh giá từ khách hàng</h3>
        <div id="reviews-container">
            <!-- AJAX will load reviews here -->
            <div class="loading-spinner text-center py-4">
                <div class="spinner-border text-danger" role="status">
                    <span class="sr-only">Đang tải...</span>
                </div>
                <p class="mt-2 text-muted">Đang tải đánh giá...</p>
            </div>
        </div>

        @if (user != null)
        {
            using (Html.BeginForm("AddReview", "ProductDetail", FormMethod.Post, new { @id = "review-form", @class = "form-review-box" }))
            {
                <h4>Viết đánh giá của bạn</h4>
                <input type="hidden" name="ProductID" value="@Model.MaSanPham" />
                <div class="mb-3">
                    <textarea name="NoiDung" rows="3" placeholder="Chia sẻ suy nghĩ của bạn về cuốn sách này..." required></textarea>
                </div>
                <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                    <div>
                        <span class="star-select-label">Đánh giá của bạn:</span>
                        <div class="rating-stars-interactive">
                            <i class="bi bi-star-fill star active" data-value="1"></i>
                            <i class="bi bi-star-fill star" data-value="2"></i>
                            <i class="bi bi-star-fill star" data-value="3"></i>
                            <i class="bi bi-star-fill star" data-value="4"></i>
                            <i class="bi bi-star-fill star" data-value="5"></i>
                        </div>
                        <input type="hidden" id="rating" name="SoSao" value="1" />
                    </div>
                    <button class="btn-submit-review" type="submit">Gửi Đánh Giá</button>
                </div>
            }
        }
        else
        {
            <div class="alert alert-light border text-center py-3 mt-4" style="border-radius:12px;">
                <p class="m-0 text-muted">Vui lòng <a href="@Url.Action("Login", "User")" class="text-danger font-weight-bold">Đăng nhập</a> để gửi đánh giá của bạn về sản phẩm này.</p>
            </div>
        }
    </div>

    <!-- Related Products -->
    <div class="related-books-section">
        <div class="section-title">
            <span>Khám Phá Thêm</span>
            <a href="@Url.Action("GetAllBook", "Category")" class="btn-view-all">Xem tất cả <i class="bi bi-arrow-right"></i></a>
        </div>
        <div class="row">
            @foreach (var item in ViewBag.MoreBook)
            {
                <div class="col-lg-3 col-md-4 col-sm-6">
                    <div class="related-card">
                        <div class="related-img-box">
                            <a href="@Url.Action("Index", "ProductDetail", new { id = item.MaSanPham })">
                                <img src="@item.Anh" alt="@item.TenSanPham">
                            </a>
                .then(response => response.text())
                .then(data => {
                    document.getElementById('reviews-container').innerHTML = data;
                });
        }

        // Xử lý submit form đánh giá
        document.getElementById('review-form').addEventListener('submit', function(e) {
            e.preventDefault();

            const formData = new FormData(this);

            fetch(this.action, {
                method: 'POST',
                body: formData
            }).then(() => {
                loadReviews(); // Reload đánh giá sau khi submit
                this.reset(); // Reset form
                alert('Đánh giá đã được gửi!');
            });
        });

        // Xử lý rating sao
        function initStarRating() {
            const stars = document.querySelectorAll('.rating-stars .star');
            const ratingInput = document.getElementById('rating');

            stars.forEach(star => {
                star.addEventListener('click', function() {
                    const value = this.getAttribute('data-value');
                    ratingInput.value = value;
                    updateStars(value);
                });
            });

            function updateStars(value) {
                stars.forEach(star => {
                    const starValue = star.getAttribute('data-value');
                    star.classList.toggle('selected', starValue <= value);
                });
            }
        }
    </script>
</div>