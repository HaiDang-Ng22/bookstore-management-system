@{
    ViewBag.Title = "Trang Chủ";
}
@model IEnumerable<BookStoreOnline.Models.SANPHAM>

@{
    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
    var user = Session["TaiKhoan"] as BookStoreOnline.Models.KHACHHANG;
}

@section styles {
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<style>
    /* Hero Slideshow */
    .hero-section { padding: 24px 0 0; }
    .hero-slide-wrapper {
        border-radius: 18px;
        overflow: hidden;
        box-shadow: 0 12px 40px rgba(0,0,0,.1);
        position: relative;
        background: #f5f6fa;
        cursor: pointer;
    }
    .slide-track { display: flex; transition: transform .55s cubic-bezier(.4,0,.2,1); }
    .slide-track img { width: 100%; flex-shrink: 0; height: auto; display: block; object-fit: cover; }
    .slide-arrow {
        position: absolute; top: 50%; transform: translateY(-50%);
        width: 44px; height: 44px;
        border-radius: 50%;
        background: rgba(255,255,255,.92);
        border: none; cursor: pointer;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px; color: #1e293b;
        box-shadow: 0 4px 16px rgba(0,0,0,.12);
        transition: .25s; z-index: 10;
    }
    .slide-arrow:hover { background: #e8392a; color: #fff; }
    .slide-prev { left: 14px; }
    .slide-next { right: 14px; }
    .slide-dots {
        position: absolute; bottom: 14px; left: 50%; transform: translateX(-50%);
        display: flex; gap: 7px;
    }
    .slide-dot {
        width: 8px; height: 8px;
        border-radius: 50%;
        background: rgba(255,255,255,.55);
        border: none; cursor: pointer; transition: .25s;
    }
    .slide-dot.active { background: #fff; width: 24px; border-radius: 4px; }

    /* Feature badges */
    .features-bar {
        display: flex;
        gap: 16px;
        margin: 20px 0 32px;
        flex-wrap: wrap;
    }
    .feature-item {
        flex: 1; min-width: 160px;
        background: #fff;
        border-radius: 14px;
        padding: 16px 18px;
        display: flex;
        align-items: center;
        gap: 12px;
        box-shadow: 0 2px 12px rgba(0,0,0,.05);
        border: 1px solid #f1f5f9;
    }
    .feature-icon {
        width: 44px; height: 44px;
        border-radius: 12px;
        background: #fef2f2;
        display: flex; align-items: center; justify-content: center;
        font-size: 20px; color: #e8392a; flex-shrink: 0;
    }
    .feature-text strong { display: block; font-size: 13px; font-weight: 700; color: #111827; }
    .feature-text span { font-size: 12px; color: #9ca3af; }

    /* Section heading */
    .section-head {
        display: flex; align-items: center; justify-content: space-between;
        margin: 36px 0 20px;
    }
    .section-head h2 {
        font-size: 22px; font-weight: 800; color: #111827;
        position: relative; padding-bottom: 10px; margin: 0;
    }
    .section-head h2::after {
        content: ''; position: absolute; bottom: 0; left: 0;
        width: 44px; height: 3.5px;
        background: linear-gradient(135deg,#e8392a,#ff6b5b);
        border-radius: 2px;
    }
    .see-all-link {
        color: #e8392a; font-size: 13px; font-weight: 600;
        display: flex; align-items: center; gap: 5px;
        transition: .2s; text-decoration: none;
    }
    .see-all-link:hover { gap: 8px; color: #c0281c; text-decoration: none; }

    /* Product grid */
    .products-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
    @@media(max-width:991px) { .products-grid { grid-template-columns: repeat(3,1fr); } }
    @@media(max-width:767px) { .products-grid { grid-template-columns: repeat(2,1fr); } }
    @@media(max-width:480px) { .products-grid { grid-template-columns: 1fr; } }

    /* Product card */
    .product-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        box-shadow: 0 2px 14px rgba(0,0,0,.06);
        border: 1px solid #f1f5f9;
        transition: .3s;
        display: flex; flex-direction: column;
        position: relative;
    }
    .product-card:hover { transform: translateY(-6px); box-shadow: 0 12px 36px rgba(0,0,0,.12); }

    .product-img-wrap {
        background: #fafafa;
        display: flex; align-items: center; justify-content: center;
        height: 210px; overflow: hidden; padding: 12px;
    }
    .product-img-wrap img {
        max-height: 186px; width: auto; object-fit: contain;
        transition: transform .4s ease;
    }
    .product-card:hover .product-img-wrap img { transform: scale(1.06); }

    .product-badge {
        position: absolute; top: 12px; left: 12px;
        background: rgba(220,38,38,.88); color: #fff;
        font-size: 10px; font-weight: 700; padding: 3px 8px;
        border-radius: 5px; text-transform: uppercase; letter-spacing: .5px;
    }

    .product-body { padding: 14px 14px 16px; display: flex; flex-direction: column; flex: 1; }
    .product-title {
        font-size: 14px; font-weight: 600; color: #1e293b;
        line-height: 1.4; margin-bottom: 8px;
        display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
    }
    .product-title a { color: inherit; text-decoration: none; }
    .product-title a:hover { color: #e8392a; }

    .product-price { font-size: 17px; font-weight: 800; color: #e8392a; margin-bottom: 8px; }

    .stars-row { display: flex; align-items: center; gap: 4px; margin-bottom: 8px; }
    .star-icon { font-size: 11px; color: #e2e8f0; }
    .star-icon.on { color: #f59e0b; }
    .rating-count { font-size: 11px; color: #9ca3af; margin-left: 4px; }

    .sold-bar-wrap {
        width: 100%; height: 12px;
        background: #f1f5f9; border-radius: 999px;
        overflow: hidden; position: relative; margin: 6px 0 4px;
    }
    .sold-bar-fill { height: 100%; border-radius: 999px; position: absolute; left:0; top:0; }
    .sold-bar-text {
        position: absolute; width: 100%; text-align: center;
        font-size: 9px; font-weight: 700; color: #1e293b; line-height: 12px; z-index: 2;
    }

    .btn-buy-card {
        display: flex; align-items: center; justify-content: center;
        width: 100%; height: 38px; border-radius: 999px;
        background: linear-gradient(135deg,#e8392a,#ff6b5b);
        color: #fff; font-size: 13px; font-weight: 700;
        border: none; cursor: pointer; margin-top: auto;
        text-decoration: none; transition: .25s;
        box-shadow: 0 4px 12px rgba(232,57,42,.2);
    }
    .btn-buy-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(232,57,42,.3); color: #fff; text-decoration: none; }
    .btn-buy-card.disabled-btn { opacity: .45; pointer-events: none; background: #94a3b8; box-shadow: none; }

    /* More btn */
    .more-wrap { display: flex; justify-content: center; margin: 36px 0 56px; }
    .btn-see-more {
        display: flex; align-items: center; gap: 8px;
        padding: 0 32px; height: 46px; border-radius: 999px;
        border: 1.5px solid #e8392a; color: #e8392a;
        background: #fff; font-size: 14px; font-weight: 700;
        cursor: pointer; transition: .25s; text-decoration: none;
    }
    .btn-see-more:hover { background: linear-gradient(135deg,#e8392a,#ff6b5b); color: #fff !important; border-color: transparent; box-shadow: 0 6px 20px rgba(232,57,42,.25); transform: translateY(-2px); text-decoration: none; }
</style>
}

<div class="container hero-section">
    <!-- Slideshow -->
    <div class="hero-slide-wrapper" id="heroSlider">
        <div class="slide-track" id="slideTrack">
            <img src="~/Images/Cardgame_Slide_T6_840x320.jpg" alt="Slide 1">
            <img src="~/Images/MangaWeek_T524_MangaFiesta_Slidebanner_840x320.jpg" alt="Slide 2">
            <img src="~/Images/Silver_0624_Ver2_ZenBooksSlide_840x320.png" alt="Slide 3">
            <img src="~/Images/Tapvo_SlideBanner_T06.jpg" alt="Slide 4">
        </div>
        <button class="slide-arrow slide-prev" id="slidePrev"><i class="fas fa-chevron-left"></i></button>
        <button class="slide-arrow slide-next" id="slideNext"><i class="fas fa-chevron-right"></i></button>
        <div class="slide-dots" id="slideDots"></div>
    </div>

    <!-- Features bar -->
    <div class="features-bar">
        <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-truck"></i></div>
            <div class="feature-text">
                <strong>Miễn phí vận chuyển</strong>
                <span>Đơn hàng trên 200K</span>
            </div>
        </div>
        <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
            <div class="feature-text">
                <strong>Hàng chính hãng</strong>
                <span>100% sách thật</span>
            </div>
        </div>
        <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
            <div class="feature-text">
                <strong>Đổi trả dễ dàng</strong>
                <span>Trong vòng 30 ngày</span>
            </div>
        </div>
        <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-headset"></i></div>
            <div class="feature-text">
                <strong>Hỗ trợ 24/7</strong>
                <span>Hotline 0000 000 000</span>
            </div>
        </div>
    </div>

    <!-- Hot Books -->
    <div class="section-head">
        <h2>📚 Sách Hot</h2>
        <a href="@Url.Action("GetAllBook","Category")" class="see-all-link">
            Xem tất cả <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    <div class="products-grid">
        @foreach (var item in Model)
        {
            var soldQty = item.SoLuongBan;
            var totalQty = item.SoLuong + 100;
            var soldPct = totalQty > 0 ? (soldQty / (float)totalQty) * 100 : 0;
            var soldPctR = Math.Round(soldPct);
            var barColor = soldPct == 100 ? "#dc2626" : soldPct >= 50 ? "#d97706" : "#16a34a";

            var reviews = item.DANHGIAs;
            var avgRating = reviews.Any() ? reviews.Average(r => r.SoSao) : 0;
            var roundRating = (int)Math.Round(avgRating);

            <div class="product-card">
                @if (totalQty == 0)
                {
                    <span class="product-badge">Hết hàng</span>
                }
                <a href="@Url.Action("Index","ProductDetail", new { id = item.MaSanPham })" class="product-img-wrap">
                    <img src="@item.Anh" alt="@item.TenSanPham" loading="lazy">
                </a>
                <div class="product-body">
                    <div class="product-title">
                        <a href="@Url.Action("Index","ProductDetail", new { id = item.MaSanPham })">
                            Sách - @Html.Raw(GetShortTitle(item.TenSanPham))
                        </a>
                    </div>
                    <div class="product-price" style="display: flex; align-items: center; gap: 6px;">
                        @String.Format(price, "{0:c0}", item.Gia)
                        <span style="background-color: #ffeae9; color: #e8392a; font-size: 11px; font-weight: 700; padding: 2px 6px; border-radius: 4px; border: 1px solid rgba(232, 57, 42, 0.2); display: inline-block;">
                            -@(new Random(item.MaSanPham).Next(10, 35))%
                        </span>
                    </div>
                    <div class="stars-row">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="fas fa-star star-icon @(i <= roundRating ? "on" : "")"></i>
                        }
                        <span class="rating-count">(@reviews.Count())</span>
                    </div>
                    <div class="sold-bar-wrap">
                        <div class="sold-bar-fill" style="width:@soldPctR%; background:@barColor;"></div>
                        <div class="sold-bar-text">Đã bán @soldQty / @totalQty</div>
                    </div>

                    @if (totalQty > 0)
                    {
                        if (user != null)
                        {
                            <a href="@Url.Action("AddSingleProduct","Cart", new { id = item.MaSanPham })" class="btn-buy-card mt-2">
                                <i class="bi bi-bag-plus me-1"></i> Thêm vào giỏ
                            </a>
                        }
                        else
                        {
                            <a href="@Url.Action("Login","User")" class="btn-buy-card mt-2">
                                <i class="bi bi-bag-plus me-1"></i> Thêm vào giỏ
                            </a>
                        }
                    }
                    else
                    {
                        <span class="btn-buy-card disabled-btn mt-2">Hết hàng</span>
                    }
                </div>
            </div>
        }
    </div>

    <div class="more-wrap">
        <a href="@Url.Action("GetAllBook","Category")" class="btn-see-more">
            <i class="bi bi-grid"></i> Xem tất cả sách
        </a>
    </div>
</div>

@section scripts {
<script>
(function() {
    const track = document.getElementById('slideTrack');
    const dotsWrap = document.getElementById('slideDots');
    const imgs = track.querySelectorAll('img');
    let cur = 0;
    const total = imgs.length;

    // Create dots
    imgs.forEach((_, i) => {
        const d = document.createElement('button');
        d.className = 'slide-dot' + (i === 0 ? ' active' : '');
        d.addEventListener('click', () => goTo(i));
        dotsWrap.appendChild(d);
    });

    function goTo(n) {
        cur = (n + total) % total;
        track.style.transform = `translateX(-${cur * 100}%)`;
        dotsWrap.querySelectorAll('.slide-dot').forEach((d, i) =>
            d.classList.toggle('active', i === cur));
    }

    document.getElementById('slidePrev').addEventListener('click', () => goTo(cur - 1));
    document.getElementById('slideNext').addEventListener('click', () => goTo(cur + 1));

    let timer = setInterval(() => goTo(cur + 1), 4500);
    document.getElementById('heroSlider').addEventListener('mouseenter', () => clearInterval(timer));
    document.getElementById('heroSlider').addEventListener('mouseleave', () => {
        timer = setInterval(() => goTo(cur + 1), 4500);
    });
})();
</script>
}

@helper GetShortTitle(string title) {
    var words = title.Split(' ');
    if (words.Length > 5)
    {
        @(string.Join(" ", words.Take(5)) + "…")
    }
    else
    {
        @title
    }
}