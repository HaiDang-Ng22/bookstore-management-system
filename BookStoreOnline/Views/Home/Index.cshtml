@using BookStoreOnline.Models
@{
    ViewBag.Title = "Trang Chủ";
}
@model List<BookStoreOnline.Models.SANPHAM>

@{
    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
    var user = Session["TaiKhoan"] as BookStoreOnline.Models.KHACHHANG;
}

@section styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        /* Hero Slideshow */
        .hero-section {
            padding: 24px 0 0;
        }

        .hero-slide-wrapper {
            border-radius: 18px;
            overflow: hidden;
            box-shadow: 0 12px 40px rgba(0,0,0,.1);
            position: relative;
            background: #f5f6fa;
            cursor: pointer;
        }

        .slide-track {
            display: flex;
            transition: transform .55s cubic-bezier(.4,0,.2,1);
        }

            .slide-track img {
                width: 100%;
                flex-shrink: 0;
                height: auto;
                display: block;
                object-fit: cover;
            }

        .slide-arrow {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            width: 44px;
            height: 44px;
            border-radius: 50%;
            background: rgba(255,255,255,.92);
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            color: #1e293b;
            box-shadow: 0 4px 16px rgba(0,0,0,.12);
            transition: .25s;
            z-index: 10;
        }

            .slide-arrow:hover {
                background: #e8392a;
                color: #fff;
            }

        .slide-prev {
            left: 14px;
        }

        .slide-next {
            right: 14px;
        }

        .slide-dots {
            position: absolute;
            bottom: 14px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 7px;
        }

        .slide-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            background: rgba(255,255,255,.55);
            border: none;
            cursor: pointer;
            transition: .25s;
        }

            .slide-dot.active {
                background: #fff;
                width: 24px;
                border-radius: 4px;
            }

        /* Feature badges */
        .features-bar {
            display: flex;
            gap: 16px;
            margin: 20px 0 32px;
            flex-wrap: wrap;
        }
        .feature-item {
            flex: 1;
            min-width: 160px;
            background: #fff;
            border-radius: 14px;
            padding: 16px 18px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 2px 12px rgba(0,0,0,.05);
            border: 1px solid #f1f5f9;
        }

        .feature-icon {
            width: 44px;
            height: 44px;
            border-radius: 12px;
            background: #fef2f2;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            color: #e8392a;
            flex-shrink: 0;
        }

        .feature-text strong {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: #111827;
        }

        .feature-text span {
            font-size: 12px;
            color: #9ca3af;
        }

        /* Section heading */
        .section-head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin: 36px 0 20px;
        }

            .section-head h2 {
                font-size: 22px;
                font-weight: 800;
                color: #111827;
                position: relative;
                padding-bottom: 10px;
                margin: 0;
            }

                .section-head h2::after {
                    content: '';
                    position: absolute;
                    bottom: 0;
                    left: 0;
                    width: 44px;
                    height: 3.5px;
                    background: linear-gradient(135deg,#e8392a,#ff6b5b);
                    border-radius: 2px;
                }

        .see-all-link {
            color: #e8392a;
            font-size: 13px;
            font-weight: 600;
            display: flex;
            align-items: center;
            gap: 5px;
            transition: .2s;
            text-decoration: none;
        }

            .see-all-link:hover {
                gap: 8px;
                color: #c0281c;
                text-decoration: none;
            }

        /* Product grid */
        .products-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 18px;
        }

        @@media(max-width:991px) {
            .products-grid {
                grid-template-columns: repeat(3,1fr);
            }
        }

        @@media(max-width:767px) {
            .products-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media(max-width:480px) {
            .products-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Product card */
        .product-card {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 14px rgba(0,0,0,.06);
            border: 1px solid #f1f5f9;
            transition: .3s;
            display: flex;
            flex-direction: column;
            position: relative;
        }

            .product-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 36px rgba(0,0,0,.12);
            }

        .product-img-wrap {
            background: #fafafa;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 210px;
            overflow: hidden;
            padding: 12px;
        }

            .product-img-wrap img {
                max-height: 186px;
                width: auto;
                object-fit: contain;
                transition: transform .4s ease;
            }

        .product-card:hover .product-img-wrap img {
            transform: scale(1.06);
        }

        .product-badge {
            position: absolute;
            top: 12px;
            left: 12px;
            background: rgba(220,38,38,.88);
            color: #fff;
            font-size: 10px;
            font-weight: 700;
            padding: 3px 8px;
            border-radius: 5px;
            text-transform: uppercase;
            letter-spacing: .5px;
        }

        .product-body {
            padding: 14px 14px 16px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .product-title {
            font-size: 14px;
            font-weight: 600;
            color: #1e293b;
            line-height: 1.4;
            margin-bottom: 8px;
        }
    /* More btn */
    .more-wrap { display: flex; justify-content: center; margin: 36px 0 56px; }
    .btn-see-more {
        display: flex; align-items: center; gap: 8px;
        padding: 0 32px; height: 46px; border-radius: 999px;
        border: 1.5px solid #e8392a; color: #e8392a;
        background: #fff; font-size: 14px; font-weight: 700;
        cursor: pointer; transition: .25s; text-decoration: none;
    }
    .btn-see-more:hover { background: linear-gradient(135deg,#e8392a,#ff6b5b); color: #fff !important; border-color: transparent; box-shadow: 0 6px 20px rgba(232,57,42,.25); transform: translateY(-2px); text-decoration: none; }

    /* Top 5 selling books */
    .top-books-title {
        font-size: 24px;
        font-weight: 800;
        color: #111827;
        text-align: center;
        margin: 50px 0 32px 0;
    }

    .champion-book-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        border: 1px solid #e5e7eb;
        padding: 30px;
        max-width: 500px;
        margin: 0 auto 40px auto;
        text-align: center;
        position: relative;
    }

    .champion-badge {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: #fff;
        font-weight: 800;
        font-size: 12px;
        text-transform: uppercase;
        padding: 6px 16px;
        border-radius: 999px;
        box-shadow: 0 4px 12px rgba(245,158,11,0.3);
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .champion-book-card img {
        max-height: 220px;
        object-fit: contain;
        margin: 10px auto 20px auto;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        border-radius: 8px;
    }

    .champion-book-card h3 {
        font-size: 18px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 6px;
    }

    .champion-book-card .author {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 10px;
    }

    .champion-book-card .price {
        font-size: 18px;
        font-weight: 800;
        color: #e8392a;
        margin-bottom: 0;
    }

    .sub-book-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        padding: 20px;
        text-align: center;
        height: 100%;
        transition: transform 0.25s;
    }

        .sub-book-card:hover {
            transform: translateY(-4px);
        }

        .sub-book-card img {
            height: 140px;
            object-fit: contain;
            margin: 0 auto 16px auto;
            box-shadow: 0 4px 10px rgba(0,0,0,0.06);
            border-radius: 6px;
        }

        .sub-book-card h4 {
            font-size: 14px;
            font-weight: 700;
            color: #111827;
            line-height: 1.4;
            margin-bottom: 6px;
            height: 38px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
            .product-title a {
                color: inherit;
                text-decoration: none;
            }

                .product-title a:hover {
                    color: #e8392a;
                }

        .product-price {
            font-size: 17px;
            font-weight: 800;
            color: #e8392a;
            margin-bottom: 8px;
        }

        .stars-row {
            display: flex;
            align-items: center;
            gap: 4px;
            margin-bottom: 8px;
        }

        .star-icon {
            font-size: 11px;
            color: #e2e8f0;
        }

            .star-icon.on {
                color: #f59e0b;
            }

        .rating-count {
            font-size: 11px;
            color: #9ca3af;
            margin-left: 4px;
        }

        .sold-bar-wrap {
            width: 100%;
            height: 12px;
            background: #f1f5f9;
            border-radius: 999px;
            overflow: hidden;
            position: relative;
            margin: 6px 0 4px;
        }

        .sold-bar-fill {
            height: 100%;
            border-radius: 999px;
            position: absolute;
            left: 0;
            top: 0;
        }

        .sold-bar-text {
            position: absolute;
            width: 100%;
            text-align: center;
            font-size: 9px;
            font-weight: 700;
            color: #1e293b;
            line-height: 12px;
            z-index: 2;
        }

        .btn-buy-card {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 38px;
            border-radius: 999px;
            background: linear-gradient(135deg,#e8392a,#ff6b5b);
            color: #fff;
            font-size: 13px;
            font-weight: 700;
            border: none;
            cursor: pointer;
            margin-top: auto;
            text-decoration: none;
            transition: .25s;
            box-shadow: 0 4px 12px rgba(232,57,42,.2);
        }

            .btn-buy-card:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(232,57,42,.3);
                color: #fff;
                text-decoration: none;
            }

            .btn-buy-card.disabled-btn {
                opacity: .45;
                pointer-events: none;
                background: #94a3b8;
                box-shadow: none;
            }

        /* More btn */
        .more-wrap {
            display: flex;
            justify-content: center;
            margin: 36px 0 56px;
        }

        .btn-see-more {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 0 32px;
            height: 46px;
            border-radius: 999px;
            border: 1.5px solid #e8392a;
            color: #e8392a;
            background: #fff;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: .25s;
            text-decoration: none;
        }

            .btn-see-more:hover {
                background: linear-gradient(135deg,#e8392a,#ff6b5b);
                color: #fff !important;
                border-color: transparent;
                box-shadow: 0 6px 20px rgba(232,57,42,.25);
                transform: translateY(-2px);
                text-decoration: none;
            }
        .sub-book-card .author {
            font-size: 12px;
            color: #6b7280;
            margin-bottom: 8px;
        }

        .sub-book-card .price {
            font-size: 14.5px;
            font-weight: 800;
            color: #e8392a;
            margin: 0;
        }

    .cta-container {
        text-align: center;
        margin-top: 50px;
    }

    .btn-explore {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 50px;
        padding: 0 36px;
        border-radius: 999px;
        background: linear-gradient(135deg, #e8392a 0%, #ff6b5b 100%);
        color: #fff;
        font-weight: 700;
        font-size: 15px;
        box-shadow: 0 4px 14px rgba(232,57,42,0.22);
        transition: all 0.25s;
        }

        .btn-explore:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(232,57,42,0.32);
            color: #fff;
            text-decoration: none;
        }
</style>
    }

<div class="container hero-section">
    <!-- Slideshow -->
    <div class="hero-slide-wrapper" id="heroSlider">
        <div class="slide-track" id="slideTrack">
            <img src="~/Images/Cardgame_Slide_T6_840x320.jpg" alt="Slide 1">
            <img src="~/Images/MangaWeek_T524_MangaFiesta_Slidebanner_840x320.jpg" alt="Slide 2">
            <img src="~/Images/Silver_0624_Ver2_ZenBooksSlide_840x320.png" alt="Slide 3">
            <img src="~/Images/Tapvo_SlideBanner_T06.jpg" alt="Slide 4">
        </div>
        <button class="slide-arrow slide-prev" id="slidePrev"><i class="fas fa-chevron-left"></i></button>
        <button class="slide-arrow slide-next" id="slideNext"><i class="fas fa-chevron-right"></i></button>
        <div class="slide-dots" id="slideDots"></div>
    </div>

    <!-- Features bar -->
    <div class="features-bar">
        <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-truck"></i></div>
            <div class="feature-text">
                <strong>Miễn phí vận chuyển</strong>
                <span>Đơn hàng trên 200K</span>
            </div>
        </div>
        <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-shield-check"></i></div>
            <div class="feature-text">
                <strong>Hàng chính hãng</strong>
                <span>100% sách thật</span>
            </div>
        </div>
        <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-arrow-counterclockwise"></i></div>
            <div class="feature-text">
                <strong>Đổi trả dễ dàng</strong>
                <span>Trong vòng 30 ngày</span>
            </div>
        </div>
        <div class="feature-item">
            <div class="feature-icon"><i class="bi bi-headset"></i></div>
            <div class="feature-text">
                <strong>Hỗ trợ 24/7</strong>
                <span>Hotline 0000 000 000</span>
            </div>
        </div>
    </div>
    <!-- Top Selling Books -->
    @if (Model != null && Model.Count > 0)
    {
        <h2 class="top-books-title"><i class="bi bi-trophy-fill text-warning mr-2"></i> Top 5 Sách Bán Chạy Nhất</h2>

        <div class="champion-book-card">
            <span class="champion-badge"><i class="bi bi-award-fill"></i> Sách bán chạy nhất </span>
            <a href="@Url.Action("Index", "ProductDetail", new { id = Model[0].MaSanPham })">
                <img src="@Model[0].Anh" alt="@Model[0].TenSanPham" />
            </a>
            <h3><a href="@Url.Action("Index", "ProductDetail", new { id = Model[0].MaSanPham })" class="text-dark">@Model[0].TenSanPham</a></h3>
            <p class="author">Tác giả: <strong>@Model[0].TacGia</strong></p>
            <p class="price">@String.Format("{0:0,0} đ", Model[0].Gia)</p>
        </div>

        <div class="row">
            @for (int i = 1; i < 5 && i < Model.Count; i++)
            {
                <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                    <div class="sub-book-card">
                        <a href="@Url.Action("Index", "ProductDetail", new { id = Model[i].MaSanPham })">
                            <img src="@Model[i].Anh" alt="@Model[i].TenSanPham" />
                        </a>
                        <h4><a href="@Url.Action("Index", "ProductDetail", new { id = Model[i].MaSanPham })" class="text-dark">@Model[i].TenSanPham</a></h4>
                        <p class="author">Tác giả: @Model[i].TacGia</p>
                        <p class="price">@String.Format("{0:0,0} đ", Model[i].Gia)</p>
                    </div>
                </div>
            }
        </div>
    }

    <!-- Hot Books -->
    <div class="section-head">
        <h2>📚 Sách Hot</h2>
        <a href="@Url.Action("GetAllBook","Category")" class="see-all-link">
            Xem tất cả <i class="bi bi-arrow-right"></i>
        </a>
    </div>

    <!-- Thanh bộ lọc và sắp xếp ngang ở trang chủ -->
    <div class="card border-0 shadow-sm p-4 mb-4" style="border-radius: 18px; background: #fff; height: auto !important;">
        <form action="@Url.Action("Index", "Home")" method="get" class="row align-items-end">
            <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
                <label style="font-size: 12px; font-weight: 600; color: #475569; margin-bottom: 6px;">Giá từ (đ)</label>
                <input type="number" name="minPrice" class="form-control" value="@ViewBag.MinPrice" placeholder="0" min="0" style="border-radius: 8px; font-size: 14px; height: 42px;" />
            </div>
            <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
                <label style="font-size: 12px; font-weight: 600; color: #475569; margin-bottom: 6px;">Đến giá (đ)</label>
                <input type="number" name="maxPrice" class="form-control" value="@ViewBag.MaxPrice" placeholder="500,000" min="0" style="border-radius: 8px; font-size: 14px; height: 42px;" />
            </div>
            <div class="col-md-3 col-sm-6 mb-3 mb-md-0">
                <label style="font-size: 12px; font-weight: 600; color: #475569; margin-bottom: 6px;">Sắp xếp theo giá</label>
                <select name="sortOrder" class="form-control" style="border-radius: 8px; font-size: 14px; height: 42px;">
                    <option value="" @(ViewBag.SortOrder == "" ? "selected" : "")>Mặc định</option>
                    <option value="price_asc" @(ViewBag.SortOrder == "price_asc" ? "selected" : "")>Giá: Thấp đến Cao</option>
                    <option value="price_desc" @(ViewBag.SortOrder == "price_desc" ? "selected" : "")>Giá: Cao đến Thấp</option>
                </select>
            </div>
            <div class="col-md-3 col-sm-6 d-flex">
                <button type="submit" class="btn-buy-card border-0 w-100" style="height: 42px; border-radius: 8px; margin: 0; display: flex; align-items: center; justify-content: center; font-size: 14px;">
                    <i class="fas fa-check mr-1"></i> Lọc & Sắp xếp
                </button>
                @if (ViewBag.MinPrice != null || ViewBag.MaxPrice != null || !string.IsNullOrEmpty(ViewBag.SortOrder))
                {
                    <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary d-flex align-items-center justify-content-center" style="border-radius: 8px; font-size: 14px; font-weight: 700; height: 42px; width: 60px; border: 1.5px solid #cbd5e1; color: #475569; background: #fff; margin-left: 8px;">
                        <i class="fas fa-times"></i>
                    </a>
                }
            </div>
        </form>
    </div>

    @if (Model == null || !Model.Any())
    {
        <div class="text-center py-5 shadow-sm mb-5" style="background: #fff; border-radius: 16px; border: 1px solid #f1f5f9; padding: 40px 15px; height: auto !important;">
            <i class="fas fa-search mb-3" style="font-size: 32px; color: #cbd5e1; display: block; margin: 0 auto 15px;"></i>
            <p style="color: #64748b; font-size: 15px; margin: 0;">Không tìm thấy cuốn sách nào khớp với khoảng giá của bạn.</p>
        </div>
    }
    else
    {
        <div class="products-grid">
            @foreach (var item in Model)
            {
                var soldQty = item.SoLuongBan;
                var totalQty = item.SoLuong + 100;
                var soldPct = totalQty > 0 ? (soldQty / (float)totalQty) * 100 : 0;
                var soldPctR = Math.Round(soldPct);
                var barColor = soldPct == 100 ? "#dc2626" : soldPct >= 50 ? "#d97706" : "#16a34a";

                var reviews = item.DANHGIAs;
                var avgRating = reviews.Any() ? reviews.Average(r => r.SoSao) : 0;
                var roundRating = (int)Math.Round(avgRating);

                <div class="product-card" style="height: auto !important;">
                    @if (totalQty == 0)
                    {
                        <span class="product-badge">Hết hàng</span>
                    }

                    <a href="@Url.Action("Index","ProductDetail",new { id = item.MaSanPham })" class="product-img-wrap">
                        <img src="@item.Anh" alt="@item.TenSanPham" loading="lazy">
                    </a>

                    <div class="product-body">
                        <div class="product-title">
                            <a href="@Url.Action("Index","ProductDetail",new { id = item.MaSanPham })">
                                Sách - @Html.Raw(GetShortTitle(item.TenSanPham))
                            </a>
                        </div>

                        <div class="product-price" style="display:flex;align-items:center;gap:6px;">
                            @String.Format(price, "{0:c0}", item.Gia)
                            <span style="background:#ffeae9;color:#e8392a;font-size:11px;font-weight:700;padding:2px 6px;border-radius:4px;">
                                -@(new Random(item.MaSanPham).Next(10,35))%
                            </span>
                        </div>

                        <div class="stars-row">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <i class="fas fa-star star-icon @(i <= roundRating ? "on" : "")"></i>
                            }
                            <span class="rating-count">
                                (@reviews.Count())
                            </span>
                        </div>

                        <div class="sold-bar-wrap">
                            <div class="sold-bar-fill" style="width:@soldPctR%;background:@barColor;"></div>
                            <div class="sold-bar-text">
                                Đã bán @soldQty / @totalQty
                            </div>
                        </div>

                        @if (totalQty > 0)
                        {
                            if (user != null)
                            {
                                <a href="@Url.Action("AddSingleProduct","Cart",new { id = item.MaSanPham })" class="btn-buy-card mt-2">
                                    <i class="bi bi-bag-plus me-1"></i> Thêm vào giỏ
                                </a>
                            }
                            else
                            {
                                <a href="@Url.Action("Login","User")" class="btn-buy-card mt-2">
                                    <i class="bi bi-bag-plus me-1"></i> Thêm vào giỏ
                                </a>
                            }
                        }
                        else
                        {
                            <span class="btn-buy-card disabled-btn mt-2">
                                Hết hàng
                            </span>
                        }
                    </div>
                </div>
            }
        </div>
    }

