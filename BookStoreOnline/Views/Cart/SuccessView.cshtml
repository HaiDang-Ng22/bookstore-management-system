@{
    ViewBag.Title = "Thanh toán thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .result-wrap {
        min-height: calc(100vh - 280px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 16px;
    }
    .result-card {
        background: #fff;
        border-radius: 24px;
        padding: 48px 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        text-align: center;
        max-width: 480px;
        width: 100%;
    }
    .result-icon-success {
        font-size: 64px;
        color: #16a34a;
        margin-bottom: 24px;
        display: inline-block;
        background: #dcfce7;
        width: 110px;
        height: 110px;
        line-height: 110px;
        border-radius: 50%;
    }
    .result-card h2 {
        font-size: 24px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
    }
    .result-card p {
        font-size: 14.5px;
        color: #6b7280;
        margin-bottom: 32px;
        line-height: 1.6;
    }
    .btn-action-group {
        display: flex;
        gap: 12px;
        justify-content: center;
    }
    .btn-home {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 48px;
        padding: 0 24px;
        background: linear-gradient(135deg, #e8392a 0%, #ff6b5b 100%);
        color: #fff;
        font-weight: 700;
        font-size: 14px;
        border-radius: 999px;
        box-shadow: 0 4px 14px rgba(232,57,42,0.22);
        transition: all 0.25s;
    }
    .btn-home:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(232,57,42,0.32);
        color: #fff;
    }
    .btn-orders {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 48px;
        padding: 0 24px;
        background: #fff;
        border: 1.5px solid #d1d5db;
        color: #374151;
        font-weight: 700;
        font-size: 14px;
        border-radius: 999px;
        transition: all 0.25s;
    }
    .btn-orders:hover {
        background: #f9fafb;
        border-color: #9ca3af;
        color: #111827;
    }
</style>

<div class="result-wrap">
    <div class="result-card">
        <div class="result-icon-success">
            <i class="bi bi-check-circle-fill"></i>
        </div>
        <h2>Đặt Hàng Thành Công</h2>
        <p>Cảm ơn bạn đã mua sắm tại nhà sách của chúng tôi! Đơn hàng của bạn đã được ghi nhận thành công và đang được chuẩn bị để giao tới bạn sớm nhất.</p>
        <div class="btn-action-group">
            <a href="@Url.Action("Index", "Order")" class="btn-orders">
                <i class="bi bi-box-seam"></i> Lịch sử đơn hàng
            </a>
            <a href="@Url.Action("Index", "Home")" class="btn-home">
                <i class="bi bi-house-door"></i> Về trang chủ
            </a>
        </div>
    </div>
</div>