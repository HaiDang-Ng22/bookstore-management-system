@{
    ViewBag.Title = "Giỏ hàng trống";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .empty-cart-wrap {
        min-height: calc(100vh - 280px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 16px;
    }
    .empty-cart-card {
        background: #fff;
        border-radius: 24px;
        padding: 48px 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        text-align: center;
        max-width: 460px;
        width: 100%;
    }
    .empty-cart-icon {
        font-size: 64px;
        color: #e8392a;
        margin-bottom: 20px;
        display: inline-block;
        background: #fdf2f2;
        width: 110px;
        height: 110px;
        line-height: 110px;
        border-radius: 50%;
    }
    .empty-cart-card h3 {
        font-size: 20px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
    }
    .empty-cart-card p {
        font-size: 14.5px;
        color: #6b7280;
        margin-bottom: 28px;
        line-height: 1.6;
    }
    .btn-shop-now {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 48px;
        padding: 0 32px;
        background: linear-gradient(135deg, #e8392a 0%, #ff6b5b 100%);
        color: #fff;
        font-weight: 700;
        font-size: 14.5px;
        border-radius: 999px;
        box-shadow: 0 4px 14px rgba(232,57,42,0.22);
        transition: all 0.25s;
    }
    .btn-shop-now:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(232,57,42,0.32);
        color: #fff;
    }
</style>

<div class="empty-cart-wrap">
    <div class="empty-cart-card">
        <div class="empty-cart-icon">
            <i class="bi bi-cart-x"></i>
        </div>
        <h3>Giỏ hàng của bạn đang trống</h3>
        <p>Có vẻ như bạn chưa chọn được sản phẩm ưng ý. Hãy cùng quay lại cửa hàng để lựa chọn những cuốn sách thú vị nhé!</p>
        <a href="@Url.Action("Index", "Home")" class="btn-shop-now">
            <i class="bi bi-arrow-left"></i> Quay lại mua sắm
        </a>
    </div>
</div>
