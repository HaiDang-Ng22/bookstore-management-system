@using BookStoreOnline.Models;
@model List<CartItem>
@{
    ViewBag.Title = "Giỏ Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

@{
    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
    var user = Session["TaiKhoan"] as BookStoreOnline.Models.KHACHHANG;
}

<style>
    .cart-section {
        padding: 40px 15px;
    }
    .cart-title {
        font-size: 26px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .cart-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        padding: 24px;
        margin-bottom: 30px;
    }
    .cart-table {
        width: 100%;
        border-collapse: collapse;
    }
    .cart-table th {
        font-weight: 700;
        font-size: 13px;
        text-transform: uppercase;
        color: #4b5563;
        letter-spacing: 0.5px;
        padding: 12px 16px;
        border-bottom: 1.5px solid #e5e7eb;
    }
    .cart-table td {
        padding: 20px 16px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
    }
    .cart-table tr:last-child td {
        border-bottom: none;
    }
    .cart-product {
        display: flex;
        align-items: center;
        gap: 16px;
    }
    .cart-product img {
        width: 64px;
        height: 80px;
        object-fit: contain;
        border-radius: 6px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.06);
    }
    .cart-product-title {
        font-size: 15px;
        font-weight: 700;
        color: #111827;
        margin: 0 0 4px 0;
        line-height: 1.4;
    }
    .quantity-wrapper {
        display: inline-flex;
        align-items: center;
        border: 1.5px solid #d1d5db;
        border-radius: 10px;
        overflow: hidden;
        height: 38px;
        background: #fff;
    }
    .quantity-btn {
        background: none;
        border: none;
        width: 32px;
        height: 100%;
        color: #4b5563;
        font-weight: 600;
        cursor: pointer;
        transition: background 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .quantity-btn:hover {
        background: #f1f5f9;
    }
    .quantity-input {
        border: none;
        width: 44px;
        text-align: center;
        font-weight: 700;
        color: #111827;
        outline: none;
        font-size: 14px;
    }
    .price-cell {
        font-size: 16px;
        font-weight: 800;
        color: #e8392a;
        margin: 0;
    }
    .delete-prod-btn {
        color: #9ca3af;
        font-size: 20px;
        transition: color 0.2s;
    }
    .delete-prod-btn:hover {
        color: #dc2626;
    }
    /* Summary Card */
    .summary-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        padding: 24px;
        position: sticky;
        top: 90px;
    }
    .summary-title {
        font-size: 18px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 20px;
        border-bottom: 1.5px solid #f1f5f9;
        padding-bottom: 12px;
    }
    .summary-group {
        margin-bottom: 18px;
    }
    .summary-group label {
        display: block;
        font-size: 13px;
        font-weight: 600;
        color: #374151;
        margin-bottom: 8px;
    }
    .summary-group textarea,
    .summary-group select,
    .summary-group input[type="text"] {
        width: 100%;
        border-radius: 10px;
        border: 1.5px solid #d1d5db;
        padding: 10px 14px;
        font-size: 14px;
        outline: none;
        transition: border-color 0.2s;
        background: #f9fafb;
    }
    .summary-group textarea:focus,
    .summary-group select:focus,
    .summary-group input[type="text"]:focus {
        border-color: #e8392a;
        background: #fff;
    }
    .summary-table {
        width: 100%;
        margin: 20px 0;
    }
    .summary-table td {
        padding: 8px 0;
        font-size: 14.5px;
        color: #4b5563;
    }
    .summary-table tr:last-child td {
        border-top: 1.5px solid #f1f5f9;
        padding-top: 14px;
    }
    .total-price-text {
        font-size: 22px;
        font-weight: 800;
        color: #e8392a;
        margin: 0;
    }
    .btn-checkout {
        width: 100%;
        height: 48px;
        border-radius: 999px;
        border: none;
        background: linear-gradient(135deg, #e8392a 0%, #ff6b5b 100%);
        color: #fff;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        transition: all 0.25s ease;
        box-shadow: 0 4px 14px rgba(232,57,42,0.22);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }
    .btn-checkout:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(232,57,42,0.32);
    }
    .discount-badge-box {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: #fdf2f2;
        border-radius: 8px;
        padding: 10px 14px;
        border: 1px dashed rgba(232,57,42,0.3);
        margin-top: 10px;
    }
    .discount-badge-box span {
        font-size: 13px;
        font-weight: 700;
        color: #e8392a;
    }
    #discount-amount {
        font-size: 14px;
        font-weight: 700;
        color: #16a34a;
        margin: 0;
    }
</style>

<div class="container cart-section">
    <h2 class="cart-title"><i class="bi bi-cart3"></i> Giỏ Hàng Của Bạn</h2>

    @using (Html.BeginForm("InsertOrder", "Cart", FormMethod.Post, new { @class = "checkout-form" }))
    {
        <div class="row">
            <!-- Left Column: Products -->
            <div class="col-lg-8">
                <div class="cart-card">
                    <div class="table-responsive">
                        <table class="cart-table">
                            <thead>
                                <tr>
                                    <th>Sản phẩm</th>
                                    <th>Số lượng</th>
                                    <th>Đơn giá</th>
                                    <th style="width: 50px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model)
                                {
                                    <tr class="prod-list-table">
                                        <td>
                                            <div class="cart-product">
                                                <img src="@item.ImagePro" alt="@item.NamePro">
                                                <div>
                                                    <h5 class="cart-product-title">@item.NamePro</h5>
                                                    <small class="text-muted">Mã SP: @item.ProductID</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <div class="quantity-wrapper">
                                                <button type="button" class="quantity-btn" data-action="decrease">-</button>
                                                <input type="number" name="Quantity" value="@item.Number" min="1" data-product-id="@item.ProductID" class="quantity-input">
                                                <button type="button" class="quantity-btn" data-action="increase">+</button>
                                                <input type="hidden" name="ProductID" value="@item.ProductID" />
                                            </div>
                                        </td>
                                        <td>
                                            <h5 class="price-cell" data-price="@item.FinalPrice()">@String.Format(price, "{0:c0}", item.FinalPrice())</h5>
                                            <input type="hidden" name="ProductID" value="@item.ProductID" />
                                        </td>
                                        <td class="text-right">
                                            <a href="@Url.Action("Remove", "Cart", new { id = item.ProductID })" class="delete-prod-btn"><i class="bi bi-trash3-fill"></i></a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="summary-card">
                    <h3 class="summary-title"><i class="bi bi-receipt-cutoff"></i> Thông tin đơn hàng</h3>

                    <div class="summary-group">
                        <label><i class="bi bi-geo-alt-fill text-muted mr-1"></i> Tỉnh / Thành phố</label>
                        <select id="province" class="form-control" required>
                            <option value="">-- Chọn Tỉnh / Thành phố --</option>
                        </select>
                    </div>

                    <div class="summary-group">
                        <label>Quận / Huyện</label>
                        <select id="district" class="form-control" required disabled>
                            <option value="">-- Chọn Quận / Huyện --</option>
                        </select>
                    </div>

                    <div class="summary-group">
                        <label>Phường / Xã</label>
                        <select id="ward" class="form-control" required disabled>
                            <option value="">-- Chọn Phường / Xã --</option>
                        </select>
                    </div>

                    <div class="summary-group">
                        <label>Số nhà, tên đường</label>
                        <input type="text" id="streetAddress" class="form-control" placeholder="Ví dụ: 123 Đường Lê Lợi" required />
                    </div>

                    <input type="hidden" id="address" name="address" />

                    <div class="summary-group">
                        <label for="paymentMethod1"><i class="bi bi-wallet2 text-muted mr-1"></i> Phương thức thanh toán</label>
                        <select id="paymentMethod1" name="paymentMethod1" class="form-control" required>
                            <option value="">-- Chọn phương thức thanh toán --</option>
                            <option value="cod">Thanh toán khi nhận hàng (COD)</option>
                            <option value="paypal">Thanh toán bằng PayPal</option>
                            <option value="momo">Thanh toán bằng MoMo</option>
                        </select>
                    </div>

                    <div class="summary-group">
                        <label for="discountCode"><i class="bi bi-ticket-perforated-fill text-muted mr-1"></i> Mã khuyến mãi (nếu có)</label>
                        <input type="text" id="discountCode" name="discountCode" placeholder="Nhập mã giảm giá..." />

                        <div class="discount-badge-box">
                            <span><i class="bi bi-check-circle-fill mr-1"></i> Đã giảm:</span>
                            <p id="discount-amount">0 đ</p>
                        </div>
                    </div>

                    <table class="summary-table">
                        <tr>
                            <td>Tổng số lượng:</td>
                            <td class="text-right font-weight-bold" id="total-quantity">@ViewBag.TotalNumber</td>
                        </tr>
                        <tr>
                            <td class="align-middle">Tổng thanh toán:</td>
                            <td class="text-right"><h4 class="total-price-text" id="total-price">@String.Format(price, "{0:c0}", ViewBag.TotalPrice)</h4></td>
                        </tr>
                    </table>

                    <button type="submit" class="btn-checkout">
                        <i class="bi bi-credit-card-2-front-fill"></i> Đặt Hàng Ngay
                    </button>
                </div>
            </div>
        </div>
    }
</div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var priceFormat = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' });

        var quantityInputs = document.querySelectorAll('.quantity-input');
        var priceCells = document.querySelectorAll('.price-cell');
        var totalPriceElement = document.getElementById('total-price');
        var totalQuantityElement = document.getElementById('total-quantity');
        var discountInput = document.querySelector('input[name="discountCode"]');
        var discountDetails = document.getElementById('discount-amount');

        quantityInputs.forEach(function (input) {
            var wrapper = input.closest('.quantity-wrapper');
            var increaseBtn = wrapper.querySelector('.quantity-btn[data-action="increase"]');
            var decreaseBtn = wrapper.querySelector('.quantity-btn[data-action="decrease"]');

            increaseBtn.addEventListener('click', function () {
                var currentValue = parseInt(input.value);
                updateQuantity(input, currentValue + 1);
            });

            decreaseBtn.addEventListener('click', function () {
                var currentValue = parseInt(input.value);
                if (currentValue > 1) {
                    updateQuantity(input, currentValue - 1);
                }
            });

            input.addEventListener('input', function () {
                var newValue = parseInt(input.value);
                updateQuantity(input, newValue);
            });
        });

        function updateQuantity(input, newQuantity) {
            var productId = input.dataset.productId;
            var priceCell = input.closest('tr').querySelector('.price-cell');
            var originalPrice = parseFloat(priceCell.dataset.price);

            fetch('@Url.Action("Update", "Cart")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `productId=${productId}&quantity=${newQuantity}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    var newPrice = originalPrice * newQuantity;
                    priceCell.textContent = priceFormat.format(newPrice);
                    input.value = newQuantity;
                    updateTotalPriceAndQuantity();
                } else {
                    alert(data.message);
                    input.value = data.validQuantity;
                    updateQuantity(input, data.validQuantity);
                }
            })
            .catch(error => {
                console.error('Có lỗi xảy ra:', error);
                alert('Có lỗi xảy ra khi cập nhật số lượng!');
            });
        }

        function updateTotalPriceAndQuantity() {
            var totalPrice = 0;
            var totalQuantity = 0;

            priceCells.forEach(function (cell) {
                var quantityInput = cell.closest('tr').querySelector('.quantity-input');
                var quantity = parseInt(quantityInput.value);
                totalPrice += parseFloat(cell.dataset.price) * quantity;
                totalQuantity += quantity;
            });

            var discountAmountText = discountDetails.textContent.replace(/[^\d]/g, '');
            var discountAmount = parseFloat(discountAmountText) || 0;
            totalPrice -= discountAmount;

            if (totalPrice < 0) {
                totalPrice = 0;
            }

            totalPriceElement.textContent = priceFormat.format(totalPrice);
            totalQuantityElement.textContent = totalQuantity;
        }

        discountInput.addEventListener('blur', function () {
            var discountCode = discountInput.value;
            if(!discountCode.trim()) {
                discountDetails.textContent = '0 đ';
                updateTotalPriceAndQuantity();
                return;
            }

            fetch('@Url.Action("ApplyDiscount", "Cart")', {
                method: 'POST',
                headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                body: `discountCode=${discountCode}`
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    discountDetails.textContent = priceFormat.format(data.discountAmount);
                    updateTotalPriceAndQuantity();
                } else {
                    alert(data.message);
                    discountDetails.textContent = '0 đ';
                    updateTotalPriceAndQuantity();
                }
            })
            .catch(error => {
                console.error('Có lỗi xảy ra khi áp dụng mã giảm giá:', error);
            });
        });
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const apiHost = "https://provinces.open-api.vn/api/";

        // 1. Tự động tải danh sách Tỉnh / Thành phố từ API khi load trang
        fetch(apiHost + "?depth=1")
            .then(res => res.json())
            .then(data => {
                const pSelect = document.getElementById("province");
                if (pSelect) {
                    data.forEach(item => {
                        pSelect.innerHTML += `<option value="${item.code}">${item.name}</option>`;
                    });
                }
            }).catch(err => console.error("Lỗi kết nối API tỉnh thành:", err));

        // 2. Khi người dùng chọn Tỉnh -> Tự động load danh sách Quận / Huyện tương ứng
        document.getElementById("province").addEventListener("change", function () {
            const pCode = this.value;
            const dSelect = document.getElementById("district");
            const wSelect = document.getElementById("ward");

            dSelect.innerHTML = '<option value="">-- Chọn Quận / Huyện --</option>';
            dSelect.disabled = true;
            wSelect.innerHTML = '<option value="">-- Chọn Phường / Xã --</option>';
            wSelect.disabled = true;

            if (pCode) {
                fetch(`${apiHost}p/${pCode}?depth=2`)
                    .then(res => res.json())
                    .then(data => {
                        dSelect.disabled = false;
                        data.districts.forEach(item => {
                            dSelect.innerHTML += `<option value="${item.code}">${item.name}</option>`;
                        });
                    });
            }
            gopDiaChiFull();
        });

        // 3. Khi người dùng chọn Quận -> Tự động load danh sách Phường / Xã tương ứng
        document.getElementById("district").addEventListener("change", function () {
            const dCode = this.value;
            const wSelect = document.getElementById("ward");

            wSelect.innerHTML = '<option value="">-- Chọn Phường / Xã --</option>';
            wSelect.disabled = true;

            if (dCode) {
                fetch(`${apiHost}d/${dCode}?depth=2`)
                    .then(res => res.json())
                    .then(data => {
                        wSelect.disabled = false;
                        data.wards.forEach(item => {
                            wSelect.innerHTML += `<option value="${item.code}">${item.name}</option>`;
                        });
                    });
            }
            gopDiaChiFull();
        });

        // 4. Lắng nghe sự kiện khi chọn Phường hoặc gõ Số nhà để gộp chuỗi địa chỉ
        document.getElementById("ward").addEventListener("change", gopDiaChiFull);
        document.getElementById("streetAddress").addEventListener("input", gopDiaChiFull);

        // Hàm tự động gộp chuỗi thành: "Số nhà, Phường ..., Quận ..., Tỉnh ..." để ném vào Database
        function gopDiaChiFull() {
            const pSelect = document.getElementById("province");
            const dSelect = document.getElementById("district");
            const wSelect = document.getElementById("ward");
            const streetInput = document.getElementById("streetAddress");

            const pText = pSelect.selectedIndex > 0 ? pSelect.options[pSelect.selectedIndex].text : "";
            const dText = dSelect.selectedIndex > 0 ? dSelect.options[dSelect.selectedIndex].text : "";
            const wText = wSelect.selectedIndex > 0 ? wSelect.options[wSelect.selectedIndex].text : "";
            const street = streetInput ? streetInput.value.trim() : "";

            // Nếu điền đầy đủ cả 4 trường thì mới gộp chuỗi hoàn chỉnh để lưu
            if (pText && dText && wText && street) {
                document.getElementById("address").value = `${street}, ${wText}, ${dText}, ${pText}`;
            } else {
                document.getElementById("address").value = "";
            }
        }
    });
</script>