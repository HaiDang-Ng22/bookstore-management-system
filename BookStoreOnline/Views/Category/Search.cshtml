@{
    ViewBag.Title = "Tìm kiếm";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
@model IEnumerable<BookStoreOnline.Models.SANPHAM>
@{
    var price = System.Globalization.CultureInfo.GetCultureInfo("vi-VN");
    var user = Session["TaiKhoan"] as BookStoreOnline.Models.KHACHHANG;
}

@section styles {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        .search-section {
            padding: 30px 0;
            min-height: calc(100vh - 280px);
        }

        /* Sidebar danh mục bên trái */
        .sidebar-category {
            background: #fff;
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 2px 14px rgba(0,0,0,.04);
            border: 1px solid #f1f5f9;
        }

            .sidebar-category h3 {
                font-size: 15px;
                font-weight: 700;
                color: #1e293b;
                margin-bottom: 16px;
                text-transform: uppercase;
                letter-spacing: 0.5px;
            }

        .category-list {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        .category-item {
            border-bottom: 1px solid #f1f5f9;
        }

            .category-item:last-child {
                border-bottom: none;
            }

            .category-item a {
                display: block;
                padding: 12px 0;
                color: #475569;
                font-size: 14px;
                text-decoration: none;
                transition: .2s;
            }

                .category-item a:hover {
                    color: #e8392a;
                    padding-left: 6px;
                }

        /* Tiêu đề kết quả tìm kiếm */
        .list-title {
            font-size: 20px;
            font-weight: 800;
            color: #111827;
            margin-bottom: 24px;
            position: relative;
            padding-bottom: 10px;
        }

            .list-title::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 0;
                width: 44px;
                height: 3.5px;
                background: linear-gradient(135deg,#e8392a,#ff6b5b);
                border-radius: 2px;
            }

        /* Lưới hiển thị sản phẩm */
        .products-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 18px;
        }

        /* FIX LỖI DÒNG 83: Viết dính liền @@media không khoảng trắng */
        @@media(max-width:991px) {
            .products-grid {
                grid-template-columns: repeat(2,1fr);
            }
        }

        @@media(max-width:576px) {
            .products-grid {
                grid-template-columns: 1fr;
            }
        }

        /* Thiết kế Thẻ sản phẩm chuẩn ảnh số 3 */
        .product-card {
            background: #fff;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 2px 14px rgba(0,0,0,.04);
            border: 1px solid #f1f5f9;
            transition: .3s;
            display: flex;
            flex-direction: column;
            position: relative;
            height: 100%;
        }

            .product-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 36px rgba(0,0,0,.1);
            }

        .product-img-wrap {
            background: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 220px;
            overflow: hidden;
            padding: 16px;
        }

            .product-img-wrap img {
                max-height: 100%;
                width: auto;
                object-fit: contain;
                transition: transform .4s ease;
            }

        .product-card:hover .product-img-wrap img {
            transform: scale(1.04);
        }

        .product-body {
            padding: 14px;
            display: flex;
            flex-direction: column;
            flex: 1;
        }

        .product-title {
            font-size: 14px;
            font-weight: 500;
            color: #1e293b;
            line-height: 1.4;
            margin-bottom: 12px;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
            height: 38px;
        }

            .product-title a {
                color: inherit;
                text-decoration: none;
            }

                .product-title a:hover {
                    color: #e8392a;
                }

        .price-row {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-bottom: 10px;
        }

        .product-price {
            font-size: 15px;
            font-weight: 700;
            color: #e8392a;
        }

        .discount-badge {
            background-color: #ffeae9;
            color: #e8392a;
            font-size: 11px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 4px;
        }

        .stars-row {
            display: flex;
            align-items: center;
            gap: 3px;
            margin-bottom: 10px;
        }

        .star-icon {
            font-size: 11px;
            color: #e2e8f0;
        }

            .star-icon.on {
                color: #f59e0b;
            }

        .rating-count {
            font-size: 11px;
            color: #9ca3af;
            margin-left: 4px;
        }

        /* Thanh tiến độ đã bán */
        .sold-bar-wrap {
            width: 100%;
            height: 14px;
            background: #e2e8f0;
            border-radius: 999px;
            overflow: hidden;
            position: relative;
            margin-bottom: 14px;
        }

        .sold-bar-fill {
            height: 100%;
            border-radius: 999px;
            position: absolute;
            left: 0;
            top: 0;
        }

        .sold-bar-text {
            position: absolute;
            width: 100%;
            text-align: center;
            font-size: 9px;
            font-weight: 700;
            color: #1e293b;
            line-height: 14px;
            z-index: 2;
        }

        .btn-buy-card {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 100%;
            height: 38px;
            border-radius: 8px;
            background: #e8392a;
            color: #fff;
            font-size: 14px;
            font-weight: 600;
            border: none;
            cursor: pointer;
            text-decoration: none;
            transition: .2s;
        }

            .btn-buy-card:hover {
                background: #d62f21;
                color: #fff;
                text-decoration: none;
            }

        .no-result {
            text-align: center;
            padding: 40px;
            color: #64748b;
            font-size: 15px;
            background: #fff;
            border-radius: 16px;
            border: 1px solid #e2e8f0;
        }
    </style>
}

<div class="container search-section">
    <div class="row">
        <!-- Sidebar bộ lọc khoảng giá thông minh bên trái -->
        <div class="col-lg-3 col-md-4">
            <div class="filter-sidebar">
                <h3 class="filter-title"><i class="fas fa-filter text-danger mr-1"></i> Bộ lọc theo giá</h3>
                <form action="@Url.Action("Search", "Category")" method="get">
                    <!-- Giữ lại từ khóa tìm kiếm khi khách thực hiện bấm lọc giá -->
                    <input type="hidden" name="inputString" value="@Html.Raw(ViewBag.TextSearch)" />

                    <div class="form-group" style="margin-bottom: 15px;">
                        <label style="font-size: 12px; font-weight: 600; color: #475569;">Giá từ (đ)</label>
                        <input type="number" name="minPrice" class="form-control" value="@ViewBag.MinPrice" placeholder="0" min="0" style="border-radius: 8px;" />
                    </div>
                    <div class="form-group" style="margin-bottom: 20px;">
                        <label style="font-size: 12px; font-weight: 600; color: #475569;">Đến giá (đ)</label>
                        <input type="number" name="maxPrice" class="form-control" value="@ViewBag.MaxPrice" placeholder="500,000" min="0" style="border-radius: 8px;" />
                    </div>

                    <button type="submit" class="btn-buy-card" style="width: 100%; border: none;">
                        <i class="fas fa-check mr-1"></i> Áp dụng bộ lọc
                    </button>
                </form>
            </div>
        </div>

        <!-- Lưới hiển thị danh sách sách kết quả tìm kiếm bên phải -->
        <div class="col-lg-9 col-md-8">
            <h3 class="list-title">Kết quả tìm kiếm cho: "<span class="text-danger">@ViewBag.TextSearch</span>"</h3>

            @if (Model == null || !Model.Any())
            {
                <div class="no-result">
                    <i class="fas fa-search mb-3" style="font-size: 32px; color: #cbd5e1; display: block; margin: 0 auto 15px;"></i>
                    <p>Không tìm thấy cuốn sách nào khớp với từ khóa và khoảng giá của bạn.</p>
                </div>
            }
            else
            {
                <div class="products-grid">
                    @foreach (var item in Model)
                    {
                        var soldQuantity = item.SoLuongBan;
                        // Nâng cấp: Đồng bộ chỉ số ảo hóa tổng kho hàng +100 giống hệt trang chủ Index
                        var totalQuantity = item.SoLuong + 100;
                        var percentageSold = totalQuantity > 0 ? (soldQuantity / (float)totalQuantity) * 100 : 0;
                        var roundedPercentageSold = Math.Round(percentageSold);

                        var progressBarColor = roundedPercentageSold == 100 ? "#dc2626" :
                                               roundedPercentageSold >= 50 ? "#f59e0b" :
                                               "#16a34a";

                        <div class="product-card">
                            <div class="product-img-wrap">
                                <a href="@Url.Action("Index", "ProductDetail", new { id = item.MaSanPham })">
                                    <img src="@item.Anh" alt="@item.TenSanPham" loading="lazy">
                                </a>
                            </div>

                            <div class="product-body">
                                <div class="product-title">
                                    <a href="@Url.Action("Index", "ProductDetail", new { id = item.MaSanPham })">
                                        @Html.Raw(GetShortTitle(item.TenSanPham))
                                    </a>
                                </div>

                                <div class="price-row">
                                    <span class="product-price">@String.Format(price, "{0:c0}", item.Gia)</span>
                                    <span class="discount-badge">-@(new Random(item.MaSanPham).Next(10, 25))%</span>
                                </div>

                                <div class="stars-row">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="fas fa-star star-icon @(i <= 5 ? "on" : "")"></i>
                                    }
                                    <span class="rating-count">(@item.DANHGIAs.Count.ToString())</span>
                                </div>

                                <div class="sold-bar-wrap">
                                    <div class="sold-bar-fill" style="width: @(roundedPercentageSold)%; background-color: @progressBarColor;"></div>
                                    <div class="sold-bar-text">Đã bán @soldQuantity/@totalQuantity</div>
                                </div>

                                @if (user != null)
                                {
                                    <a href="@Url.Action("AddSingleProduct", "Cart", new { id = item.MaSanPham })" class="btn-buy-card">Mua</a>
                                }
                                else
                                {
                                    <a href="@Url.Action("Login", "User")" class="btn-buy-card">Mua</a>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

@helper GetShortTitle(string title)
{
    if (string.IsNullOrEmpty(title))
    {
        <text></text>
    }
    else
    {
        var words = title.Trim().Split(' ').Where(w => !string.IsNullOrEmpty(w)).ToArray();
        if (words.Length > 5)
        {
            string shortTitle = string.Join(" ", words.Take(5)) + "...";
            <text>@shortTitle</text>
        }
        else
        {
            <text>@title</text>
        }
    }
}