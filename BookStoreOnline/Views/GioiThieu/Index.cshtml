
@model List<BookStoreOnline.Models.SANPHAM>

@{
    ViewBag.Title = "Giới Thiệu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .intro-section {
        padding: 40px 15px;
    }
    .intro-header {
        text-align: center;
        margin-bottom: 48px;
    }
    .intro-header h1 {
        font-size: 32px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
    }
    .intro-header p {
        font-size: 16px;
        color: #6b7280;
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.6;
    }
    .intro-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        padding: 32px;
        margin-bottom: 40px;
    }
    .video-container {
        position: relative;
        padding-bottom: 56.25%; /* 16:9 Aspect Ratio */
        height: 0;
        overflow: hidden;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0,0,0,0.08);
        border: 1px solid #e2e8f0;
    }
    .video-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }
    .feature-card {
        background: #fff;
        border-radius: 16px;
        padding: 24px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        height: 100%;
        transition: transform 0.25s;
    }
    .feature-card:hover {
        transform: translateY(-4px);
    }
    .feature-card h3 {
        font-size: 18px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .feature-card h3 i {
        color: #e8392a;
    }
    .feature-card p {
        font-size: 14px;
        color: #6b7280;
        line-height: 1.6;
        margin: 0;
    }
    /* Top 5 selling books */
    .top-books-title {
        font-size: 24px;
        font-weight: 800;
        color: #111827;
        text-align: center;
        margin: 50px 0 32px 0;
    }
    .champion-book-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.04);
        border: 1px solid #e5e7eb;
        padding: 30px;
        max-width: 500px;
        margin: 0 auto 40px auto;
        text-align: center;
        position: relative;
    }
    .champion-badge {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        background: linear-gradient(135deg, #fbbf24 0%, #f59e0b 100%);
        color: #fff;
        font-weight: 800;
        font-size: 12px;
        text-transform: uppercase;
        padding: 6px 16px;
        border-radius: 999px;
        box-shadow: 0 4px 12px rgba(245,158,11,0.3);
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .champion-book-card img {
        max-height: 220px;
        object-fit: contain;
        margin: 10px auto 20px auto;
        box-shadow: 0 8px 20px rgba(0,0,0,0.1);
        border-radius: 8px;
    }
    .champion-book-card h3 {
        font-size: 18px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 6px;
    }
    .champion-book-card .author {
        font-size: 14px;
        color: #6b7280;
        margin-bottom: 10px;
    }
    .champion-book-card .price {
        font-size: 18px;
        font-weight: 800;
        color: #e8392a;
        margin-bottom: 0;
    }
    .sub-book-card {
        background: #fff;
        border-radius: 16px;
        box-shadow: 0 4px 16px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        padding: 20px;
        text-align: center;
        height: 100%;
        transition: transform 0.25s;
    }
    .sub-book-card:hover {
        transform: translateY(-4px);
    }
    .sub-book-card img {
        height: 140px;
        object-fit: contain;
        margin: 0 auto 16px auto;
        box-shadow: 0 4px 10px rgba(0,0,0,0.06);
        border-radius: 6px;
    }
    .sub-book-card h4 {
        font-size: 14px;
        font-weight: 700;
        color: #111827;
        line-height: 1.4;
        margin-bottom: 6px;
        height: 38px;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .sub-book-card .author {
        font-size: 12px;
        color: #6b7280;
        margin-bottom: 8px;
    }
    .sub-book-card .price {
        font-size: 14.5px;
        font-weight: 800;
        color: #e8392a;
        margin: 0;
    }
    .cta-container {
        text-align: center;
        margin-top: 50px;
    }
    .btn-explore {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 50px;
        padding: 0 36px;
        border-radius: 999px;
        background: linear-gradient(135deg, #e8392a 0%, #ff6b5b 100%);
        color: #fff;
        font-weight: 700;
        font-size: 15px;
        box-shadow: 0 4px 14px rgba(232,57,42,0.22);
        transition: all 0.25s;
    }
    .btn-explore:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(232,57,42,0.32);
        color: #fff;
        text-decoration: none;
    }
</style>

<div class="container intro-section">
    <div class="intro-header">
        <h1>Giới Thiệu Về Chúng Tôi</h1>
        <p>Chào mừng bạn đến với Nhà Sách Online – không gian mua sắm sách trực tuyến hàng đầu, nơi hội tụ hàng ngàn tựa sách giá trị thuộc nhiều lĩnh vực.</p>
    </div>

    <!-- Video Review Section -->
    <div class="row mb-5 justify-content-center">
        <div class="col-lg-9">
            <div class="intro-card">
                <h3 class="mb-3 text-center font-weight-bold" style="font-size: 20px; color:#111827;">Review Book từ Nhà Hội Yêu Sách</h3>
                <div class="video-container">
                    <iframe src="https://www.youtube.com/embed/W4WzXp-wo74?si=odgEMlAIwvYZGH8Q" title="YouTube video player" allowfullscreen></iframe>
                </div>
            </div>
        </div>
    </div>

    <!-- Intro Text Section -->
    <div class="intro-card text-center mb-5">
        <h3 class="font-weight-bold mb-3" style="color: #111827;">Khám Phá Thế Giới Sách Cùng Chúng Tôi</h3>
        <p class="text-muted leading-relaxed" style="font-size: 15px; max-width: 850px; margin: 0 auto;">
            Chúng tôi tự hào mang đến cho quý độc giả một thư viện sách trực tuyến đa dạng và phong phú. Dù bạn đang tìm kiếm những tác phẩm văn học kinh điển, sách khoa học kỹ thuật chuyên ngành, hay những cuốn tiểu thuyết giải trí nhẹ nhàng, chúng tôi đều sẵn sàng đáp ứng. Hãy khởi đầu hành trình khám phá tri thức của bạn ngay hôm nay!
        </p>
    </div>

    <!-- Features Section -->
    <div class="row mb-5">
        <div class="col-md-4 mb-4 mb-md-0">
            <div class="feature-card">
                <h3><i class="bi bi-journal-bookmark-fill"></i> Tựa Sách Đa Dạng</h3>
                <p>Chúng tôi liên tục cập nhật những đầu sách mới ra mắt và thịnh hành trên thị trường, mang đến sự lựa chọn vô cùng phong phú cho bạn.</p>
            </div>
        </div>
        <div class="col-md-4 mb-4 mb-md-0">
            <div class="feature-card">
                <h3><i class="bi bi-star-fill"></i> Chất Lượng Đảm Bảo</h3>
                <p>Tất cả sản phẩm tại nhà sách đều là sách bản quyền chất lượng cao từ các nhà xuất bản uy tín, trang in sắc nét và đóng gói cẩn thận.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="feature-card">
                <h3><i class="bi bi-percent"></i> Ưu Đãi Hấp Dẫn</h3>
                <p>Nhiều chương trình khuyến mãi đặc biệt, mã giảm giá và dịch vụ giao hàng nhanh chóng, mang lại trải nghiệm mua sắm hoàn hảo và tiết kiệm.</p>
            </div>
        </div>
    </div>

    <!-- Top Selling Books -->
    @if (Model != null && Model.Count > 0)
    {
        <h2 class="top-books-title"><i class="bi bi-trophy-fill text-warning mr-2"></i> Top 5 Sách Bán Chạy Nhất</h2>

        <div class="champion-book-card">
            <span class="champion-badge"><i class="bi bi-award-fill"></i> Quán quân bán chạy</span>
            <a href="@Url.Action("Index", "ProductDetail", new { id = Model[0].MaSanPham })">
                <img src="@Model[0].Anh" alt="@Model[0].TenSanPham" />
            </a>
            <h3><a href="@Url.Action("Index", "ProductDetail", new { id = Model[0].MaSanPham })" class="text-dark">@Model[0].TenSanPham</a></h3>
            <p class="author">Tác giả: <strong>@Model[0].TacGia</strong></p>
            <p class="price">@String.Format("{0:0,0} đ", Model[0].Gia)</p>
        </div>

        <div class="row">
            @for (int i = 1; i < 5 && i < Model.Count; i++)
            {
                <div class="col-lg-3 col-md-6 col-sm-6 mb-4">
                    <div class="sub-book-card">
                        <a href="@Url.Action("Index", "ProductDetail", new { id = Model[i].MaSanPham })">
                            <img src="@Model[i].Anh" alt="@Model[i].TenSanPham" />
                        </a>
                        <h4><a href="@Url.Action("Index", "ProductDetail", new { id = Model[i].MaSanPham })" class="text-dark">@Model[i].TenSanPham</a></h4>
                        <p class="author">Tác giả: @Model[i].TacGia</p>
                        <p class="price">@String.Format("{0:0,0} đ", Model[i].Gia)</p>
                    </div>
                </div>
            }
        </div>
    }

    <!-- CTA Section -->
    <div class="cta-container">
        <a href="@Url.Action("GetAllBook", "Category")" class="btn-explore">
            <i class="bi bi-book-half"></i> Khám Phá Cửa Hàng Ngay
        </a>
    </div>
</div>