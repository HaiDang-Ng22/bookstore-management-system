@{
    ViewBag.Title = "Lỗi hệ thống";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .error-wrap {
        min-height: calc(100vh - 280px);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 48px 16px;
    }
    .error-card {
        background: #fff;
        border-radius: 24px;
        padding: 48px 40px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        text-align: center;
        max-width: 480px;
        width: 100%;
    }
    .error-icon {
        font-size: 64px;
        color: #dc2626;
        margin-bottom: 24px;
        display: inline-block;
        background: #fee2e2;
        width: 110px;
        height: 110px;
        line-height: 110px;
        border-radius: 50%;
    }
    .error-card h2 {
        font-size: 24px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 12px;
    }
    .error-card p {
        font-size: 14.5px;
        color: #6b7280;
        margin-bottom: 32px;
        line-height: 1.6;
    }
    .btn-home {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 48px;
        padding: 0 32px;
        background: linear-gradient(135deg, #e8392a 0%, #ff6b5b 100%);
        color: #fff;
        font-weight: 700;
        font-size: 14.5px;
        border-radius: 999px;
        box-shadow: 0 4px 14px rgba(232,57,42,0.22);
        transition: all 0.25s;
    }
    .btn-home:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(232,57,42,0.32);
        color: #fff;
        text-decoration: none;
    }
</style>

<div class="error-wrap">
    <div class="error-card">
        <div class="error-icon">
            <i class="bi bi-exclamation-triangle-fill"></i>
        </div>
        <h2>Đã Xảy Ra Lỗi</h2>
        <p>Hệ thống đã gặp sự cố trong lúc xử lý yêu cầu của bạn. Vui lòng quay lại trang chủ hoặc thử lại sau ít phút.</p>
        <a href="@Url.Action("Index", "Home")" class="btn-home">
            <i class="bi bi-house-door"></i> Quay lại trang chủ
        </a>
    </div>
</div>
