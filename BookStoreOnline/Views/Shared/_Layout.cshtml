@{
    var user = Session["TaiKhoan"] as BookStoreOnline.Models.KHACHHANG;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@(ViewBag.Title != null ? ViewBag.Title + " | " : "")Nhà Sách Online</title>
    <meta name="description" content="@(ViewBag.MetaDescription ?? "Mua sách online chất lượng cao, giá tốt tại Nhà Sách Online. Đặt hàng ngay!")">
    <meta name="keywords" content="sách, mua sách online, nhà sách, sách hay, sách giá rẻ">
    <meta name="robots" content="index, follow">
    <meta property="og:title" content="Nhà Sách Online">
    <meta property="og:description" content="Nhà sách trực tuyến cung cấp hàng nghìn đầu sách chất lượng với giá tốt nhất.">
    <link rel="icon" href="~/Images/z5482551824090_8d0041d8091c42fc59c7cfff0e837099.jpg">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <!-- Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Bootstrap 4 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
    <!-- Custom CSS -->
    <link href="~/Content/style.css" rel="stylesheet">
    <link href="~/Content/chatbot.css" rel="stylesheet" />

    <style>
        body {
            font-family: 'Inter', sans-serif !important;
            background: #f5f6fa !important;
        }

        /* ---- Top announcement bar ---- */
        .top-bar {
            background: linear-gradient(135deg, #e8392a 0%, #ff6b5b 100%);
            color: #fff;
            text-align: center;
            font-size: 12px;
            font-weight: 600;
            padding: 7px 0;
            letter-spacing: .3px;
        }

            .top-bar a {
                color: #fff;
                text-decoration: underline;
                margin-left: 6px;
            }

        /* ---- Header ---- */
        .site-header {
            background: #ffffff;
            border-bottom: 1px solid #e5e7eb;
            position: sticky;
            top: 0;
            z-index: 1000;
            box-shadow: 0 2px 12px rgba(0,0,0,.06);
        }

        .header-inner {
            display: flex;
            align-items: center;
            gap: 20px;
            padding: 12px 0;
        }

        .logo-wrap {
            flex: 0 0 auto;
        }

            .logo-wrap img {
                height: 52px;
                width: auto;
                border-radius: 8px;
                transition: .25s;
            }

                .logo-wrap img:hover {
                    transform: scale(1.04);
                }

        .search-wrap {
            flex: 1;
            max-width: 560px;
        }

            .search-wrap form {
                position: relative;
            }

        .search-input {
            width: 100%;
            height: 44px;
            border-radius: 999px;
            border: 1.5px solid #e5e7eb;
            padding: 0 52px 0 20px;
            font-size: 14px;
            font-family: 'Inter', sans-serif;
            background: #f5f6fa;
            color: #374151;
            outline: none;
            transition: .25s;
        }

            .search-input::placeholder {
                color: #9ca3af;
            }

            .search-input:focus {
                border-color: #e8392a;
                background: #fff;
                box-shadow: 0 0 0 3px rgba(232,57,42,.1);
            }

        .search-btn {
            position: absolute;
            right: 4px;
            top: 4px;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            border: none;
            background: linear-gradient(135deg,#e8392a,#ff6b5b);
            color: #fff;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: .25s;
            font-size: 14px;
        }

            .search-btn:hover {
                box-shadow: 0 4px 14px rgba(232,57,42,.4);
                transform: scale(1.08);
            }

        .header-actions {
            flex: 0 0 auto;
            display: flex;
            align-items: center;
            gap: 10px;
            margin-left: auto;
        }

        .cart-btn {
            position: relative;
            color: #e8392a;
            font-size: 26px;
            display: inline-flex;
            align-items: center;
            margin-right: 4px;
            transition: .25s;
            text-decoration: none;
        }

            .cart-btn:hover {
                color: #c0281c;
                transform: scale(1.1);
            }

        .cart-count {
            position: absolute;
            top: -6px;
            right: -10px;
            min-width: 19px;
            height: 19px;
            padding: 0 5px;
            background: #e8392a;
            color: #fff;
            border-radius: 999px;
            font-size: 10px;
            font-weight: 700;
            display: flex;
            align-items: center;
            justify-content: center;
            line-height: 1;
        }

        .btn-nav-register {
            border: 1.5px solid #e8392a !important;
            color: #e8392a !important;
            background: transparent !important;
            padding: 7px 16px !important;
            border-radius: 999px !important;
            font-weight: 600 !important;
            font-size: 13px !important;
            text-decoration: none;
            transition: .25s;
        }

            .btn-nav-register:hover {
                background: #fef2f2 !important;
                text-decoration: none;
            }

        .btn-nav-login {
            background: linear-gradient(135deg,#e8392a,#ff6b5b) !important;
            color: #fff !important;
            padding: 7px 18px !important;
            border-radius: 999px !important;
            font-weight: 700 !important;
            font-size: 13px !important;
            text-decoration: none;
            box-shadow: 0 4px 12px rgba(232,57,42,.25) !important;
            transition: .25s;
        }

            .btn-nav-login:hover {
                transform: translateY(-1px);
                box-shadow: 0 6px 20px rgba(232,57,42,.35) !important;
                text-decoration: none;
                color: #fff !important;
            }

        /* ---- Main nav ---- */
        .main-nav {
            background: #fff;
            border-bottom: 1px solid #e5e7eb;
        }

        .main-nav-inner {
            display: flex;
            align-items: center;
            gap: 4px;
            padding: 0;
        }

        .nav-link-item {
            color: #374151 !important;
            font-weight: 600;
            font-size: 14px;
            padding: 14px 16px !important;
            display: block;
            position: relative;
            text-decoration: none;
            transition: color .2s;
        }

            .nav-link-item::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 50%;
                width: 0;
                height: 2.5px;
                background: linear-gradient(135deg,#e8392a,#ff6b5b);
                transform: translateX(-50%);
                border-radius: 2px;
                transition: width .25s;
            }

            .nav-link-item:hover {
                color: #e8392a !important;
                text-decoration: none;
            }

                .nav-link-item:hover::after {
                    width: 60%;
                }

        .nav-cat-btn {
            background: linear-gradient(135deg,#e8392a,#ff6b5b);
            color: #fff;
            border-radius: 8px;
            padding: 7px 14px;
            font-size: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 8px;
            transition: .25s;
        }

            .nav-cat-btn:hover {
                opacity: .88;
                color: #fff;
            }

        /* ---- User dropdown ---- */
        .user-dropdown-toggle {
            display: flex;
            align-items: center;
            gap: 7px;
            text-decoration: none;
            color: #374151;
            font-weight: 600;
            font-size: 14px;
            padding: 4px 8px;
            border-radius: 10px;
            transition: .2s;
        }

            .user-dropdown-toggle:hover {
                background: #fef2f2;
                color: #e8392a;
                text-decoration: none;
            }

        .user-avatar {
            font-size: 26px;
            color: #e8392a;
        }

        .user-name {
            max-width: 110px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .dropdown-menu {
            border: none !important;
            border-radius: 14px !important;
            box-shadow: 0 12px 40px rgba(0,0,0,.12) !important;
            padding: 8px !important;
            min-width: 190px !important;
        }

        .dropdown-item {
            border-radius: 8px !important;
            padding: 10px 14px !important;
            font-size: 13px !important;
            font-weight: 500 !important;
            color: #374151 !important;
            transition: .2s !important;
        }

            .dropdown-item:hover {
                background: #fef2f2 !important;
                color: #e8392a !important;
            }

            .dropdown-item i {
                width: 18px;
                margin-right: 8px;
                color: #9ca3af;
            }

            .dropdown-item:hover i {
                color: #e8392a;
            }

        .dropdown-divider {
            margin: 6px 0 !important;
            border-color: #e5e7eb !important;
        }

        /* ---- Footer ---- */
        .site-footer {
            background: #fff;
            border-top: 1px solid #e5e7eb;
            padding: 56px 0 0;
            margin-top: 60px;
            color: #374151;
        }

        .footer-brand p {
            font-size: 13px;
            color: #9ca3af;
            line-height: 1.7;
            margin-top: 12px;
        }

        .footer-col h5 {
            font-size: 12px;
            font-weight: 700;
            color: #111827;
            text-transform: uppercase;
            letter-spacing: .8px;
            margin-bottom: 18px;
        }

        .footer-link {
            display: block;
            font-size: 13px;
            color: #6b7280;
            margin-bottom: 10px;
            transition: color .2s;
        }

            .footer-link:hover {
                color: #e8392a;
                text-decoration: none;
            }

        .footer-social {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }

            .footer-social a {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                background: #f5f6fa;
                color: #6b7280;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 15px;
                transition: .25s;
            }

                .footer-social a:hover {
                    background: linear-gradient(135deg,#e8392a,#ff6b5b);
                    color: #fff;
                    transform: translateY(-3px);
                }

        .footer-bottom {
            border-top: 1px solid #e5e7eb;
            margin-top: 44px;
            padding: 20px 0;
            text-align: center;
            font-size: 12px;
            color: #9ca3af;
        }
    </style>

    @RenderSection("styles", required: false)
</head>
<body>
    <!-- Top bar -->
    <div class="top-bar d-none d-md-block">
        🎉 Miễn phí vận chuyển cho đơn hàng trên 200.000đ &nbsp;|&nbsp; Giao hàng nhanh toàn quốc
        <a href="@Url.Action("GetAllBook","Category")">Mua ngay</a>
    </div>

    <!-- Header -->
    <header class="site-header">
        <div class="container header-inner">
            <!-- Logo -->
            <div class="logo-wrap d-none d-lg-block">
                <a href="@Url.Action("Index","Home")">
                    <img src="~/Images/z5482551824090_8d0041d8091c42fc59c7cfff0e837099.jpg" alt="BookStore Logo">
                </a>
            </div>

            <!-- Search -->
            <div class="search-wrap">
                @using (Html.BeginForm("Search", "Category", FormMethod.Post))
                {
                    <div style="position:relative;">
                        <!-- Đổi từ autocomplete="off" thành autocomplete="new-password" hoặc autocomplete="disabled" -->
                        <input type="text" id="inputSearchSmart" name="inputString" placeholder="Tìm kiếm sách, tác giả..." class="search-input" autocomplete="new-password">
                        <button type="submit" class="search-btn"><i class="bi bi-search"></i></button>
                    </div>
                }
            </div>

            <!-- Actions -->
            <div class="header-actions">
                <!-- Cart -->
                @if (user == null)
                {
                    <a href="@Url.Action("Login","User")" class="cart-btn">
                        <i class="bi bi-bag"></i>
                    </a>
                }
                else
                {
                    { Html.RenderAction("CartPartial", "Cart"); }
                }

                <!-- Auth or User -->
                @if (user == null)
                {
                    <a href="@Url.Action("SignUp","User")" class="btn-nav-register d-none d-sm-inline">Đăng ký</a>
                    <a href="@Url.Action("Login","User")" class="btn-nav-login">Đăng nhập</a>
                }
                else
                {
                    <div class="dropdown">
                        <a class="user-dropdown-toggle" href="#" role="button" id="userDropdown" data-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-person-circle user-avatar"></i>
                            <span class="user-name d-none d-sm-inline">@user.Ten</span>
                            <i class="bi bi-chevron-down" style="font-size:11px; color:#9ca3af;"></i>
                        </a>
                        <div class="dropdown-menu dropdown-menu-right" aria-labelledby="userDropdown">
                            <div style="padding:8px 14px 6px; border-bottom:1px solid #e5e7eb; margin-bottom:4px;">
                                <div style="font-weight:700; font-size:14px; color:#111827;">@user.Ten</div>
                                <div style="font-size:12px; color:#9ca3af;">@user.Email</div>
                            </div>
                            <a class="dropdown-item" href="@Url.Action("UpdateInfo","User")">
                                <i class="bi bi-person"></i> Thông tin cá nhân
                            </a>
                            <a class="dropdown-item" href="@Url.Action("Index/" + user.MaKH,"Order")">
                                <i class="bi bi-bag-check"></i> Đơn hàng của tôi
                            </a>
                            <a class="dropdown-item" href="@Url.Action("ChangePassword","User")">
                                <i class="bi bi-shield-lock"></i> Đổi mật khẩu
                            </a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" href="@Url.Action("LogOut","User")" style="color:#e8392a !important;">
                                <i class="bi bi-box-arrow-right" style="color:#e8392a;"></i> Đăng xuất
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </header>

    <!-- Main Nav -->
    <nav class="main-nav d-none d-lg-block">
        <div class="container">
            <div class="main-nav-inner">
                <!-- Category toggle -->
                <div style="z-index:10;">
                    @{ Html.RenderAction("GetPartialCategoryNav", "CategoryPartial"); }
                </div>

                <a class="nav-link-item" href="@Url.Action("Index","Home")">
                    <i class="bi bi-house me-1"></i> Trang chủ
                </a>
                <a class="nav-link-item" href="@Url.Action("GetAllBook","Category")">
                    <i class="bi bi-grid me-1"></i> Tất cả sản phẩm
                </a>
                <a class="nav-link-item" href="@Url.Action("Index","GioiThieu")">
                    <i class="bi bi-info-circle me-1"></i> Giới thiệu
                </a>
                <a class="nav-link-item" href="@Url.Action("Index","LienHe")">
                    <i class="bi bi-envelope me-1"></i> Liên hệ
                </a>
                <a class="nav-link-item" href="@Url.Action("Index","UserChat")">
                    <i class="bi bi-chat-square-text me-1"></i> Trợ giúp
                </a>
            </div>
        </div>
    </nav>

    <!-- Page content -->
    <main>
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" style="border-radius: 12px; border: none; background: #e6f4ea; color: #137333; font-weight: 500;">
                    <i class="bi bi-check-circle-fill mr-2" style="font-size: 16px;"></i> @TempData["SuccessMessage"]
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close" style="color: #137333; opacity: 0.8;">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            </div>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert" style="border-radius: 12px; border: none; background: #fce8e6; color: #c5221f; font-weight: 500;">
                    <i class="bi bi-exclamation-triangle-fill mr-2" style="font-size: 16px;"></i> @TempData["ErrorMessage"]
                    <button type="button" class="close" data-dismiss="alert" aria-label="Close" style="color: #c5221f; opacity: 0.8;">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="row">
                <div class="col-md-3 mb-4 footer-brand">
                    <img src="~/Images/z5482551824090_8d0041d8091c42fc59c7cfff0e837099.jpg" alt="Logo" style="height:52px; border-radius:8px;">
                    <p>Nhà sách trực tuyến chất lượng cao, mang tri thức đến mọi nhà với giá tốt nhất.</p>
                    <div class="footer-social">
                        <a href="#" title="Facebook"><i class="fab fa-facebook-f"></i></a>
                        <a href="#" title="Instagram"><i class="fab fa-instagram"></i></a>
                        <a href="#" title="YouTube"><i class="fab fa-youtube"></i></a>
                        <a href="#" title="TikTok"><i class="fab fa-tiktok"></i></a>
                    </div>
                </div>

                <div class="col-md-3 mb-4 footer-col">
                    <h5>Dịch vụ</h5>
                    <a class="footer-link" href="#">Giới thiệu về nhà sách</a>
                    <a class="footer-link" href="#">Hệ thống nhà sách</a>
                    <a class="footer-link" href="#">Điều khoản sử dụng</a>
                    <a class="footer-link" href="#">Chính sách bảo mật</a>
                    <a class="footer-link" href="#">Phương thức vận chuyển</a>
                </div>

                <div class="col-md-3 mb-4 footer-col">
                    <h5>Hỗ trợ</h5>
                    <a class="footer-link" href="#">Chính sách đổi – trả</a>
                    <a class="footer-link" href="#">Chính sách bảo hành</a>
                    <a class="footer-link" href="#">Chính sách vận chuyển</a>
                    <a class="footer-link" href="#">Phương thức thanh toán</a>
                    <a class="footer-link" href="#">Câu hỏi thường gặp</a>
                </div>

                <div class="col-md-3 mb-4 footer-col">
                    <h5>Liên hệ</h5>
                    <a class="footer-link" href="#"><i class="bi bi-geo-alt me-2" style="color:#e8392a;"></i>60-62 Lê Lợi, Q.1, TP.HCM</a>
                    <a class="footer-link" href="tel:0000000000"><i class="bi bi-telephone me-2" style="color:#e8392a;"></i>Hotline: 0000 000 000</a>
                    <a class="footer-link" href="mailto:nhasach@gmail.com"><i class="bi bi-envelope me-2" style="color:#e8392a;"></i>nhasach@gmail.com</a>
                    <div style="margin-top:16px;">
                        <img src="~/Images/donvihotro.jpg" alt="Đơn vị hỗ trợ" style="max-height:36px; border-radius:4px;" onerror="this.style.display='none'">
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container">
                <p style="margin:0;">© @DateTime.Now.Year <strong>Nhà Sách Online</strong>. Bản quyền thuộc về nhà sách. Giấy phép ĐKKD số 0304132047 – Sở KH&ĐT TP.HCM.</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/popper.js@1.16.1/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.min.js"></script>

    @Html.Partial("_ChatBot")

    @RenderSection("scripts", required: false)

    <script src="~/Scripts/chatbot.js">
    </script>

    <!-- SCRIPT ĐỘC QUYỀN: AUTO-SUGGEST TÌM KIẾM THÔNG MINH -->
    <script>
        $(document).ready(function () {
            // Tự động inject CSS cho Toast nếu chưa có
            if ($("#toast-style").length === 0) {
                $('head').append(`
                    <style id="toast-style">
                        @@keyframes slideIn {
                            to { opacity: 1; transform: translateX(0); }
                        }
                        @@keyframes fadeOut {
                            to { opacity: 0; transform: translateY(-20px); }
                        }
                    </style>
                `);
            }

            // Hàm hiển thị thông báo Toast đẹp mắt
            function showToastNotification(title, message, isError = false) {
                var $container = $('#toast-container');
                if ($container.length === 0) {
                    $('body').append('<div id="toast-container" style="position: fixed; top: 80px; right: 20px; z-index: 99999; display: flex; flex-direction: column; gap: 10px;"></div>');
                    $container = $('#toast-container');
                }
                var iconClass = isError ? 'bi-exclamation-triangle-fill text-danger' : 'bi-check-circle-fill text-success';
                var borderStyle = isError ? 'error' : '';
                
                var toastId = 'toast-' + Date.now();
                var html = `
                    <div id="${toastId}" class="custom-toast ${borderStyle}" style="min-width: 280px; background: #fff; border-radius: 12px; box-shadow: 0 10px 30px rgba(0,0,0,0.15); padding: 16px; display: flex; align-items: center; gap: 12px; border-left: 5px solid #10b981; animation: slideIn 0.3s cubic-bezier(0.4, 0, 0.2, 1) forwards; opacity: 0; transform: translateX(50px);">
                        <i class="bi ${iconClass}" style="font-size: 20px;"></i>
                        <div style="flex: 1;">
                            <div style="font-weight: 700; font-size: 14px; color: #1e293b;">${title}</div>
                            <div style="font-size: 13px; color: #64748b; margin-top: 2px;">${message}</div>
                        </div>
                        <i class="bi bi-x" style="cursor: pointer; color: #9ca3af; font-size: 16px;" onclick="closeToast('${toastId}')"></i>
                    </div>
                `;
                
                if (isError) {
                    html = html.replace('border-left: 5px solid #10b981;', 'border-left: 5px solid #ef4444;');
                }
                
                $container.append(html);
                
                setTimeout(function() {
                    closeToast(toastId);
                }, 4000);
            }

            window.closeToast = function(id) {
                var $toast = $('#' + id);
                if ($toast.length) {
                    $toast.css('animation', 'fadeOut 0.3s forwards');
                    setTimeout(function() {
                        $toast.remove();
                    }, 300);
                }
            }

            // Đánh chặn click nút "Mua" nhanh để thêm vào giỏ hàng bằng AJAX
            $(document).on('click', 'a[href*="/Cart/AddSingleProduct"], a[href*="/Cart/AddSingleProduct/"]', function (e) {
                e.preventDefault();
                var url = $(this).attr('href');
                var btn = $(this);
                
                btn.css('pointer-events', 'none').css('opacity', '0.7');
                
                $.ajax({
                    url: url,
                    type: 'GET',
                    dataType: 'json',
                    success: function (response) {
                        btn.css('pointer-events', 'auto').css('opacity', '1');
                        if (response.success) {
                            $('.quantity-prod-cart').text(response.totalNumber);
                            showToastNotification("Thành công", "Đã thêm sản phẩm vào giỏ hàng!");
                        } else {
                            showToastNotification("Thất bại", response.message || "Không thể thêm sản phẩm.", true);
                        }
                    },
                    error: function (xhr, status, error) {
                        btn.css('pointer-events', 'auto').css('opacity', '1');
                        showToastNotification("Lỗi", "Không thể thêm vào giỏ hàng hoặc chưa đăng nhập.", true);
                    }
                });
            });

            // Đánh chặn submit form "Thêm vào giỏ hàng" ở trang chi tiết sản phẩm bằng AJAX
            $(document).on('submit', 'form[action*="/Cart/AddToCart"]', function (e) {
                e.preventDefault();
                var form = $(this);
                var url = form.attr('action');
                var formData = form.serialize();
                var submitBtn = form.find('.btn-add-to-cart');
                
                submitBtn.prop('disabled', true).css('opacity', '0.7');
                
                $.ajax({
                    url: url,
                    type: 'POST',
                    data: formData,
                    dataType: 'json',
                    success: function (response) {
                        submitBtn.prop('disabled', false).css('opacity', '1');
                        if (response.success) {
                            $('.quantity-prod-cart').text(response.totalNumber);
                            showToastNotification("Thành công", "Đã thêm sản phẩm vào giỏ hàng!");
                        } else {
                            showToastNotification("Thất bại", response.message || "Không thể thêm sản phẩm.", true);
                        }
                    },
                    error: function (xhr, status, error) {
                        submitBtn.prop('disabled', false).css('opacity', '1');
                        showToastNotification("Lỗi", "Vượt quá số lượng tồn kho hoặc lỗi kết nối.", true);
                    }
                });
            });

            var $input = $("#inputSearchSmart");

            // Tự động nhúng hộp Dropdown vào bên trong div relative của form để khớp khít tọa độ 100%
            if ($("#suggestBoxSmart").length === 0) {
                $input.parent().append('<div id="suggestBoxSmart" style="position: absolute; top: 100%; left: 0; width: 100%; background: #ffffff; border: 1px solid #cbd5e1; border-radius: 8px; box-shadow: 0 10px 25px rgba(0,0,0,0.15); z-index: 99999; display: none; overflow: hidden; margin-top: 5px;"></div>');
            }
            var $box = $("#suggestBoxSmart");

            // Bắt sự kiện mỗi khi người dùng gõ phím
            $input.on("input", function () {
                var val = $(this).val().trim();

                // Nếu gõ dưới 1 ký tự hoặc xóa trắng thì ẩn hộp đi
                if (val.length < 1) {
                    $box.hide().empty();
                    return;
                }

                // Kích hoạt luồng chạy Ajax ngầm gọi về Endpoint nội bộ
                $.ajax({
                    url: '/Category/GetSuggestions',
                    type: 'GET',
                    data: { term: val },
                    dataType: 'json',
                    success: function (data) {
                        $box.empty();
                        // Nếu database báo không có sách khớp thì giấu hộp đi
                        if (!data || data.length === 0) {
                            $box.hide();
                            return;
                        }

                        // Duyệt mảng JSON để vẽ giao diện từng dòng gợi ý
                        data.forEach(function (item) {
                            var htmlItem = `
                                    <a href="/ProductDetail/Index/${item.id}" style="display: flex; align-items: center; gap: 12px; padding: 12px 15px; border-bottom: 1px solid #f1f5f9; text-decoration: none; color: #1e293b; transition: background 0.2s; box-sizing: border-box;">
                                        <img src="${item.img}" style="width: 36px; height: 48px; object-fit: contain; border-radius: 4px; background: #f8fafc;" />
                                        <div style="flex: 1; min-width: 0;">
                                            <div style="font-weight: 700; font-size: 13.5px; line-height: 1.3; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: #0f172a;">${item.title}</div>
                                            <div style="font-size: 11.5px; color: #64748b; margin-top: 2px;">👤 Tác giả: ${item.author}</div>
                                        </div>
                                        <div style="font-weight: 800; color: #e8392a; font-size: 14px; white-space: nowrap;">${item.price}</div>
                                    </a>
                                `;
                            $box.append(htmlItem);
                        });

                        // Render đổ bóng hiển thị hộp thoại
                        $box.css("display", "block");
                    },
                    error: function (err) {
                        console.log("Lỗi kết nối API GetSuggestions:", err);
                    }
                });
            });

            // Tự động đóng hộp gợi ý khi click chuột ra ngoài nền web
            $(document).on("click", function (e) {
                if (!$(e.target).closest("#inputSearchSmart, #suggestBoxSmart").length) {
                    $box.hide();
                }
            });
        });
    </script>
</body>
</html>