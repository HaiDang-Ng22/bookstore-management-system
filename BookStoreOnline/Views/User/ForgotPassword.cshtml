@model BookStoreOnline.Models.KHACHHANG
@{
    ViewBag.Title = "Quên Mật Khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.auth-wrap { min-height: calc(100vh - 280px); display:flex; align-items:center; justify-content:center; padding:48px 16px; background:linear-gradient(135deg,#fef2f2,#f5f6fa,#eff6ff); }
.auth-card { width:100%; max-width:420px; background:#fff; border-radius:24px; padding:44px 40px; box-shadow:0 20px 60px rgba(0,0,0,.10); border:1px solid #f1f5f9; }
.auth-logo-badge { width:60px;height:60px;background:linear-gradient(135deg,#e8392a,#ff6b5b);border-radius:18px;display:inline-flex;align-items:center;justify-content:center;font-size:26px;color:#fff;box-shadow:0 8px 20px rgba(232,57,42,.3); }
.auth-card h2 { font-size:24px;font-weight:800;color:#111827;text-align:center;margin-bottom:4px; }
.auth-subtitle { text-align:center;color:#9ca3af;font-size:14px;margin-bottom:28px; }
.form-field { margin-bottom:18px; }
.form-field label { display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px; }
.field-input { width:100%;height:48px;border:1.5px solid #e5e7eb;border-radius:12px;padding:0 16px;font-size:14px;font-family:'Inter',sans-serif;color:#374151;background:#f9fafb;outline:none;transition:.25s;display:block; }
.field-input:focus { border-color:#e8392a;background:#fff;box-shadow:0 0 0 3px rgba(232,57,42,.1); }
.btn-auth { width:100%;height:50px;border-radius:999px;border:none;background:linear-gradient(135deg,#e8392a,#ff6b5b);color:#fff;font-size:15px;font-weight:700;cursor:pointer;transition:.25s;box-shadow:0 6px 20px rgba(232,57,42,.25);display:flex;align-items:center;justify-content:center;gap:8px; }
.btn-auth:hover { transform:translateY(-2px);box-shadow:0 10px 28px rgba(232,57,42,.35); }
.back-link { text-align:center;font-size:14px;color:#6b7280;margin-top:20px; }
.back-link a { color:#e8392a;font-weight:600;text-decoration:none; }
.back-link a:hover { text-decoration:underline; }
.msg-success { background:#dcfce7;color:#166534;border-radius:10px;padding:12px 14px;margin-bottom:18px;font-size:13px;display:flex;align-items:center;gap:8px; }
.msg-error { background:#fee2e2;color:#991b1b;border-radius:10px;padding:12px 14px;margin-bottom:18px;font-size:13px;display:flex;align-items:center;gap:8px; }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div style="text-align:center;margin-bottom:20px;">
            <div class="auth-logo-badge"><i class="bi bi-lock"></i></div>
        </div>
        <h2>Khôi Phục Mật Khẩu</h2>
        <p class="auth-subtitle">Nhập email của bạn để nhận liên kết đặt lại mật khẩu.</p>

        @if (ViewBag.ThongBao != null)
        {
            <div class="msg-success"><i class="bi bi-check-circle-fill"></i> @ViewBag.ThongBao</div>
        }
        @if (ViewBag.Error != null)
        {
            <div class="msg-error"><i class="bi bi-exclamation-circle-fill"></i> @ViewBag.Error</div>
        }

        <form action="@Url.Action("ForgotPassword","User")" method="post">
            <div class="form-field">
                <label for="fpEmail"><i class="bi bi-envelope me-1"></i> Địa chỉ Email</label>
                <input type="email" id="fpEmail" name="email" class="field-input" placeholder="ten@email.com" required>
            </div>
            <button type="submit" class="btn-auth">
                <i class="bi bi-send"></i> Gửi Liên Kết Đặt Lại
            </button>
        </form>

        <div class="back-link">
            <a href="@Url.Action("Login","User")"><i class="bi bi-arrow-left me-1"></i> Quay lại đăng nhập</a>
        </div>
    </div>
</div>