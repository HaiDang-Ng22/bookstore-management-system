@model BookStoreOnline.Models.KHACHHANG
@{
    ViewBag.Title = "Đặt lại mật khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.auth-wrap {
    min-height: calc(100vh - 280px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 48px 16px;
    background: linear-gradient(135deg, #fef2f2 0%, #f5f6fa 50%, #eff6ff 100%);
}
.auth-card {
    width: 100%;
    max-width: 420px;
    background: #fff;
    border-radius: 24px;
    padding: 44px 40px;
    box-shadow: 0 20px 60px rgba(0,0,0,.10);
    border: 1px solid #f1f5f9;
}
.auth-logo { text-align: center; margin-bottom: 20px; }
.auth-logo-badge {
    width: 60px; height: 60px;
    background: linear-gradient(135deg,#e8392a,#ff6b5b);
    border-radius: 18px;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 28px; color: #fff; margin: 0 auto 10px;
    box-shadow: 0 8px 20px rgba(232,57,42,.3);
}
.auth-card h2 {
    font-size: 24px; font-weight: 800; color: #111827;
    text-align: center; margin-bottom: 4px;
}
.auth-subtitle { text-align: center; color: #9ca3af; font-size: 14px; margin-bottom: 28px; }
.form-field { margin-bottom: 18px; }
.form-field label {
    display: block; font-size: 13px; font-weight: 600;
    color: #374151; margin-bottom: 8px;
}
.form-field .field-input {
    width: 100%; height: 48px;
    border: 1.5px solid #e5e7eb;
    border-radius: 12px;
    padding: 0 16px;
    font-size: 14px; font-family: 'Inter',sans-serif;
    color: #374151; background: #f9fafb;
    outline: none; transition: .25s;
    display: block;
}
.form-field .field-input:focus {
    border-color: #e8392a;
    background: #fff;
    box-shadow: 0 0 0 3px rgba(232,57,42,.1);
}
.btn-auth {
    width: 100%; height: 50px;
    border-radius: 999px;
    border: none;
    background: linear-gradient(135deg,#e8392a,#ff6b5b);
    color: #fff; font-size: 15px; font-weight: 700;
    cursor: pointer; transition: .25s;
    box-shadow: 0 6px 20px rgba(232,57,42,.25);
    margin-top: 4px;
    display: flex; align-items: center; justify-content: center; gap: 8px;
}
.btn-auth:hover { transform: translateY(-2px); box-shadow: 0 10px 28px rgba(232,57,42,.35); }
.alert-custom {
    border-radius: 10px; border: none; font-size: 13px;
    padding: 12px 14px; margin-bottom: 18px;
    background: #fee2e2; color: #991b1b;
    display: flex; align-items: center; gap: 8px;
}
.alert-custom-success {
    border-radius: 10px; border: none; font-size: 13px;
    padding: 12px 14px; margin-bottom: 18px;
    background: #dcfce7; color: #166534;
    display: flex; align-items: center; gap: 8px;
}
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div class="auth-logo">
            <div class="auth-logo-badge"><i class="bi bi-shield-lock"></i></div>
        </div>
        <h2>Đặt Lại Mật Khẩu</h2>
        <p class="auth-subtitle">Nhập mật khẩu mới của bạn để đặt lại quyền truy cập.</p>

        @if (ViewBag.ThongBao != null)
        {
            var isSuccess = ViewBag.ThongBao.ToString().Contains("thành công");
            <div class="@(isSuccess ? "alert-custom-success" : "alert-custom")">
                <i class="bi @(isSuccess ? "bi-check-circle-fill" : "bi-exclamation-circle-fill")"></i>
                @ViewBag.ThongBao
            </div>
        }

        @using (Html.BeginForm("ResetPassword", "User", FormMethod.Post))
        {
            @Html.AntiForgeryToken()
            <input type="hidden" name="token" value="@ViewBag.Token" />

            <div class="form-field">
                <label for="newPassword">Mật khẩu mới</label>
                <div style="position:relative;">
                    <input type="password" name="newPassword" id="newPassword" class="field-input" placeholder="Nhập mật khẩu mới" required style="padding-right:44px;">
                    <button type="button" onclick="togglePass('newPassword', this)"
                        style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:#9ca3af;cursor:pointer;font-size:16px;padding:0;">
                        <i class="bi bi-eye-slash"></i>
                    </button>
                </div>
            </div>

            <div class="form-field">
                <label for="confirmPassword">Xác nhận mật khẩu</label>
                <div style="position:relative;">
                    <input type="password" name="confirmPassword" id="confirmPassword" class="field-input" placeholder="Xác nhận mật khẩu" required style="padding-right:44px;">
                    <button type="button" onclick="togglePass('confirmPassword', this)"
                        style="position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:#9ca3af;cursor:pointer;font-size:16px;padding:0;">
                        <i class="bi bi-eye-slash"></i>
                    </button>
                </div>
            </div>

            <button type="submit" class="btn-auth">
                <i class="bi bi-check-lg"></i> Cập Nhật Mật Khẩu
            </button>
        }
    </div>
</div>

@section scripts {
<script>
function togglePass(inputId, btn) {
    const input = document.getElementById(inputId);
    const icon = btn.querySelector('i');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye';
    } else {
        input.type = 'password';
        icon.className = 'bi bi-eye-slash';
    }
}
</script>
}