@{
    ViewBag.Title = "Đổi Mật Khẩu";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
.auth-wrap { min-height:calc(100vh - 280px); display:flex; align-items:center; justify-content:center; padding:48px 16px; background:linear-gradient(135deg,#fef2f2,#f5f6fa,#eff6ff); }
.auth-card { width:100%; max-width:440px; background:#fff; border-radius:24px; padding:44px 40px; box-shadow:0 20px 60px rgba(0,0,0,.10); border:1px solid #f1f5f9; }
.auth-logo-badge { width:60px;height:60px;background:linear-gradient(135deg,#e8392a,#ff6b5b);border-radius:18px;display:inline-flex;align-items:center;justify-content:center;font-size:26px;color:#fff;box-shadow:0 8px 20px rgba(232,57,42,.3); }
.auth-card h2 { font-size:24px;font-weight:800;color:#111827;text-align:center;margin-bottom:4px; }
.auth-subtitle { text-align:center;color:#9ca3af;font-size:14px;margin-bottom:28px; }
.form-field { margin-bottom:16px; }
.form-field label { display:block;font-size:13px;font-weight:600;color:#374151;margin-bottom:7px; }
.pass-wrap { position:relative; }
.field-input { width:100%;height:48px;border:1.5px solid #e5e7eb;border-radius:12px;padding:0 44px 0 14px;font-size:14px;font-family:'Inter',sans-serif;color:#374151;background:#f9fafb;outline:none;transition:.25s;display:block; }
.field-input:focus { border-color:#e8392a;background:#fff;box-shadow:0 0 0 3px rgba(232,57,42,.1); }
.pass-toggle { position:absolute;right:14px;top:50%;transform:translateY(-50%);background:none;border:none;color:#9ca3af;cursor:pointer;font-size:16px;padding:0; }
.btn-auth { width:100%;height:50px;border-radius:999px;border:none;background:linear-gradient(135deg,#e8392a,#ff6b5b);color:#fff;font-size:15px;font-weight:700;cursor:pointer;transition:.25s;box-shadow:0 6px 20px rgba(232,57,42,.25);display:flex;align-items:center;justify-content:center;gap:8px;margin-top:8px; }
.btn-auth:hover { transform:translateY(-2px);box-shadow:0 10px 28px rgba(232,57,42,.35); }
.msg-success { background:#dcfce7;color:#166534;border-radius:10px;padding:12px 14px;margin-bottom:18px;font-size:13px;display:flex;align-items:center;gap:8px; }
.msg-error { background:#fee2e2;color:#991b1b;border-radius:10px;padding:12px 14px;margin-bottom:18px;font-size:13px;display:flex;align-items:center;gap:8px; }
.strength-bar { height:4px;border-radius:4px;background:#e5e7eb;margin-top:6px;overflow:hidden; }
.strength-fill { height:100%;border-radius:4px;transition:.3s; width:0; }
</style>

<div class="auth-wrap">
    <div class="auth-card">
        <div style="text-align:center;margin-bottom:20px;">
            <div class="auth-logo-badge"><i class="bi bi-shield-lock"></i></div>
        </div>
        <h2>Đổi Mật Khẩu</h2>
        <p class="auth-subtitle">Để bảo mật tài khoản, không chia sẻ mật khẩu với người khác.</p>

        @if (ViewBag.ThongBao != null)
        {
            <div class="msg-error"><i class="bi bi-exclamation-circle-fill"></i> @ViewBag.ThongBao</div>
        }
        @if (ViewBag.ThongBaoSuccess != null)
        {
            <div class="msg-success"><i class="bi bi-check-circle-fill"></i> @ViewBag.ThongBaoSuccess</div>
        }

        <form method="post">
            @Html.AntiForgeryToken()
            <div class="form-field">
                <label>Mật khẩu hiện tại</label>
                <div class="pass-wrap">
                    <input type="password" id="oldPw" name="oldPassword" class="field-input" placeholder="••••••••" required>
                    <button type="button" class="pass-toggle" onclick="togglePw('oldPw',this)"><i class="bi bi-eye-slash"></i></button>
                </div>
            </div>
            <div class="form-field">
                <label>Mật khẩu mới</label>
                <div class="pass-wrap">
                    <input type="password" id="newPw" name="newPassword" class="field-input" placeholder="••••••••" required oninput="checkStrength(this.value)">
                    <button type="button" class="pass-toggle" onclick="togglePw('newPw',this)"><i class="bi bi-eye-slash"></i></button>
                </div>
                <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                <div id="strengthLabel" style="font-size:11px;color:#9ca3af;margin-top:4px;"></div>
            </div>
            <div class="form-field">
                <label>Xác nhận mật khẩu mới</label>
                <div class="pass-wrap">
                    <input type="password" id="confirmPw" name="confirmPassword" class="field-input" placeholder="••••••••" required>
                    <button type="button" class="pass-toggle" onclick="togglePw('confirmPw',this)"><i class="bi bi-eye-slash"></i></button>
                </div>
            </div>
            <button type="submit" class="btn-auth">
                <i class="bi bi-check-circle"></i> Cập Nhật Mật Khẩu
            </button>
        </form>
    </div>
</div>

@section scripts {
<script>
function togglePw(id, btn) {
    const el = document.getElementById(id);
    const icon = btn.querySelector('i');
    el.type = el.type === 'password' ? 'text' : 'password';
    icon.className = el.type === 'password' ? 'bi bi-eye-slash' : 'bi bi-eye';
}
function checkStrength(val) {
    const fill = document.getElementById('strengthFill');
    const label = document.getElementById('strengthLabel');
    let strength = 0;
    if (val.length >= 8) strength++;
    if (/[A-Z]/.test(val)) strength++;
    if (/[0-9]/.test(val)) strength++;
    if (/[^A-Za-z0-9]/.test(val)) strength++;
    const colors = ['#dc2626','#f59e0b','#16a34a','#16a34a'];
    const labels = ['Yếu','Trung bình','Mạnh','Rất mạnh'];
    fill.style.width = (strength * 25) + '%';
    fill.style.background = colors[strength - 1] || '#e5e7eb';
    label.textContent = strength > 0 ? labels[strength - 1] : '';
    label.style.color = colors[strength - 1] || '#9ca3af';
}
</script>
}