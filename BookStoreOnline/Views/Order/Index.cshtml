@model IEnumerable<BookStoreOnline.Models.DONHANG>
@{ ViewBag.Title = "Đơn hàng của tôi"; Layout = "~/Views/Shared/_Layout.cshtml"; }
<style>
    .orders-page{max-width:920px;margin:0 auto;padding:46px 16px 70px}.orders-head{margin-bottom:22px}.orders-head h2{font-size:28px;font-weight:800;color:#172033;margin:0 0 6px}.orders-head p{color:#718096;margin:0}.orders-card{background:#fff;border:1px solid #e5eaf0;border-radius:14px;overflow:hidden;box-shadow:0 6px 22px rgba(25,35,55,.05)}.order-row{display:grid;grid-template-columns:1fr 1fr auto;align-items:center;gap:24px;padding:20px 22px;border-bottom:1px solid #edf0f4}.order-row:last-child{border-bottom:0}.order-label{display:block;color:#8a94a6;font-size:12px;font-weight:700;text-transform:uppercase;letter-spacing:.04em;margin-bottom:4px}.order-value{color:#1b2538;font-size:15px;font-weight:700}.view-btn{display:inline-flex;align-items:center;gap:7px;padding:10px 16px;border-radius:9px;background:#ef4438;color:#fff;font-weight:700;text-decoration:none;white-space:nowrap}.view-btn:hover{background:#d9362c;color:#fff;text-decoration:none}.empty-order{text-align:center;padding:60px 20px;color:#7b8798}.notice{padding:13px 16px;border-radius:10px;margin-bottom:16px}.notice-success{background:#eaf8ef;color:#18733a}.notice-error{background:#fff0ef;color:#a62921}@@media(max-width:650px){.order-row{grid-template-columns:1fr auto;gap:12px}.order-date{grid-column:1}.order-action{grid-column:2;grid-row:1/3}}
</style>
<main class="orders-page">
    <div class="orders-head"><h2>Đơn hàng của tôi</h2><p>Theo dõi và xem lại các đơn hàng bạn đã đặt.</p></div>
    @if(TempData["SuccessMessage"]!=null){<div class="notice notice-success">@TempData["SuccessMessage"]</div>}
    @if(TempData["ErrorMessage"]!=null){<div class="notice notice-error">@TempData["ErrorMessage"]</div>}
    <section class="orders-card">
        @if(Model != null && Model.Any()){
            foreach(var order in Model){
                <article class="order-row">
                    <div><span class="order-label">Mã đơn hàng</span><span class="order-value">#@order.MaDonHang</span></div>
                    <div class="order-date"><span class="order-label">Ngày / giờ đặt</span><span class="order-value">@(order.NgayDat?.ToString("dd/MM/yyyy - HH:mm") ?? "Chưa cập nhật")</span></div>
                    <div class="order-action"><a class="view-btn" href="@Url.Action("Details","Order",new{id=order.MaDonHang})"><i class="bi bi-eye"></i> Xem chi tiết</a></div>
                </article>
            }
        }else{<div class="empty-order"><i class="bi bi-bag" style="font-size:38px"></i><p class="mt-3 mb-0">Bạn chưa có đơn hàng nào.</p></div>}
    </section>
</main>
