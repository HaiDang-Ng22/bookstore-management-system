@model BookStoreOnline.Models.DONHANG

@{
    ViewBag.Title = "Chi Tiết Đơn Hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .details-section {
        padding: 40px 15px;
        min-height: calc(100vh - 280px);
    }
    .details-title {
        font-size: 26px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 24px;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .details-card {
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.03);
        border: 1px solid #e5e7eb;
        padding: 24px;
        margin-bottom: 30px;
    }
    .details-card h4 {
        font-size: 18px;
        font-weight: 800;
        color: #111827;
        margin-bottom: 20px;
        border-bottom: 1.5px solid #f1f5f9;
        padding-bottom: 12px;
    }
    .details-table {
        width: 100%;
        border-collapse: collapse;
    }
    .details-table th {
        font-weight: 700;
        font-size: 13px;
        text-transform: uppercase;
        color: #4b5563;
        letter-spacing: 0.5px;
        padding: 12px 16px;
        border-bottom: 1.5px solid #e5e7eb;
    }
    .details-table td {
        padding: 16px;
        vertical-align: middle;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14.5px;
    }
    .details-table tr:last-child td {
        border-bottom: none;
    }
    .prod-thumb {
        width: 60px;
        height: 75px;
        object-fit: contain;
        border-radius: 6px;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }
    .info-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }
    .info-list li {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #f1f5f9;
        font-size: 14.5px;
        color: #4b5563;
    }
    .info-list li:last-child {
        border-bottom: none;
    }
    .info-list li strong {
        color: #111827;
    }
    .badge-status {
        font-size: 12.5px;
        font-weight: 700;
        padding: 4px 10px;
        border-radius: 999px;
    }
    .badge-status-pending { background: #fee2e2; color: #991b1b; }
    .badge-status-success { background: #dcfce7; color: #166534; }
    .badge-status-info { background: #dbeafe; color: #1e40af; }
    
    .btn-back {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        height: 44px;
        padding: 0 20px;
        border-radius: 10px;
        background: #fff;
        border: 1.5px solid #d1d5db;
        color: #374151;
        font-weight: 700;
        font-size: 14px;
        transition: all 0.2s;
    }
    .btn-back:hover {
        background: #f9fafb;
        color: #111827;
        text-decoration: none;
    }
</style>

<div class="container details-section">
    <h2 class="details-title"><i class="bi bi-file-earmark-text"></i> Chi Tiết Đơn Hàng</h2>

    @if (Model != null)
    {
        <div class="row">
            <!-- Left Column: Products in order -->
            <div class="col-lg-8">
                <div class="details-card">
                    <h4>Sản phẩm trong đơn hàng</h4>
                    <div class="table-responsive">
                        <table class="details-table">
                            <thead>
                                <tr>
                                    <th>Hình ảnh</th>
                                    <th>Tên sản phẩm</th>
                                    <th>Số lượng</th>
                                    <th>Đơn giá</th>
                                    <th class="text-right">Thành tiền</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.CHITIETDONHANGs)
                                {
                                    <tr>
                                        <td>
                                            <img src="@(item.SANPHAM?.Anh ?? "/images/no-image.png")" alt="@item.SANPHAM?.TenSanPham" class="prod-thumb" />
                                        </td>
                                        <td class="font-weight-bold" style="max-width: 250px;">
                                            @(item.SANPHAM != null ? item.SANPHAM.TenSanPham : "Sản phẩm đã xóa")
                                        </td>
                                        <td>@item.SoLuong</td>
                                        <td>@((item.SANPHAM?.Gia ?? 0).ToString("N0")) VNĐ</td>
                                        <td class="text-right font-weight-bold text-danger">@(((item.SoLuong ?? 0) * (item.SANPHAM?.Gia ?? 0)).ToString("N0")) VNĐ</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- Right Column: Order Summary Info -->
            <div class="col-lg-4">
                <div class="details-card">
                    <h4>Thông tin đơn hàng</h4>
                    <ul class="info-list">
                        <li>
                            <span>Mã đơn hàng:</span>
                            <strong>#@Model.MaDonHang</strong>
                        </li>
                        <li>
                            <span>Ngày đặt:</span>
                            <strong>@(Model.NgayDat?.ToString("dd/MM/yyyy") ?? "Chưa cập nhật")</strong>
                        </li>
                        <li>
                            <span>Tổng tiền:</span>
                            <strong class="text-danger font-weight-bold">@(Model.TongTien.ToString("N0")) VNĐ</strong>
                        </li>
                        <li>
                            <span>Trạng thái giao hàng:</span>
                            <span class="badge-status @(Model.TrangThai == 0 ? "badge-status-pending" : Model.TrangThai == 1 ? "badge-status-info" : Model.TrangThai == 2 ? "badge-status-info" : Model.TrangThai == 3 ? "badge-status-success" : "badge-status-pending")">
                                @(Model.TrangThai == 0 ? "Chờ xác nhận" : Model.TrangThai == 1 ? "Đã xác nhận" : Model.TrangThai == 2 ? "Đang giao" : Model.TrangThai == 3 ? "Đã nhận" : "Đã hủy")
                            </span>
                        </li>
                        <li>
                            <span>Trạng thái thanh toán:</span>
                            <span class="badge-status @(Model.TrangThaiThanhToan == 0 ? "badge-status-pending" : Model.TrangThaiThanhToan == 1 ? "badge-status-success" : "badge-status-pending")">
                                @(Model.TrangThaiThanhToan == 0 ? "Chưa thanh toán" : Model.TrangThaiThanhToan == 1 ? "Đã thanh toán" : "Đã hủy")
                            </span>
                        </li>
                    </ul>
                </div>
                
                <div class="mt-2 text-center text-lg-left">
                    <a href="@Url.Action("Index", "Order")" class="btn-back">
                        <i class="bi bi-arrow-left"></i> Quay lại lịch sử đơn hàng
                    </a>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-danger text-center">Không tìm thấy thông tin đơn hàng này.</div>
    }
</div>
