@model BookStoreOnline.Models.DONHANG
@using BookStoreOnline.Areas.Admin.Constants
@{ ViewBag.Title="Chi tiết đơn hàng"; Layout="~/Views/Shared/_Layout.cshtml"; var vi=System.Globalization.CultureInfo.GetCultureInfo("vi-VN"); }
<style>
 .detail-page{max-width:1100px;margin:0 auto;padding:42px 16px 70px}.back-link{display:inline-flex;align-items:center;gap:7px;color:#64748b;font-weight:700;text-decoration:none;margin-bottom:18px}.back-link:hover{color:#ef4438;text-decoration:none}.detail-title{display:flex;justify-content:space-between;align-items:center;gap:16px;margin-bottom:22px}.detail-title h2{font-size:27px;font-weight:800;color:#172033;margin:0}.status-pill{display:inline-flex;padding:7px 12px;border-radius:999px;font-size:13px;font-weight:800;background:#eef2ff;color:#3f51a3}.detail-grid{display:grid;grid-template-columns:minmax(0,1.55fr) minmax(300px,.8fr);gap:20px}.panel{background:#fff;border:1px solid #e5eaf0;border-radius:14px;padding:22px;box-shadow:0 6px 22px rgba(25,35,55,.04);margin-bottom:20px}.panel h3{font-size:17px;font-weight:800;color:#1d2739;margin:0 0 18px}.product-table{width:100%;border-collapse:collapse}.product-table th{padding:10px 8px;border-bottom:1px solid #e7ebf0;color:#7c8798;font-size:12px;text-transform:uppercase}.product-table td{padding:14px 8px;border-bottom:1px solid #f0f2f5;vertical-align:middle}.product-table tr:last-child td{border-bottom:0}.product{display:flex;align-items:center;gap:12px}.product img{width:52px;height:68px;object-fit:cover;border-radius:7px;border:1px solid #edf0f3}.product-name{font-weight:700;color:#253047}.info-row{display:flex;justify-content:space-between;gap:18px;padding:11px 0;border-bottom:1px solid #edf0f3}.info-row:last-child{border-bottom:0}.info-row span{color:#768195}.info-row strong{text-align:right;color:#202a3c}.total-row{font-size:18px}.total-row strong{color:#ef4438}.cancel-box{border-color:#ffd5d1;background:#fffafa}.cancel-box p{font-size:14px;color:#697386}.cancel-box textarea{width:100%;border:1px solid #d9dee7;border-radius:9px;padding:10px 12px;resize:vertical;margin:8px 0 12px}.cancel-btn{width:100%;border:0;border-radius:9px;background:#d9382e;color:#fff;padding:11px;font-weight:800;cursor:pointer}.cancel-btn:hover{background:#bd2d25}.locked{padding:13px;border-radius:9px;background:#f4f6f8;color:#697386;font-size:14px}.notice{padding:13px 16px;border-radius:10px;margin-bottom:18px}.notice-success{background:#eaf8ef;color:#18733a}.notice-error{background:#fff0ef;color:#a62921}@@media(max-width:850px){.detail-grid{grid-template-columns:1fr}.detail-title{align-items:flex-start;flex-direction:column}.product-table th:nth-child(3),.product-table td:nth-child(3){display:none}}
</style>
<main class="detail-page">
 <a class="back-link" href="@Url.Action("Index","Order")"><i class="bi bi-arrow-left"></i> Quay lại đơn hàng</a>
 @if(TempData["SuccessMessage"]!=null){<div class="notice notice-success">@TempData["SuccessMessage"]</div>}
 @if(TempData["ErrorMessage"]!=null){<div class="notice notice-error">@TempData["ErrorMessage"]</div>}
 <div class="detail-title"><h2>Đơn hàng #@Model.MaDonHang</h2><span class="status-pill">@OrderStatus(Model.TrangThai)</span></div>
 <div class="detail-grid"><div>
  <section class="panel"><h3>Sản phẩm đã đặt</h3><div class="table-responsive"><table class="product-table"><thead><tr><th>Sản phẩm</th><th>Số lượng</th><th>Đơn giá</th><th>Thành tiền</th></tr></thead><tbody>
  @foreach(var item in Model.CHITIETDONHANGs){var qty=item.SoLuong??0;var unit=item.SANPHAM?.Gia??0;<tr><td><div class="product"><img src="@(item.SANPHAM?.Anh??"/images/no-image.png")" alt=""><span class="product-name">@(item.SANPHAM?.TenSanPham??"Sản phẩm")</span></div></td><td>@qty</td><td>@String.Format(vi,"{0:c0}",unit)</td><td><strong>@String.Format(vi,"{0:c0}",qty*unit)</strong></td></tr>}
  </tbody></table></div></section>
  <section class="panel"><h3>Thông tin nhận hàng</h3><div class="info-row"><span>Khách hàng</span><strong>@(Model.KHACHHANG?.Ten??"Chưa cập nhật")</strong></div><div class="info-row"><span>Số điện thoại</span><strong>@(Model.KHACHHANG?.SoDienThoai??"Chưa cập nhật")</strong></div><div class="info-row"><span>Địa chỉ giao hàng</span><strong>@Model.DiaChi</strong></div></section>
 </div><aside>
  <section class="panel"><h3>Thông tin đơn hàng</h3><div class="info-row"><span>Mã đơn</span><strong>#@Model.MaDonHang</strong></div><div class="info-row"><span>Ngày / giờ đặt</span><strong>@(Model.NgayDat?.ToString("dd/MM/yyyy - HH:mm")??"Chưa cập nhật")</strong></div><div class="info-row"><span>Trạng thái</span><strong>@OrderStatus(Model.TrangThai)</strong></div><div class="info-row"><span>Thanh toán</span><strong>@PaymentStatus(Model.TrangThaiThanhToan)</strong></div><div class="info-row"><span>Phương thức</span><strong>@PaymentMethod(Model.PhuongThucThanhToan)</strong></div><div class="info-row total-row"><span>Tổng thanh toán</span><strong>@String.Format(vi,"{0:c0}",Model.TongTien)</strong></div></section>
  @if(Model.TrangThai==(int)Constants.StatusOrder.NoInform){<section class="panel cancel-box"><h3>Hủy đơn hàng</h3><p>Bạn chỉ có thể hủy trước khi người bán xác nhận đơn.</p><form method="post" action="@Url.Action("Delete","Order")" onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn hàng này?');">@Html.AntiForgeryToken()<input type="hidden" name="id" value="@Model.MaDonHang"><label for="reason"><strong>Lý do hủy</strong></label><textarea id="reason" name="reason" rows="3" required maxlength="255" placeholder="Nhập lý do hủy đơn..."></textarea><button class="cancel-btn" type="submit"><i class="bi bi-x-circle"></i> Hủy đơn hàng</button></form></section>}
  else if(Model.TrangThai!=(int)Constants.StatusOrder.Canceled){<div class="locked"><i class="bi bi-lock"></i> Đơn đã được người bán xác nhận nên không thể hủy.</div>}
 </aside></div>
</main>
@functions{
 string OrderStatus(int? s){switch(s){case 0:return "Chưa xác nhận";case 1:return "Đã xác nhận";case 2:return "Đang giao hàng";case 3:return "Đã giao hàng";case 4:return "Đã hủy";case 5:return "Giao thất bại";case 6:return "Hẹn giao lại";case 7:return "Đang hoàn hàng";case 8:return "Đã hoàn hàng";default:return "Chưa cập nhật";}}
 string PaymentStatus(int s){switch(s){case 0:return "Chưa thanh toán";case 1:return "Đã thanh toán";case 2:return "Hoàn tiền";default:return "Chưa cập nhật";}}
 string PaymentMethod(int p){switch(p){case 1:return "Thanh toán khi nhận hàng (COD)";case 2:return "VNPAY";case 3:return "Chuyển khoản / Ví điện tử";default:return "Chưa cập nhật";}}
}
